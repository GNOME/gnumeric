#: ../plugins/fn-eng/functions.c:1426
msgid "ERF:Gauss error function"
msgstr "ERF:Gauss' fejlfunktion"

#: ../plugins/fn-eng/functions.c:1427
msgid "lower:lower limit of the integral, defaults to 0"
msgstr "lower:nedre grænse for integralet, standardværdi er 0"

#: ../plugins/fn-eng/functions.c:1428
msgid "upper:upper limit of the integral"
msgstr "upper:øvre grænse for integralet"

#: ../plugins/fn-eng/functions.c:1429
msgid ""
"ERF returns 2/sqrt(π)* integral from @{lower} to @{upper} of exp(-t*t) dt"
msgstr ""
"ERF returnerer 2/sqrt(π)* integralet fra @{lower} til @{upper} af exp(-t*t) "
"dt"

#: ../plugins/fn-eng/functions.c:1435 ../plugins/fn-eng/functions.c:1463
msgid "wiki:en:Error_function"
msgstr ""

#: ../plugins/fn-eng/functions.c:1457
msgid "ERFC:Complementary Gauss error function"
msgstr "ERFC:Komplementær Gauss' fejlfunktion"

#: ../plugins/fn-eng/functions.c:1459
msgid "ERFC returns 2/sqrt(π)* integral from @{x} to ∞ of exp(-t*t) dt"
msgstr "ERFC returnerer 2/sqrt(π)* integral fra @{x} til ∞ af exp(-t*t) dt"

#: ../plugins/fn-eng/functions.c:1478
msgid "DELTA:Kronecker delta function"
msgstr "DELTA:Kroneckers deltafunktion"

#: ../plugins/fn-eng/functions.c:1479 ../plugins/fn-eng/functions.c:1502
msgid "x0:number"
msgstr "x0:tal"

#: ../plugins/fn-eng/functions.c:1480 ../plugins/fn-eng/functions.c:1503
msgid "x1:number, defaults to 0"
msgstr "x1:tal, standardværdi er 0"

#: ../plugins/fn-eng/functions.c:1481
msgid "DELTA  returns 1 if  @{x1} = @{x0} and 0 otherwise."
msgstr "DELTA returnerer 1 hvis @{x1} = @{x0} og 0 ellers."

#: ../plugins/fn-eng/functions.c:1482 ../plugins/fn-eng/functions.c:1505
msgid "If either argument is non-numeric, #VALUE! is returned."
msgstr ""
"Hvis ingen af argumenterne er ikkenumeriske, så returneres fejlen #VÆRDI!"

#: ../plugins/fn-eng/functions.c:1501
msgid "GESTEP:step function with step at @{x1} evaluated at @{x0}"
msgstr "GESTEP:Trinfunktion med trin ved @{x1} evalueret ved @{x0}"

#: ../plugins/fn-eng/functions.c:1504
msgid "GESTEP returns 1 if  @{x1} ≤ @{x0} and 0 otherwise."
msgstr "GESTEP returnerer 1 hvis @{x1} ≤ @{x0} og 0 ellers."

