msgstr "Hvis @{x} eller @{y} ikke er heltal, afkortes de."

#: ../plugins/fn-stat/functions.c:5089
msgid "LKSTEST:Lilliefors (Kolmogorov-Smirnov) Test of Normality"
msgstr "LKSTEST:Lilliefors (Kolmogorov-Smirnov) test for normalitet"

#: ../plugins/fn-stat/functions.c:5090 ../plugins/fn-stat/functions.c:5208
#: ../plugins/fn-stat/functions.c:5293 ../plugins/fn-stat/functions.c:5377
msgid "x:array of sample values"
msgstr "x:matrix af stikprøveværdier"

#: ../plugins/fn-stat/functions.c:5091
msgid ""
"This function returns an array with the first row giving the p-value of the "
"Lilliefors (Kolmogorov-Smirnov) Test, the second row the test statistic of "
"the test, and the third the number of observations in the sample."
msgstr ""
"Denne funktion returnerer en matrix hvor den første række giver p-værdien "
"for Lilliefors (Kolmogorov-Smirnov)-testen, den anden række testens "
"teststatistik og den tredje antallet af observationer i stikprøven."

#: ../plugins/fn-stat/functions.c:5093
msgid "If there are less than 5 sample values, LKSTEST returns #VALUE!"
msgstr ""
"Hvis der er færre end fem eksempelværdier, så returnerer LKSTEST #VÆRDI!"

#: ../plugins/fn-stat/functions.c:5095
msgid "wiki:en:Lilliefors_test"
msgstr ""

#: ../plugins/fn-stat/functions.c:5207
msgid "SFTEST:Shapiro-Francia Test of Normality"
msgstr "SFTEST:Shapiro-Francia-test for normalitet"

