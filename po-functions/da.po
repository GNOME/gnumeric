msgstr "STDEV:Stikprøve-standardafvigelse for den givne stikprøve"

#: ../plugins/fn-stat/functions.c:111
msgid "STDEV is also known as the N-1-standard deviation."
msgstr "STDEV er også kendt som N-1-standardafvigelsen."

#: ../plugins/fn-stat/functions.c:112
msgid ""
"To obtain the population standard deviation of a whole population use STDEVP."
msgstr ""
"For at få populations-standardafvigelsen af en hel population skal du bruge "
"STDEVP."

#: ../plugins/fn-stat/functions.c:116 ../plugins/fn-stat/functions.c:144
msgid "wiki:en:Standard_deviation"
