#: ../plugins/fn-info/functions.c:64
msgid "CELL:information of @{type} about @{cell}"
msgstr "CELL:Information af typen @{type} om @{cell}"

#: ../plugins/fn-info/functions.c:65
msgid "type:string specifying the type of information requested"
msgstr "type:streng der angiver den ønskede informationstype"

#: ../plugins/fn-info/functions.c:66
msgid "cell:cell reference"
msgstr "cell:cellereference"

#: ../plugins/fn-info/functions.c:67
msgid ""
"@{type} specifies the type of information you want to obtain:\n"
"  address        \t\tReturns the given cell reference as text.\n"
"  col            \t\tReturns the number of the column in @{cell}.\n"
"  color          \t\tReturns 0.\n"
"  contents       \t\tReturns the contents of the cell in @{cell}.\n"
"  column         \t\tReturns the number of the column in @{cell}.\n"
"  columnwidth    \tReturns the column width.\n"
"  coord          \t\tReturns the absolute address of @{cell}.\n"
"  datatype       \tsame as type\n"
"  filename       \t\tReturns the name of the file of @{cell}.\n"
"  format         \t\tReturns the code of the format of the cell.\n"
"  formulatype    \tsame as type\n"
"  locked         \t\tReturns 1 if @{cell} is locked.\n"
"  parentheses    \tReturns 1 if @{cell} contains a negative value\n"
"                 \t\tand its format displays it with parentheses.\n"
"  prefix         \t\tReturns a character indicating the horizontal\n"
"                 \t\talignment of @{cell}.\n"
"  prefixcharacter  \tsame as prefix\n"
"  protect        \t\tReturns 1 if @{cell} is locked.\n"
"  row            \t\tReturns the number of the row in @{cell}.\n"
"  sheetname      \tReturns the name of the sheet of @{cell}.\n"
"  type           \t\tReturns \"l\" if @{cell} contains a string, \n"
"                 \t\t\"v\" if it contains some other value, and \n"
"                 \t\t\"b\" if @{cell} is blank.\n"
"  value          \t\tReturns the contents of the cell in @{cell}.\n"
"  width          \t\tReturns the column width."
msgstr ""

#: ../plugins/fn-info/functions.c:363
msgid "EXPRESSION:expression in @{cell} as a string"
msgstr "EXPRESSION:Udtryk i @{cell} som en tekststreng"

#: ../plugins/fn-info/functions.c:364
msgid "cell:a cell reference"
msgstr "cell:en cellereference"

#: ../plugins/fn-info/functions.c:365
msgid "If @{cell} contains no expression, EXPRESSION returns empty."
msgstr "Hvis @{cell} ikke indeholder et udtryk, så returnerer EXPRESSION tom."

#: ../plugins/fn-info/functions.c:400
msgid "GET.FORMULA:the formula in @{cell} as a string"
msgstr "GET.FORMULA:Formlen i @{cell} som en tekststreng"

#: ../plugins/fn-info/functions.c:401 ../plugins/fn-info/functions.c:443
#: ../plugins/fn-info/functions.c:1019
msgid "cell:the referenced cell"
msgstr "cell:den refererede celle"

#: ../plugins/fn-info/functions.c:402
msgid "GET.FORMULA is the OpenFormula function FORMULA."
msgstr "GET.FORMULA er OpenFormula-funktionen FORMULA."

#: ../plugins/fn-info/functions.c:403
msgid ""
"If A1 is empty and A2 contains =B1+B2, then\n"
"GET.FORMULA(A2) yields '=B1+B2' and\n"
"GET.FORMULA(A1) yields ''."
msgstr ""
"Hvis A1 er tom og A2 indeholder =B1+B2, så\n"
"giver GET.FORMULA(A2) '=B1+B2' og\n"
"GET.FORMULA(A1) giver ''."

#: ../plugins/fn-info/functions.c:442
msgid "ISFORMULA:TRUE if @{cell} contains a formula"
msgstr "ISFORMULA:SAND hvis @{cell} indeholder en formel"

#: ../plugins/fn-info/functions.c:444
msgid "ISFORMULA is OpenFormula compatible."
msgstr "ISFORMULA er kompatibel med OpenFormula."

#: ../plugins/fn-info/functions.c:473
msgid "COUNTBLANK:the number of blank cells in @{range}"
msgstr "COUNTBLANK:Antallet af tomme celler i @{range}"

#: ../plugins/fn-info/functions.c:474
msgid "range:a cell range"
msgstr "range:et celleinterval"

#: ../plugins/fn-info/functions.c:476
msgid "COUNTBLANK(A1:A20) returns the number of blank cell in A1:A20."
msgstr "COUNTBLANK(A1:A20) returnerer antallet af tomme celler i A1:A20."

#: ../plugins/fn-info/functions.c:528
msgid ""
"INFO:information about the current operating environment according to @{type}"
msgstr "INFO:Information om det aktuelle driftsmiljø i henhold til @{type}"

#: ../plugins/fn-info/functions.c:530
msgid "type:string giving the type of information requested"
msgstr "type:streng der giver den ønskede informationstype"

#: ../plugins/fn-info/functions.c:531
msgid ""
"INFO returns information about the current operating environment according "
"to @{type}:\n"
"  memavail     \t\tReturns the amount of memory available, bytes.\n"
"  memused      \tReturns the amount of memory used (bytes).\n"
"  numfile      \t\tReturns the number of active worksheets.\n"
"  osversion    \t\tReturns the operating system version.\n"
"  recalc       \t\tReturns the recalculation mode (automatic).\n"
"  release      \t\tReturns the version of Gnumeric as text.\n"
"  system       \t\tReturns the name of the environment.\n"
"  totmem       \t\tReturns the amount of total memory available."
msgstr ""

#: ../plugins/fn-info/functions.c:627
msgid "ISERROR:TRUE if @{value} is any error value"
msgstr "ISERROR:SAND hvis @{value} er en fejlværdi"

#: ../plugins/fn-info/functions.c:628 ../plugins/fn-info/functions.c:646
#: ../plugins/fn-info/functions.c:668 ../plugins/fn-info/functions.c:763
#: ../plugins/fn-info/functions.c:801 ../plugins/fn-info/functions.c:819
#: ../plugins/fn-info/functions.c:836 ../plugins/fn-info/functions.c:875
#: ../plugins/fn-info/functions.c:905 ../plugins/fn-info/functions.c:955
msgid "value:a value"
msgstr "value:en værdi"

#: ../plugins/fn-info/functions.c:645
msgid "ISNA:TRUE if @{value} is the #N/A error value"
msgstr "ISNA:SAND hvis @{value} er fejlværdien #N/A"

#: ../plugins/fn-info/functions.c:667
msgid "ISERR:TRUE if @{value} is any error value except #N/A"
msgstr "ISERR:SAND hvis @{value} er en fejlværdi undtagen #N/A"

#: ../plugins/fn-info/functions.c:686
msgid "ERROR.TYPE:the type of @{error}"
msgstr "ERROR.TYPE:Typen af @{error}"

#: ../plugins/fn-info/functions.c:687
msgid "error:an error"
msgstr "error:En fejl"

#: ../plugins/fn-info/functions.c:688
msgid ""
"ERROR.TYPE returns an error number corresponding to the given error value.  "
"The error numbers for error values are:\n"
"\n"
"\t#NULL!    \t1\n"
"\t#DIV/0!   \t2\n"
"\t#VALUE!   \t3\n"
"\t#REF!     \t4\n"
"\t#NAME?    \t5\n"
"\t#NUM!     \t6\n"
"\t#N/A      \t7\n"
"\t#GETTING_DATA\t8\n"
"\t#SPILL!   \t9"
msgstr ""
"ERROR.TYPE returnerer et fejlnummer som svarer til en given fejlværdi.  "
"Fejlnumrene for fejlværdierne er:\n"
"\n"
"\t#NUL!     \t1\n"
"\t#DIV/0!   \t2\n"
"\t#VÆRDI!   \t3\n"
"\t#REF!     \t4\n"
"\t#NAVN?    \t5\n"
"\t#TAL!     \t6\n"
"\t#N/A      \t7\n"
"\t#GETTING_DATA\t8\n"
"\t#SPILL!   \t9"

#: ../plugins/fn-info/functions.c:727
msgid "NA:the error value #N/A"
msgstr "NA:Fejlværdien #N/A"

#: ../plugins/fn-info/functions.c:745
msgid "ERROR:the error with the given @{name}"
msgstr "ERROR:Fejlen med det givne @{name}"

#: ../plugins/fn-info/functions.c:746
msgid "name:string"
msgstr "name:streng"

#: ../plugins/fn-info/functions.c:762
msgid "ISBLANK:TRUE if @{value} is blank"
msgstr "ISBLANK:SAND hvis @{value} er tom"

#: ../plugins/fn-info/functions.c:764
msgid ""
"This function checks if a value is blank.  Empty cells are blank, but empty "
"strings are not."
msgstr ""
"Denne funktion kontrollerer om en værdi er blank. Tomme celler er blanke, "
"men tomme strenge er ikke."

#: ../plugins/fn-info/functions.c:779
msgid "ISEVEN:TRUE if @{n} is even"
msgstr "ISEVEN:SAND hvis @{n} er lige"

#: ../plugins/fn-info/functions.c:780 ../plugins/fn-info/functions.c:854
#: ../plugins/fn-math/functions.c:1478
msgid "n:number"
msgstr "n:tal"

#: ../plugins/fn-info/functions.c:800
msgid "ISLOGICAL:TRUE if @{value} is a logical value"
msgstr "ISLOGICAL:SAND hvis @{value} er en logisk værdi"

#: ../plugins/fn-info/functions.c:802
msgid "This function checks if a value is either TRUE or FALSE."
msgstr "Denne funktion kontrollerer om en værdi enten er SAND eller FALSK."

#: ../plugins/fn-info/functions.c:818
msgid "ISNONTEXT:TRUE if @{value} is not text"
msgstr "ISNONTEXT:SAND hvis @{value} ikke er tekst"

#: ../plugins/fn-info/functions.c:835
msgid "ISNUMBER:TRUE if @{value} is a number"
msgstr "ISNUMBER:SAND hvis @{value} er et tal"

#: ../plugins/fn-info/functions.c:837
msgid ""
"This function checks if a value is a number.  Neither TRUE nor FALSE are "
"numbers for this purpose."
msgstr ""
"Denne funktion kontrollerer om en værdi er et tal. Hverken SAND eller FALSK "
"er tal til dette formål."

#: ../plugins/fn-info/functions.c:853
msgid "ISODD:TRUE if @{n} is odd"
msgstr "ISODD:SAND hvis @{n} er ulige"

#: ../plugins/fn-info/functions.c:874
msgid "ISREF:TRUE if @{value} is a reference"
msgstr "ISREF:SAND hvis @{value} er en reference"

#: ../plugins/fn-info/functions.c:876
msgid "This function checks if a value is a cell reference."
msgstr "Denne funktion kontrollerer om en værdi er en cellereference."

#: ../plugins/fn-info/functions.c:904
msgid "ISTEXT:TRUE if @{value} is text"
msgstr "ISTEXT:SAND hvis @{value} er tekst"

#: ../plugins/fn-info/functions.c:922
msgid "N:@{text} converted to a number"
msgstr "N:@{text} konverteret til et tal"

