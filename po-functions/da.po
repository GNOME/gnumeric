msgid "x:code point"
msgstr "x:kodepunkt"

#: ../plugins/fn-string/functions.c:56
msgid "CHAR(@{x}) returns the CP1252 (Windows-1252) character with code @{x}."
msgstr "CHAR(@{x}) returnerer CP1252-tegnet (Windows-1252) med kode @{x}."

