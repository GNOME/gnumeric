#: ../plugins/fn-christian-date/functions.c:130
msgid ""
"EASTERSUNDAY:Easter Sunday in the Gregorian calendar according to the Roman "
"rite of the Christian Church"
msgstr ""
"EASTERSUNDAY:Påskesøndag i den gregorianske kalender efter den romersk-"
"katolske ritus"

#: ../plugins/fn-christian-date/functions.c:132
msgid ""
"year:year between 1582 and 9956, defaults to the year of the next Easter "
"Sunday"
msgstr ""
"year:år mellem 1582 og 9956, standardværdi er året for næste påskesøndag"

#: ../plugins/fn-christian-date/functions.c:133
#: ../plugins/fn-christian-date/functions.c:156
#: ../plugins/fn-christian-date/functions.c:176
#: ../plugins/fn-christian-date/functions.c:195
#: ../plugins/fn-christian-date/functions.c:214
msgid ""
"Two digit years are adjusted as elsewhere in Gnumeric. Dates before 1904 may "
"also be prohibited."
msgstr ""
"Tocifrede årstal justeres som andre steder i Gnumeric. Datoer før 1904 kan "
"også være forbudt."

#: ../plugins/fn-christian-date/functions.c:136
msgid ""
"The 1-argument version of EASTERSUNDAY is compatible with OpenOffice for "
"years after 1904. This function is not specified in ODF/OpenFormula."
msgstr ""
"EASTERSUNDAY-versionen med 1 argument er kompatibel med OpenOffice for år "
"efter 1904. Denne funktion er ikke angivet i ODF/OpenFormula."

#: ../plugins/fn-christian-date/functions.c:153
msgid ""
"ASHWEDNESDAY:Ash Wednesday in the Gregorian calendar according to the Roman "
"rite of the Christian Church"
msgstr ""
"ASHWEDNESDAY:Askeonsdag i den gregorianske kalender efter den romersk-"
"katolske ritus"

#: ../plugins/fn-christian-date/functions.c:155
msgid ""
"year:year between 1582 and 9956, defaults to the year of the next Ash "
"Wednesday"
msgstr ""
"year:år mellem 1582 og 9956, standardværdi er året for næste askeonsdag"

#: ../plugins/fn-christian-date/functions.c:173
msgid ""
"PENTECOSTSUNDAY:Pentecost Sunday in the Gregorian calendar according to the "
"Roman rite of the Christian Church"
msgstr ""
"PENTECOSTSUNDAY:Pinsedag i den gregorianske kalender efter den romersk-"
"katolske ritus"

#: ../plugins/fn-christian-date/functions.c:175
msgid ""
"year:year between 1582 and 9956, defaults to the year of the next Pentecost "
"Sunday"
msgstr "year:år mellem 1582 og 9956, standardværdi er året for næste pinsedag"

#: ../plugins/fn-christian-date/functions.c:192
msgid ""
"GOODFRIDAY:Good Friday in the Gregorian calendar according to the Roman rite "
"of the Christian Church"
msgstr ""
"GOODFRIDAY:Langfredag i den gregorianske kalender efter den romersk-katolske "
"ritus"

#: ../plugins/fn-christian-date/functions.c:194
msgid ""
"year:year between 1582 and 9956, defaults to the year of the next Good Friday"
msgstr ""
"year:år mellem 1582 og 9956, standardværdi er året for næste langfredag"

#: ../plugins/fn-christian-date/functions.c:211
msgid ""
"ASCENSIONTHURSDAY:Ascension Thursday in the Gregorian calendar according to "
"the Roman rite of the Christian Church"
msgstr ""
"ASCENSIONTHURSDAY:Kristi Himmelfartsdag i den gregorianske kalender efter "
"den romersk-katolske ritus"

#: ../plugins/fn-christian-date/functions.c:213
msgid ""
"year:year between 1582 and 9956, defaults to the year of the next Ascension "
"Thursday"
msgstr ""
"year:år mellem 1582 og 9956, standardværdi er året for næste Kristi "
"Himmelfartsdag"

#: ../plugins/fn-complex/functions.c:93
msgid "COMPLEX:a complex number of the form @{x} + @{y}@{i}"
msgstr "COMPLEX:Et komplekst tal på formen @{x} + @{y}@{i}"

#: ../plugins/fn-complex/functions.c:94
msgid "x:real part"
msgstr "x:reel del"

#: ../plugins/fn-complex/functions.c:95
msgid "y:imaginary part"
msgstr "y:imaginær del"

#: ../plugins/fn-complex/functions.c:96
msgid ""
"i:the suffix for the complex number, either \"i\" or \"j\"; defaults to \"i\""
msgstr ""
"i:suffikset for det komplekse tal, enten \"i\" eller \"j\"; standardværdi er "
"\"i\""

#: ../plugins/fn-complex/functions.c:97
msgid "If @{i} is neither \"i\" nor \"j\", COMPLEX returns #VALUE!"
msgstr "Hvis @{i} hverken er \"i\" eller \"j\", så returnerer COMPLEX #VÆRDI!"

