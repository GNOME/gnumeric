msgstr "COLUMNS:Antal kolonner i @{reference}"

#: ../plugins/fn-lookup/functions.c:1808
msgid "reference:array or area"
msgstr "reference:matrix eller område"

#: ../plugins/fn-lookup/functions.c:1809
msgid ""
"If @{reference} is neither an array nor a reference nor a range, COLUMNS "
"returns #VALUE!"
msgstr ""
"Hvis @{reference} hverken er en matrix eller en reference eller et interval, "
"returnerer COLUMNS #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1825
msgid "OFFSET:an offset cell range"
msgstr "OFFSET:Et forskudt celleinterval"

#: ../plugins/fn-lookup/functions.c:1826
msgid "range:reference or range"
msgstr "range:reference eller interval"

#: ../plugins/fn-lookup/functions.c:1827
msgid "row:number of rows to offset @{range}"
msgstr "row:antal rækker der skal forskyde @{range}"

#: ../plugins/fn-lookup/functions.c:1828
msgid "col:number of columns to offset @{range}"
msgstr "col:antal kolonner der skal forskyde @{range}"

#: ../plugins/fn-lookup/functions.c:1829
msgid "height:height of the offset range, defaults to height of @{range}"
msgstr ""
"height:højde for forskydningsintervallet, standardværdi er højde for @{range}"

#: ../plugins/fn-lookup/functions.c:1830
msgid "width:width of the offset range, defaults to width of @{range}"
msgstr ""
"width:bredde for forskydningsintervallet, standardværdi er bredde for "
"@{range}"

#: ../plugins/fn-lookup/functions.c:1831
msgid ""
"OFFSET returns the cell range starting at offset (@{row},@{col}) from "
"@{range} of height @{height} and width @{width}."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1834
msgid "If @{range} is neither a reference nor a range, OFFSET returns #VALUE!"
msgstr ""
"Hvis @{range} hverken er en reference eller et interval, så returnerer "
"OFFSET #VÆRDI!Hvis @{range} hverken er en reference eller et interval, så "
"returnerer OFFSET #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1883
msgid "ROW:vector of row numbers"
msgstr "ROW:Vektor af rækkenumre"

#: ../plugins/fn-lookup/functions.c:1885
msgid ""
"ROW function returns a 1xN array containing the sequence of integers from "
"the first row to the last row of @{x}."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1931
msgid "ROWS:number of rows in @{reference}"
msgstr "ROWS:Antal rækker i @{reference}"

#: ../plugins/fn-lookup/functions.c:1932
msgid "reference:array, reference, or range"
msgstr "reference:matrix, reference eller interval"

#: ../plugins/fn-lookup/functions.c:1933
msgid ""
"If @{reference} is neither an array nor a reference nor a range, ROWS "
"returns #VALUE!"
msgstr ""
"Hvis @{reference} hverken er en matrix eller en reference eller et interval, "
"returnerer ROWS #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1949
msgid "SHEETS:number of sheets in @{reference}"
msgstr "SHEETS:Antal ark i @{reference}"

#: ../plugins/fn-lookup/functions.c:1951
msgid "reference:array, reference, or range, defaults to the maximum range"
msgstr ""
"reference:matrix, reference eller interval, standardværdi er "
"maksimumintervallet"

#: ../plugins/fn-lookup/functions.c:1952
msgid ""
"If @{reference} is neither an array nor a reference nor a range, SHEETS "
"returns #VALUE!"
msgstr ""
"Hvis @{reference} hverken er en matrix eller en reference eller et interval, "
"returnerer SHEETS #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1988
msgid "SHEET:sheet number of @{reference}"
msgstr "SHEET:Arknummer for @{reference}"

#: ../plugins/fn-lookup/functions.c:1990
msgid ""
"reference:reference or literal sheet name, defaults to the current sheet"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1991
msgid ""
"If @{reference} is neither a reference nor a literal sheet name, SHEET "
"returns #VALUE!"
msgstr ""
"Hvis @{reference} hverken er en reference eller et bogstaveligt arknavn, "
"returnerer SHEET #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:2037
msgid "HYPERLINK:second or first arguments"
msgstr "HYPERLINK:Andet eller første argument"

#: ../plugins/fn-lookup/functions.c:2038
msgid "link_location:string"
msgstr "link_location:streng"

#: ../plugins/fn-lookup/functions.c:2039
msgid "label:string, optional"
msgstr "label:streng, valgfri"

#: ../plugins/fn-lookup/functions.c:2040
msgid ""
"HYPERLINK function currently returns its 2nd argument, or if that is omitted "
"the 1st argument."
msgstr ""

#: ../plugins/fn-lookup/functions.c:2059
msgid "TRANSPOSE:the transpose of @{matrix}"
msgstr "TRANSPOSE:Transponeringen af @{matrix}"

#: ../plugins/fn-lookup/functions.c:2060 ../plugins/fn-lookup/functions.c:2097
msgid "matrix:range"
msgstr "matrix:interval"

#: ../plugins/fn-lookup/functions.c:2096
msgid "FLIP:@{matrix} flipped"
msgstr "FLIP:@{matrix} vendt"

#: ../plugins/fn-lookup/functions.c:2098
msgid ""
"vertical:if true, @{matrix} is flipped vertically, otherwise horizontally; "
"defaults to TRUE"
msgstr ""

#: ../plugins/fn-lookup/functions.c:2141
msgid "ARRAY:vertical array of the arguments"
msgstr "ARRAY:Lodret matrix af argumenterne"

#: ../plugins/fn-lookup/functions.c:2142
msgid "v:value"
msgstr "v:værdi"

#: ../plugins/fn-lookup/functions.c:2199
msgid "SORT:sorted list of numbers as vertical array"
msgstr "SORT:Sorteret liste af tal som lodret matrix"

#: ../plugins/fn-lookup/functions.c:2200 ../plugins/fn-stat/functions.c:167
#: ../plugins/fn-stat/functions.c:215
msgid "ref:list of numbers"
msgstr "ref:liste af tal"

#: ../plugins/fn-lookup/functions.c:2201
msgid "order:0 (descending order) or 1 (ascending order); defaults to 0"
msgstr ""
"order:0 (faldende rækkefølge) eller 1 (stigende rækkefølge); standardværdi "
"er 0"

#: ../plugins/fn-lookup/functions.c:2202
msgid "Strings, booleans, and empty cells are ignored."
msgstr "Strenge, sandhedsværdier og tomme celler ignoreres."

#: ../plugins/fn-lookup/functions.c:2203
msgid "SORT({4,3,5}) evaluates to {5,4,3}"
msgstr "SORT({4,3,5}) evaluerer til {5,4,3}"

#: ../plugins/fn-lookup/functions.c:2251
msgid "UNIQUE:unique values in a range or array"
msgstr "UNIQUE:Unikke værdier i et interval eller en matrix"

#: ../plugins/fn-lookup/functions.c:2252
msgid "data:range or array"
msgstr "data:interval eller matrix"

#: ../plugins/fn-lookup/functions.c:2253
