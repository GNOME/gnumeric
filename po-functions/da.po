msgstr "calc_method:beregningsmetode, standardværdi er SAND"

#: ../plugins/fn-financial/functions.c:370
msgid ""
"If @{first_interest} < @{settlement} and @{calc_method} is TRUE, then "
"ACCRINT returns the sum of the interest accrued in all coupon periods from "
"@{issue}  date until @{settlement} date."
msgstr ""
"Hvis @{first_interest} < @{settlement} og @{calc_method} er SAND, så "
"returnerer ACCRINT summen af renten optjent i alle kuponperioder fra "
"@{issue}-dato indtil @{settlement}-dato."

#: ../plugins/fn-financial/functions.c:375
