#: ../plugins/fn-string/functions.c:1906 ../plugins/fn-string/functions.c:2168
msgid "text:string"
msgstr "text:streng"

#: ../plugins/fn-info/functions.c:924
msgid "If @{text} contains non-numerical text, 0 is returned."
msgstr "Hvis @{text} indeholder ikke-numerisk tekst, så returneres 0."

#: ../plugins/fn-info/functions.c:927
msgid "=N(\"eleven\")"
msgstr "=N(\"elleve\")"

#: ../plugins/fn-info/functions.c:954
msgid "TYPE:a number indicating the data type of @{value}"
msgstr "TYPE:Et tal der angiver datatypen af @{value}"

#: ../plugins/fn-info/functions.c:956
msgid ""
"TYPE returns a number indicating the data type of @{value}:\n"
"1  \t= number\n"
"2  \t= text\n"
"4  \t= boolean\n"
"16 \t= error\n"
"64 \t= array"
msgstr ""
"TYPE returnerer et tal der angiver datatypen for @{value}:\n"
"1  \t= tal\n"
"2  \t= tekst\n"
"4  \t= sandhedsværdi\n"
"16 \t= fejl\n"
"64 \t= matrix"

#: ../plugins/fn-info/functions.c:995
msgid "GETENV:the value of execution environment variable @{name}"
msgstr "GETENV:Værdien af eksekveringsmiljøvariablen @{name}"

#: ../plugins/fn-info/functions.c:996
msgid "name:the name of the environment variable"
msgstr "name:navnet på miljøvariablen"

#: ../plugins/fn-info/functions.c:997
msgid "If a variable called @{name} does not exist, #N/A will be returned."
msgstr "Hvis en variabel kaldet @{name} ikke findes, så returneres #N/A."

#: ../plugins/fn-info/functions.c:998
msgid "Variable names are case sensitive."
msgstr "Variabelnavne skelner mellem store og små bogstaver."

#: ../plugins/fn-info/functions.c:1018
msgid "GET.LINK:the target of the hyperlink attached to @{cell} as a string"
msgstr "GET.LINK:Målet for hyperhenvisningen knyttet til @{cell} som en streng"

#: ../plugins/fn-info/functions.c:1020
msgid ""
"The value return is not updated automatically when the link attached to "
"@{cell} changes but requires a recalculation."
msgstr ""
"Returværdien opdateres ikke automatisk når henvisningen knyttet til @{cell} "
"ændres, men kræver en genberegning."

#: ../plugins/fn-logical/functions.c:42
msgid "AND:logical conjunction"
msgstr "AND:Logisk konjunktion"

#: ../plugins/fn-logical/functions.c:43 ../plugins/fn-logical/functions.c:118
#: ../plugins/fn-logical/functions.c:168
msgid "b0:logical value"
msgstr "b0:logisk værdi"

#: ../plugins/fn-logical/functions.c:44 ../plugins/fn-logical/functions.c:119
#: ../plugins/fn-logical/functions.c:169
msgid "b1:logical value"
msgstr "b1:logisk værdi"

#: ../plugins/fn-logical/functions.c:45
msgid "AND calculates the logical conjunction of its arguments @{b0},@{b1},..."
msgstr ""
"AND beregner den logiske konjunktion af sine argumenter @{b0},@{b1},..."

#: ../plugins/fn-logical/functions.c:46 ../plugins/fn-logical/functions.c:121
#: ../plugins/fn-logical/functions.c:171
msgid ""
"If an argument is numerical, zero is considered FALSE and anything else TRUE."
msgstr ""
"Hvis et argument er numerisk, betragtes nul som FALSK og alt andet som SANDT."

#: ../plugins/fn-logical/functions.c:47 ../plugins/fn-logical/functions.c:96
#: ../plugins/fn-logical/functions.c:122 ../plugins/fn-logical/functions.c:172
msgid "Strings and empty values are ignored."
msgstr "Strenge og tomme værdier ignoreres."

#: ../plugins/fn-logical/functions.c:48 ../plugins/fn-logical/functions.c:123
#: ../plugins/fn-logical/functions.c:173
msgid "If no logical values are provided, then the error #VALUE! is returned."
msgstr "Hvis ingen logiske værdier tilbydes, så returneres fejlen #VÆRDI!"

#: ../plugins/fn-logical/functions.c:49 ../plugins/fn-logical/functions.c:124
#: ../plugins/fn-logical/functions.c:174
msgid ""
"This function is strict: if any argument is an error, the result will be the "
"first such error."
msgstr ""
"Denne funktion er streng: hvis et argument er en fejl, vil resultatet være "
"den første sådan fejl."

#: ../plugins/fn-logical/functions.c:55
msgid "wiki:en:Logical_conjunction"
msgstr ""

#: ../plugins/fn-logical/functions.c:92
msgid "NOT:logical negation"
msgstr "NOT:Logisk negation"

#: ../plugins/fn-logical/functions.c:93
msgid "b:logical value"
msgstr "b:logisk værdi"

#: ../plugins/fn-logical/functions.c:94
msgid "NOT calculates the logical negation of its argument."
msgstr "NOT beregner den logiske negation af sit argument."

#: ../plugins/fn-logical/functions.c:95
msgid ""
"If the argument is numerical, zero is considered FALSE and anything else "
"TRUE."
msgstr ""
"Hvis argumentet er numerisk, betragtes nul som FALSK og alt andet som SANDT."

#: ../plugins/fn-logical/functions.c:101
msgid "wiki:en:Negation"
msgstr ""

#: ../plugins/fn-logical/functions.c:117
msgid "OR:logical disjunction"
msgstr "OR:Logisk disjunktion"

#: ../plugins/fn-logical/functions.c:120
msgid "OR calculates the logical disjunction of its arguments @{b0},@{b1},..."
msgstr "OR beregner den logiske disjunktion af sine argumenter @{b0},@{b1},..."

#: ../plugins/fn-logical/functions.c:130
msgid "wiki:en:Logical_disjunction"
msgstr ""

#: ../plugins/fn-logical/functions.c:167
msgid "XOR:logical exclusive disjunction"
msgstr "XOR:Logisk eksklusiv disjunktion"

#: ../plugins/fn-logical/functions.c:170
msgid ""
"XOR calculates the logical exclusive disjunction of its arguments @{b0},"
"@{b1},..."
msgstr ""
"XOR beregner den logiske eksklusive disjunktion af sine argumenter @{b0},"
"@{b1},..."

#: ../plugins/fn-logical/functions.c:180
msgid "wiki:en:Exclusive_disjunction"
msgstr ""

#: ../plugins/fn-logical/functions.c:216
msgid "IFERROR:test for error"
msgstr "IFERROR:Test for fejl"

#: ../plugins/fn-logical/functions.c:217
msgid "x:value to test for error"
msgstr "x:værdi der skal testes for fejl"

#: ../plugins/fn-logical/functions.c:218 ../plugins/fn-logical/functions.c:237
msgid "y:alternate value"
msgstr "y:alternativ værdi"

#: ../plugins/fn-logical/functions.c:219
msgid ""
"This function returns the first value, unless that is an error, in which "
"case it returns the second."
msgstr ""
"Denne funktion returnerer den første værdi, medmindre den er en fejl, i "
"hvilket tilfælde den returnerer den anden."

#: ../plugins/fn-logical/functions.c:235
msgid "IFNA:test for #N/A error"
msgstr "IFNA:Test for #N/A-fejl"

#: ../plugins/fn-logical/functions.c:236
msgid "x:value to test for #N/A error"
msgstr "x:værdi der skal testes for #N/A-fejl"

#: ../plugins/fn-logical/functions.c:238
msgid ""
"This function returns the first value, unless that is #N/A, in which case it "
"returns the second."
msgstr ""
"Denne funktion returnerer den første værdi, medmindre den er #N/A, i hvilket "
"tilfælde den returnerer den anden."

#: ../plugins/fn-logical/functions.c:256
msgid "IFS:multi-branch conditional"
msgstr "IFS:Flergrenet betingelse"

#: ../plugins/fn-logical/functions.c:257
msgid "cond1:condition"
msgstr "cond1:betingelse"

#: ../plugins/fn-logical/functions.c:258
msgid "value1:value if @{condition1} is true"
msgstr "value1:værdi hvis @{condition1} er sand"

#: ../plugins/fn-logical/functions.c:259
msgid "cond2:condition"
msgstr "cond2:betingelse"

#: ../plugins/fn-logical/functions.c:260
msgid "value2:value if @{condition2} is true"
msgstr "value2:værdi hvis @{condition2} er sand"

#: ../plugins/fn-logical/functions.c:261
msgid ""
"This function returns the value after the first true conditional.  If no "
"conditional is true, #N/A is returned."
msgstr ""
"Denne funktion returnerer værdien efter den første sande betingelse. Hvis "
"ingen betingelse er sand, returneres #N/A"

#: ../plugins/fn-logical/functions.c:263
msgid ""
"Each @{condition} must be a boolean value. Any other type will result in a "
"#VALUE! error."
msgstr ""
"Hver @{condition} skal være en sandhedsværdi. Enhver anden type vil "
"resultere i en #VÆRDI!-fejl."

#: ../plugins/fn-logical/functions.c:300
msgid "SWITCH:multi-branch selector"
msgstr "SWITCH:Flergrenet vælger"

#: ../plugins/fn-logical/functions.c:301
msgid "ref:value"
msgstr "ref:værdi"

#: ../plugins/fn-logical/functions.c:302
msgid "choice1:value"
msgstr "choice1:valg1"

#: ../plugins/fn-logical/functions.c:303
msgid "value1:result"
msgstr "value1:resultat1"

#: ../plugins/fn-logical/functions.c:304
msgid "choice2:value"
msgstr "choice2:valg2"

#: ../plugins/fn-logical/functions.c:305
msgid "value2:result"
msgstr "value2:resultat2"

#: ../plugins/fn-logical/functions.c:306
msgid ""
"SWITCH compares @{ref} against @{choice1}, @{choice2}, etc. and returns the "
"corresponding @{value} for the first match. A final optional argument may be "
"provided as a default value."
msgstr ""
"SWITCH sammenligner @{ref} med @{choice1}, @{choice2}, osv. og returnerer "
"den tilsvarende @{værdi} for det første match. Et sidste valgfrit argument "
"kan angives som en standardværdi."

#: ../plugins/fn-logical/functions.c:308
msgid "If no match is found and no default is provided, #N/A is returned."
msgstr ""
"Hvis der ikke findes et match, og der ikke er angivet en standardværdi, "
"returneres #N/A."

#: ../plugins/fn-logical/functions.c:361
msgid "TRUE:the value TRUE"
msgstr "TRUE:Værdien SAND"

#: ../plugins/fn-logical/functions.c:362
msgid "TRUE returns the value TRUE."
msgstr "TRUE returnerer værdien SAND."

#: ../plugins/fn-logical/functions.c:366 ../plugins/fn-logical/functions.c:384
msgid "wiki:en:Logical_value"
msgstr ""

#: ../plugins/fn-logical/functions.c:379
msgid "FALSE:the value FALSE"
msgstr "FALSE:Værdien FALSK"

#: ../plugins/fn-logical/functions.c:380
msgid "FALSE returns the value FALSE."
msgstr "FALSE returnerer værdien FALSK."

#: ../plugins/fn-lookup/functions.c:952
msgid "ADDRESS:cell address as text"
msgstr "ADDRESS:Celleadresse som tekst"

#: ../plugins/fn-lookup/functions.c:953
msgid "row_num:row number"
msgstr "row_num:rækkenummer"

#: ../plugins/fn-lookup/functions.c:954
msgid "col_num:column number"
msgstr "col_num:kolonnenummer"

#: ../plugins/fn-lookup/functions.c:955
msgid ""
"abs_num:1 for an absolute, 2 for a row absolute and column relative, 3 for a "
"row relative and column absolute, and 4 for a relative reference; defaults "
"to 1"
msgstr ""

#: ../plugins/fn-lookup/functions.c:958
msgid ""
"a1:if TRUE, an A1-style reference is provided, otherwise an R1C1-style "
"reference; defaults to TRUE"
msgstr ""

#: ../plugins/fn-lookup/functions.c:960
msgid "text:name of the worksheet, defaults to no sheet"
msgstr "text:navn på arbejdsarket, standardværdi er intet ark"

#: ../plugins/fn-lookup/functions.c:961
msgid "If @{row_num} or @{col_num} is less than one, ADDRESS returns #VALUE!"
msgstr ""
"Hvis @{row_num} eller @{col_num} er mindre end én, så returnerer ADDRESS "
"#VÆRDI!"

#: ../plugins/fn-lookup/functions.c:963
msgid "If @{abs_num} is greater than 4 ADDRESS returns #VALUE!"
msgstr "Hvis @{abs_num} er større end 4, så returnerer ADDRESS #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1050
msgid "AREAS:number of areas in @{reference}"
msgstr "AREAS:Antal områder i @{reference}"

#: ../plugins/fn-lookup/functions.c:1051
msgid "reference:range"
msgstr "reference:interval"

#: ../plugins/fn-lookup/functions.c:1118
msgid "CHOOSE:the (@{index}+1)th argument"
msgstr "CHOOSE:Det (@{index}+1)'te argument"

#: ../plugins/fn-lookup/functions.c:1119
msgid "index:positive number"
msgstr "index:positivt tal"

#: ../plugins/fn-lookup/functions.c:1120
msgid "value1:first value"
msgstr "value1:første værdi"

#: ../plugins/fn-lookup/functions.c:1121
msgid "value2:second value"
msgstr "value2:anden værdi"

#: ../plugins/fn-lookup/functions.c:1122
msgid "CHOOSE returns its (@{index}+1)th argument."
msgstr "CHOOSE returnerer sit (@{index}+1)'te argument."

#: ../plugins/fn-lookup/functions.c:1123
msgid ""
"@{index} is truncated to an integer. If @{index} < 1 or the truncated "
"@{index} > number of values, CHOOSE returns #VALUE!"
msgstr ""
"@{index} er afkortet til et heltal. Hvis @{index} < 1 eller den afkortet "
"@{index} > antal værdier, så returnerer CHOOSE #VÆRDI!"

#: ../plugins/fn-lookup/functions.c:1165
msgid "VLOOKUP:search the first column of @{range} for @{value}"
msgstr "VLOOKUP:Søg i første kolonne af @{range} efter @{value}"

#: ../plugins/fn-lookup/functions.c:1166 ../plugins/fn-lookup/functions.c:1234
msgid "value:search value"
msgstr "value:Søgeværdi"

#: ../plugins/fn-lookup/functions.c:1167 ../plugins/fn-lookup/functions.c:1235
msgid "range:range to search"
msgstr "range:interval der skal søges i"

#: ../plugins/fn-lookup/functions.c:1168
msgid "column:1-based column offset indicating the return values"
msgstr "column:1-baseret kolonneforskydning der angiver returværdierne"

#: ../plugins/fn-lookup/functions.c:1169 ../plugins/fn-lookup/functions.c:1237
msgid ""
"approximate:if false, an exact match of @{value} must be found; defaults to "
"TRUE"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1171
msgid "as_index:if true, the 0-based row offset is returned; defaults to FALSE"
msgstr ""
"as_index:hvis sand, så returneres den 0-baserede rækkeforskydning; "
"standardværdi er FALSK"

#: ../plugins/fn-lookup/functions.c:1173
msgid ""
"VLOOKUP function finds the row in @{range} that has a first cell similar to "
"@{value}.  If @{approximate} is not true it finds the row with an exact "
"equality. If @{approximate} is true, it finds the last row with first value "
"less than or equal to @{value}. If @{as_index} is true the 0-based row "
"offset is returned."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1180 ../plugins/fn-lookup/functions.c:1248
msgid ""
"If @{approximate} is true, then the values must be sorted in order of "
"ascending value."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1182
msgid "VLOOKUP returns #REF! if @{column} falls outside @{range}."
msgstr "VLOOKUP returnerer #REF! hvis @{column} falder uden for @{range}."

#: ../plugins/fn-lookup/functions.c:1233
msgid "HLOOKUP:search the first row of @{range} for @{value}"
msgstr "HLOOKUP:Søg i første række af @{range} efter @{value}"

#: ../plugins/fn-lookup/functions.c:1236
#, fuzzy
msgid "row:1-based row offset indicating the return values "
msgstr "row:1-baseret rækkeforskydning der angiver returværdierne "

#: ../plugins/fn-lookup/functions.c:1239
msgid ""
"as_index:if true, the 0-based column offset is returned; defaults to FALSE"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1241
msgid ""
"HLOOKUP function finds the row in @{range} that has a first cell similar to "
"@{value}.  If @{approximate} is not true it finds the column with an exact "
"equality. If @{approximate} is true, it finds the last column with first "
"value less than or equal to @{value}. If @{as_index} is true the 0-based "
"column offset is returned."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1250
msgid "HLOOKUP returns #REF! if @{row} falls outside @{range}."
msgstr "HLOOKUP returnerer #REF! hvis @{row} falder uden for @{range}."

#: ../plugins/fn-lookup/functions.c:1301
msgid ""
"LOOKUP:contents of @{vector2} at the corresponding location to @{value} in "
"@{vector1}"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1303
msgid "value:value to look up"
msgstr "value:værdi der skal slås op"

#: ../plugins/fn-lookup/functions.c:1304
msgid "vector1:range to search:"
msgstr "vector1:interval der skal søges i:"

#: ../plugins/fn-lookup/functions.c:1305
msgid "vector2:range of return values"
msgstr "vector2:interval af returværdier"

#: ../plugins/fn-lookup/functions.c:1306
msgid ""
"If  @{vector1} has more rows than columns, LOOKUP searches the first row of "
"@{vector1}, otherwise the first column. If @{vector2} is omitted the return "
"value is taken from the last row or column of @{vector1}."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1310
msgid ""
"If LOOKUP can't find @{value} it uses the largest value less than @{value}."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1312
msgid "The data must be sorted."
msgstr "Dataene skal være sorterede."

#: ../plugins/fn-lookup/functions.c:1313
msgid "If @{value} is smaller than the first value it returns #N/A."
msgstr "Hvis @{value} er mindre end den første værdi, så returneres #N/A."

#: ../plugins/fn-lookup/functions.c:1314
msgid ""
"If the corresponding location does not exist in @{vector2}, it returns #N/A."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1401
msgid "MATCH:the index of @{seek} in @{vector}"
msgstr "MATCH:Indekset for @{seek} i @{vector}"

#: ../plugins/fn-lookup/functions.c:1402
msgid "seek:value to find"
msgstr "seek:værdi der skal findes"

#: ../plugins/fn-lookup/functions.c:1403
msgid "vector:n by 1 or 1 by n range to be searched"
msgstr "vector:n×1- eller 1×n-interval der skal søges i"

#: ../plugins/fn-lookup/functions.c:1404
msgid ""
"type:+1 (the default) to find the largest value ≤ @{seek}, 0 to find the "
"first value = @{seek}, or -1 to find the smallest value ≥ @{seek}"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1407
msgid "MATCH searches @{vector} for @{seek} and returns the 1-based index."
msgstr ""
"MATCH søger i @{vector} efter @{seek} og returnerer det 1-baserede indeks."

#: ../plugins/fn-lookup/functions.c:1408
msgid ""
"For @{type} = -1 the data must be sorted in descending order; for @{type} = "
"+1 the data must be sorted in ascending order."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1410
msgid "If @{seek} could not be found, #N/A is returned."
msgstr "Hvis @{seek} ikke kunne findes, så returneres #N/A."

#: ../plugins/fn-lookup/functions.c:1411
msgid "If @{vector} is neither n by 1 nor 1 by n, #N/A is returned."
msgstr "Hvis @{vector} hverken er n×1 eller 1×n, så returneres #N/A."

#: ../plugins/fn-lookup/functions.c:1455
msgid ""
"XLOOKUP:search @{lookup_array} for @{lookup_value} and return the "
"corresponding item from @{return_array}"
msgstr ""
"XLOOKUP:søg efter @{lookup_value} i @{lookup_array} og returner det "
"tilsvarende element fra @{return_array}"

#: ../plugins/fn-lookup/functions.c:1456 ../plugins/fn-lookup/functions.c:1535
msgid "lookup_value:value to look up"
msgstr "lookup_value:værdi der skal slås op"

#: ../plugins/fn-lookup/functions.c:1457 ../plugins/fn-lookup/functions.c:1536
msgid "lookup_array:range to search"
msgstr "lookup_array:interval der skal søges i"

#: ../plugins/fn-lookup/functions.c:1458
msgid "return_array:range of return values"
msgstr "return_array:interval af returværdier"

#: ../plugins/fn-lookup/functions.c:1459 ../plugins/fn-string/functions.c:1711
#: ../plugins/fn-string/functions.c:1845
msgid "if_not_found:value to return if no match is found; defaults to #N/A"
msgstr ""
"if_not_found:værdi der skal returneres hvis intet match findes; standard er "
"#I/T"

#: ../plugins/fn-lookup/functions.c:1460 ../plugins/fn-lookup/functions.c:1537
msgid ""
"match_mode:0 for exact match (default), -1 for exact match or next smaller, "
"1 for exact match or next larger, 2 for wildcard match"
msgstr ""
"match_mode:0 for præcist match (standard), -1 for præcist match eller næste "
"mindre, 1 for præcist match eller næste større, 2 for match med jokertegn"

#: ../plugins/fn-lookup/functions.c:1461 ../plugins/fn-lookup/functions.c:1538
msgid ""
"search_mode:1 for first-to-last (default), -1 for last-to-first, 2 for "
"binary search ascending, -2 for binary search descending"
msgstr ""
"search_mode:1 for første-til-sidste (standard), -1 for sidste-til-første, 2 "
"for binær søgning stigende, -2 for binær søgning faldende"

#: ../plugins/fn-lookup/functions.c:1462
msgid ""
"XLOOKUP function finds the item in @{lookup_array} that matches "
"@{lookup_value} and returns the corresponding item from @{return_array}."
msgstr ""
"XLOOKUP-funktionen finder elementet i @{lookup_array} der matcher "
"@{lookup_value} og returnerer det tilsvarende element fra @{return_array}."

#: ../plugins/fn-lookup/functions.c:1534
msgid "XMATCH:the index of @{lookup_value} in @{lookup_array}"
msgstr "XMATCH:indekset for @{lookup_value} i @{lookup_array}"

#: ../plugins/fn-lookup/functions.c:1539
msgid ""
"XMATCH searches @{lookup_array} for @{lookup_value} and returns the 1-based "
"index."
msgstr ""
"XMATCH søger i @{lookup_array} efter @{lookup_value} og returnerer det 1-"
"baserede indeks."

#: ../plugins/fn-lookup/functions.c:1574
msgid "INDIRECT:contents of the cell pointed to by the @{ref_text} string"
msgstr "INDIRECT:Indholdet af cellen peget på af @{ref_text}-strengen"

#: ../plugins/fn-lookup/functions.c:1575
msgid "ref_text:textual reference"
msgstr "ref_text:tekstuel reference"

#: ../plugins/fn-lookup/functions.c:1576
msgid ""
"format:if true, @{ref_text} is given in A1-style, otherwise it is given in "
"R1C1 style; defaults to true"
msgstr ""
"format:hvis sand, angives @{ref_text} i A1-stil, ellers angives den i R1C1-"
"stil; standard er sand"

#: ../plugins/fn-lookup/functions.c:1578
msgid ""
"If @{ref_text} is not a valid reference in the style determined by "
"@{format}, INDIRECT returns #REF!"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1612
msgid "INDEX:reference to a cell in the given @{array}"
msgstr "INDEX:Reference til en celle i den givne @{array}"

#: ../plugins/fn-lookup/functions.c:1613
msgid "array:cell or inline array"
msgstr "array:celle eller indbygget matrix"

#: ../plugins/fn-lookup/functions.c:1614
msgid "row:desired row, defaults to 1"
msgstr "row:ønsket række, standardværdi er 1"

#: ../plugins/fn-lookup/functions.c:1615
msgid "col:desired column, defaults to 1"
msgstr "col:ønsket kolonne, standardværdi er 1"

#: ../plugins/fn-lookup/functions.c:1616
msgid "area:from which area to select a cell, defaults to 1"
msgstr "area:fra hvilket område der skal vælges en celle, standardværdi er 1"

