msgstr "IMINV:Den reciprokke eller inverse værdi af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:253
msgid "IMNEG:the negative of the complex number @{z}"
msgstr "IMNEG:Det negative af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:277
