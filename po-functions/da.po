msgstr "OFFTRAF:Forudsagt antal tilbudte opkald"

#: ../plugins/fn-erlang/functions.c:128
msgid "traffic:number of carried calls"
msgstr "traffic:antal afviklede opkald"

#: ../plugins/fn-erlang/functions.c:130
