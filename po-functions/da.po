msgstr "IMCOS:Kosinus af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:304
msgid "IMTAN:the tangent of the complex number @{z}"
msgstr "IMTAN:Tangens af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:331
msgid "IMSEC:the secant of the complex number @{z}"
msgstr "IMSEC:Sekant af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:333
msgid "IMSEC(@{z}) = 1/IMCOS(@{z})."
msgstr "IMSEC(@{z}) = 1/IMCOS(@{z})."

#: ../plugins/fn-complex/functions.c:359
msgid "IMCSC:the cosecant of the complex number @{z}"
msgstr "IMCSC:Cosekant af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:361
msgid "IMCSC(@{z}) = 1/IMSIN(@{z})."
msgstr "IMCSC(@{z}) = 1/IMSIN(@{z})."

#: ../plugins/fn-complex/functions.c:386
msgid "IMCOT:the cotangent of the complex number @{z}"
msgstr "IMCOT:Kotangens af det komplekse tal @{z}"

#: ../plugins/fn-complex/functions.c:388
msgid "IMCOT(@{z}) = IMCOS(@{z})/IMSIN(@{z})."
msgstr "IMCOT(@{z}) = IMCOS(@{z})/IMSIN(@{z})."

#: ../plugins/fn-complex/functions.c:414
msgid "IMEXP:the exponential of the complex number @{z}"
msgstr "IMEXP:Eksponentialfunktionen af det komplekse tal @{z}"

