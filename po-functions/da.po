#: ../plugins/fn-financial/functions.c:1671
#: ../plugins/fn-financial/functions.c:1702
#: ../plugins/fn-financial/functions.c:1742
#: ../plugins/fn-financial/functions.c:1785
#: ../plugins/fn-financial/functions.c:1875
msgid "fv:future value"
msgstr "fv:fremtidig værdi"

#: ../plugins/fn-financial/functions.c:1133
#: ../plugins/fn-financial/functions.c:1400
#: ../plugins/fn-financial/functions.c:1636
#: ../plugins/fn-financial/functions.c:1672
#: ../plugins/fn-financial/functions.c:1703
#: ../plugins/fn-financial/functions.c:1743
#: ../plugins/fn-financial/functions.c:1786
#: ../plugins/fn-financial/functions.c:3072
#: ../plugins/fn-financial/functions.c:3113
msgid "type:payment type"
msgstr "type:betalingstype"

#: ../plugins/fn-financial/functions.c:1134
#: ../plugins/fn-financial/functions.c:1279
#: ../plugins/fn-financial/functions.c:1540
msgid "guess:an estimate of what the result should be"
msgstr "guess:et estimat af hvad resultatet skulle være"

#: ../plugins/fn-financial/functions.c:1135
msgid "RATE calculates the rate of return."
msgstr "RATE beregner afkastningsraten."

#: ../plugins/fn-financial/functions.c:1137
#: ../plugins/fn-financial/functions.c:1282
#: ../plugins/fn-financial/functions.c:1542
msgid ""
"The optional @{guess} is needed because there can be more than one valid "
"result.  It defaults to 10%."
msgstr ""

#: ../plugins/fn-financial/functions.c:1244
msgid "RRI:equivalent interest rate for an investment increasing in value"
msgstr "RRI:Tilsvarende rente for en investering der stiger i værdi"

#: ../plugins/fn-financial/functions.c:1245
msgid "p:number of periods"
msgstr "p:antal perioder"

#: ../plugins/fn-financial/functions.c:1248
msgid ""
"RRI determines an equivalent interest rate for an investment that increases "
"in value. The interest is compounded after each complete period."
msgstr ""

#: ../plugins/fn-financial/functions.c:1250
msgid ""
"Note that @{p} need not be an integer but for fractional value the "
"calculated rate is only approximate."
msgstr ""

#: ../plugins/fn-financial/functions.c:1277
msgid "IRR:internal rate of return"
msgstr "IRR:Intern rente"

#: ../plugins/fn-financial/functions.c:1280
msgid ""
"IRR calculates the internal rate of return of a cash flow with periodic "
"payments.  @{values} lists the payments (negative values) and receipts "
"(positive values) for each period."
msgstr ""

#: ../plugins/fn-financial/functions.c:1395
msgid "PV:present value"
msgstr "PV:Nutidsværdi"

#: ../plugins/fn-financial/functions.c:1396
#: ../plugins/fn-financial/functions.c:1436
#: ../plugins/fn-financial/functions.c:1632
msgid "rate:effective interest rate per period"
msgstr "rate:effektiv rente per periode"

#: ../plugins/fn-financial/functions.c:1401
msgid ""
"PV calculates the present value of @{fv} which is @{nper} periods into the "
"future, assuming a periodic payment of @{pmt} and an interest rate of "
"@{rate} per period."
msgstr ""

#: ../plugins/fn-financial/functions.c:1435
msgid "NPV:net present value"
msgstr "NPV:Nettonutidsværdi"

#: ../plugins/fn-financial/functions.c:1437
msgid "value1:cash flow for period 1"
msgstr "value1:pengestrøm for periode 1"

#: ../plugins/fn-financial/functions.c:1438
msgid "value2:cash flow for period 2"
msgstr "value2:pengestrøm for periode 2"

#: ../plugins/fn-financial/functions.c:1439
msgid "NPV calculates the net present value of a cash flow."
msgstr "NPV beregner netto nutidsværdien af en pengestrøm."

#: ../plugins/fn-financial/functions.c:1481
msgid "XNPV:net present value"
msgstr "XNPV:Nettonutidsværdi"

#: ../plugins/fn-financial/functions.c:1484
#: ../plugins/fn-financial/functions.c:1539
msgid "dates:dates of cash flow"
msgstr "dates:datoer for pengestrøm"

#: ../plugins/fn-financial/functions.c:1485
msgid ""
"XNPV calculates the net present value of a cash flow at irregular times."
msgstr ""

#: ../plugins/fn-financial/functions.c:1537
msgid "XIRR:internal rate of return"
msgstr "XIRR:Intern rente"

#: ../plugins/fn-financial/functions.c:1541
msgid ""
"XIRR calculates the annualized internal rate of return of a cash flow at "
"arbitrary points in time.  @{values} lists the payments (negative values) "
"and receipts (positive values) with one value for each entry in @{dates}."
msgstr ""

#: ../plugins/fn-financial/functions.c:1631
msgid "FV:future value"
msgstr "FV:Fremtidig værdi"

#: ../plugins/fn-financial/functions.c:1637
msgid ""
"FV calculates the future value of @{pv} moved @{nper} periods into the "
"future, assuming a periodic payment of @{pmt} and an interest rate of "
"@{rate} per period."
msgstr ""

#: ../plugins/fn-financial/functions.c:1667
msgid "PMT:payment for annuity"
msgstr "PMT:Betaling for annuitet"

#: ../plugins/fn-financial/functions.c:1673
msgid "PMT calculates the payment amount for an annuity."
msgstr "PMT beregner betalingsbeløbet for en livrente."

#: ../plugins/fn-financial/functions.c:1697
msgid "IPMT:interest payment for period"
msgstr "IPMT:Rentebetaling for periode"

#: ../plugins/fn-financial/functions.c:1704
msgid ""
"IPMT calculates the interest part of an annuity's payment for period number "
"@{per}."
msgstr ""

#: ../plugins/fn-financial/functions.c:1737
msgid "PPMT:interest payment for period"
msgstr "PPMT:Rentebetaling for periode"

#: ../plugins/fn-financial/functions.c:1744
msgid ""
"PPMT calculates the principal part of an annuity's payment for period number "
"@{per}."
msgstr ""

#: ../plugins/fn-financial/functions.c:1781
msgid "NPER:number of periods"
msgstr "NPER:Antal perioder"

#: ../plugins/fn-financial/functions.c:1787
msgid ""
"NPER calculates the number of periods of an investment based on periodic "
"constant payments and a constant interest rate."
msgstr ""

#: ../plugins/fn-financial/functions.c:1829
msgid "DURATION:the (Macaulay) duration of a security"
msgstr "DURATION:(Macaulay) varigheden af et værdipapir"

#: ../plugins/fn-financial/functions.c:1832
#: ../plugins/fn-financial/functions.c:3151
msgid "coupon:annual coupon rate"
msgstr "coupon:årlig kuponrente"

#: ../plugins/fn-financial/functions.c:1836
msgid "DURATION calculates the (Macaulay) duration of a security."
msgstr "DURATION beregner (Macaulay-)varigheden for et værdipapir."

#: ../plugins/fn-financial/functions.c:1872
msgid "G_DURATION:the duration of a investment"
msgstr "G_DURATION:Varigheden af en investering"

#: ../plugins/fn-financial/functions.c:1876
msgid ""
"G_DURATION calculates the number of periods needed for an investment to "
"attain a desired value."
msgstr ""

#: ../plugins/fn-financial/functions.c:1877
msgid "G_DURATION is the OpenFormula function PDURATION."
msgstr "G_DURATION er OpenFormula-funktionen PDURATION."

#: ../plugins/fn-financial/functions.c:1904
msgid "FVSCHEDULE:future value"
msgstr "FVSCHEDULE:Fremtidig værdi"

#: ../plugins/fn-financial/functions.c:1905
msgid "principal:initial value"
msgstr "principal:oprindelig værdi"

#: ../plugins/fn-financial/functions.c:1906
msgid "schedule:range of interest rates"
msgstr "schedule:interval af rentesatser"

#: ../plugins/fn-financial/functions.c:1907
msgid ""
"FVSCHEDULE calculates the future value of @{principal} after applying a "
"range of interest rates with compounding."
msgstr ""

#: ../plugins/fn-financial/functions.c:1938
msgid "EURO:equivalent of 1 EUR"
msgstr "EURO:ækvivalent af 1 EUR"

#: ../plugins/fn-financial/functions.c:1939
msgid "currency:three-letter currency code"
msgstr "currency:valutakode med tre bogstaver"

#: ../plugins/fn-financial/functions.c:1940
msgid ""
"EURO calculates the national currency amount corresponding to 1 EUR for any "
"of the national currencies that were replaced by the Euro on its "
"introduction."
msgstr ""

#: ../plugins/fn-financial/functions.c:1941
msgid ""
"@{currency} must be one of ATS (Austria), BEF (Belgium), CYP (Cyprus), DEM "
"(Germany), EEK (Estonia), ESP (Spain), EUR (Euro), FIM (Finland), FRF "
"(France), GRD (Greece), IEP (Ireland), ITL (Italy), LUF (Luxembourg), MTL "
"(Malta), NLG (The Netherlands), PTE (Portugal), SIT (Slovenia), or SKK "
"(Slovakia)."
msgstr ""

#: ../plugins/fn-financial/functions.c:1960
#: ../plugins/fn-financial/functions.c:2144
msgid "This function is not likely to be useful anymore."
msgstr "Denne funktion er sandsynligvis ikke nyttig længere."

#: ../plugins/fn-financial/functions.c:2135
msgid "EUROCONVERT:pre-Euro amount from one currency to another"
msgstr "EUROCONVERT:Præ-Euro beløb fra én valuta til en anden"

#: ../plugins/fn-financial/functions.c:2136
msgid "n:amount"
msgstr "n:beløb"

#: ../plugins/fn-financial/functions.c:2137
msgid "source:three-letter source currency code"
msgstr "source:kildevalutakode med tre bogstaver"

#: ../plugins/fn-financial/functions.c:2138
msgid "target:three-letter target currency code"
msgstr "target:målvalutakode med tre bogstaver"

#: ../plugins/fn-financial/functions.c:2139
msgid "full_precision:whether to provide the full precision; defaults to false"
msgstr "full_precision:om fuld præcision skal leveres; standardværdi er falsk"

#: ../plugins/fn-financial/functions.c:2140
msgid ""
"triangulation_precision:number of digits (at least 3) to be rounded to after "
"conversion of the source currency to euro; defaults to no rounding"
msgstr ""

#: ../plugins/fn-financial/functions.c:2141
msgid ""
"EUROCONVERT converts @{n} units of currency @{source} to currency "
"@{target}.  The rates used are the official ones used on the introduction of "
"the Euro."
msgstr ""

#: ../plugins/fn-financial/functions.c:2142
msgid ""
"If @{full_precision} is true, the result is not rounded; if it false the "
"result is rounded to 0 or 2 decimals depending on the target currency; "
"defaults to false."
msgstr ""

#: ../plugins/fn-financial/functions.c:2143
msgid ""
"@{source} and @{target} must be one of the currencies listed for the EURO "
"function."
msgstr ""

#: ../plugins/fn-financial/functions.c:2187
msgid "PRICE:price of a security"
msgstr "PRICE:Pris på et værdipapir"

#: ../plugins/fn-financial/functions.c:2195
msgid ""
"PRICE calculates the price per $100 face value of a security that pays "
"periodic interest."
msgstr ""

#: ../plugins/fn-financial/functions.c:2237
msgid "YIELD:yield of a security"
msgstr "YIELD:Afkast for værdipapir"

#: ../plugins/fn-financial/functions.c:2241
#: ../plugins/fn-financial/functions.c:2349
#: ../plugins/fn-financial/functions.c:2391
#: ../plugins/fn-financial/functions.c:2578
#: ../plugins/fn-financial/functions.c:2751
msgid "price:price of security"
msgstr "price:pris for værdipapir"

#: ../plugins/fn-financial/functions.c:2245
msgid "YIELD calculates the yield of a security that pays periodic interest."
msgstr "YIELD beregner udbyttet af et værdipapir der betaler periodisk rente."

#: ../plugins/fn-financial/functions.c:2346
msgid "YIELDDISC:yield of a discounted security"
msgstr "YIELDDISC:Afkast for diskonteret værdipapir"

#: ../plugins/fn-financial/functions.c:2352
msgid "YIELDDISC calculates the yield of a discounted security."
msgstr "YIELDDISC beregner udbyttet af et diskonteret værdipapir."

#: ../plugins/fn-financial/functions.c:2386
msgid "YIELDMAT:yield of a security"
msgstr "YIELDMAT:Afkast af et værdipapir"

#: ../plugins/fn-financial/functions.c:2393
msgid ""
"YIELDMAT calculates the yield of a security for which the interest is paid "
"at maturity date."
msgstr ""

#: ../plugins/fn-financial/functions.c:2421
msgid "ODDFPRICE:price of a security that has an odd first period"
msgstr "ODDFPRICE:Pris på et værdipapir med uregelmæssig første periode"

#: ../plugins/fn-financial/functions.c:2425
#: ../plugins/fn-financial/functions.c:2576
msgid "first_interest:first interest date"
msgstr "first_interest:første rentedato"

#: ../plugins/fn-financial/functions.c:2431
msgid ""
"ODDFPRICE calculates the price per $100 face value of a security that pays "
"periodic interest, but has an odd first period."
msgstr ""
"ODDFPRICE beregner prisen per $100 pålydende værdi for et værdipapir der "
"betaler periodisk rente, men har en ulige første periode."

#: ../plugins/fn-financial/functions.c:2572
msgid "ODDFYIELD:yield of a security that has an odd first period"
msgstr "ODDFYIELD:Afkast af et værdipapir med uregelmæssig første periode"

#: ../plugins/fn-financial/functions.c:2582
msgid ""
"ODDFYIELD calculates the yield of a security that pays periodic interest, "
"but has an odd first period."
msgstr ""
"ODDFYIELD beregner udbyttet af et værdipapir der betaler periodisk rente, "
"men har en ulige første periode."

#: ../plugins/fn-financial/functions.c:2668
msgid "ODDLPRICE:price of a security that has an odd last period"
msgstr "ODDLPRICE:Pris på et værdipapir med uregelmæssig sidste periode"

#: ../plugins/fn-financial/functions.c:2671
#: ../plugins/fn-financial/functions.c:2749
msgid "last_interest:last interest date"
msgstr "last_interest:sidste rentedato"

#: ../plugins/fn-financial/functions.c:2677
msgid ""
"ODDLPRICE calculates the price per $100 face value of a security that pays "
"periodic interest, but has an odd last period."
msgstr ""
"ODDLPRICE beregner prisen per $100 pålydende værdi for et værdipapir der "
"betaler periodisk rente, men har en ulige sidste periode."

#: ../plugins/fn-financial/functions.c:2746
msgid "ODDLYIELD:yield of a security that has an odd last period"
msgstr "ODDLYIELD:Afkast af et værdipapir med uregelmæssig sidste periode"

#: ../plugins/fn-financial/functions.c:2755
msgid ""
"ODDLYIELD calculates the yield of a security that pays periodic interest, "
"but has an odd last period."
msgstr ""
"ODDLYIELD beregner udbyttet af et værdipapir der betaler periodisk rente, "
"men har en ulige sidste periode."

#: ../plugins/fn-financial/functions.c:2824
msgid "AMORDEGRC:depreciation of an asset using French accounting conventions"
msgstr ""
"AMORDEGRC:Afskrivning af et aktiv ved brug af franske regnskabskonventioner"

#: ../plugins/fn-financial/functions.c:2826
#: ../plugins/fn-financial/functions.c:2878
msgid "purchase_date:date of purchase"
msgstr "purchase_date:købsdato"

#: ../plugins/fn-financial/functions.c:2827
#: ../plugins/fn-financial/functions.c:2879
msgid "first_period:end of first period"
msgstr "first_period:slutning af første periode"

#: ../plugins/fn-financial/functions.c:2830
#: ../plugins/fn-financial/functions.c:2882
msgid "rate:depreciation rate"
msgstr "rate:afskrivningssats"

#: ../plugins/fn-financial/functions.c:2833
msgid ""
"AMORDEGRC calculates the depreciation of an asset using French accounting "
"conventions. Assets purchased in the middle of a period take prorated "
"depreciation into account. This is similar to AMORLINC, except that a "
"depreciation coefficient is applied in the calculation depending on the life "
"of the assets."
msgstr ""
"AMORDEGRC beregner afskrivningen af et aktiv ved hjælp af franske "
"regnskabskonventioner. Aktiver købt midt i en periode tager forholdsmæssig "
"afskrivning i betragtning. Dette ligner AMORLINC, undtagen at en "
"afskrivningskoefficient anvendes i beregningen afhængig af aktivets levetid."

#: ../plugins/fn-financial/functions.c:2837
msgid ""
"The depreciation coefficient used is:\n"
"1.0 for an expected lifetime less than 3 years,\n"
"1.5 for an expected lifetime of at least 3 years but less than 5 years,\n"
"2.0 for an expected lifetime of at least 5 years but at most 6 years,\n"
"2.5 for an expected lifetime of more than 6 years."
msgstr ""
"Den anvendte afskrivningskoefficient er:\n"
"1,0 for en forventet levetid mindre end 3 år,\n"
"1,5 for en forventet levetid på mindst 3 år men mindre end 5 år,\n"
"2,0 for en forventet levetid på mindst 5 år men højst 6 år,\n"
"2,5 for en forventet levetid på mere end 6 år."

#: ../plugins/fn-financial/functions.c:2842
msgid ""
"Special depreciation rules are applied for the last two periods resulting in "
"a possible total depreciation exceeding the difference of @{cost} - "
"@{salvage}."
msgstr ""
"Særlige afskrivningsregler anvendes for de sidste to perioder hvilket "
"resulterer i en mulig samlet afskrivning der overstiger forskellen @{cost} - "
"@{salvage}."

#: ../plugins/fn-financial/functions.c:2844
msgid "Named for AMORtissement DEGRessif Comptabilite."
msgstr "Navngivet efter AMORtissement DEGRessif Comptabilite."

#: ../plugins/fn-financial/functions.c:2876
msgid "AMORLINC:depreciation of an asset using French accounting conventions"
msgstr ""
"AMORLINC:Afskrivning af et aktiv ved brug af franske regnskabskonventioner"

#: ../plugins/fn-financial/functions.c:2885
msgid ""
"AMORLINC calculates the depreciation of an asset using French accounting "
"conventions. Assets purchased in the middle of a period take prorated "
"depreciation into account."
msgstr ""
"AMORLINC beregner afskrivningen af et aktiv ved hjælp af franske "
"regnskabskonventioner. Aktiver købt midt i en periode tager forholdsmæssig "
"afskrivning i betragtning."

#: ../plugins/fn-financial/functions.c:2887
msgid "Named for AMORtissement LINeaire Comptabilite."
msgstr "Navngivet efter AMORtissement LINeaire Comptabilite."

#: ../plugins/fn-financial/functions.c:2918
msgid "COUPDAYBS:number of days from coupon period to settlement"
msgstr "COUPDAYBS:Antal dage fra kuponperiode til afregning"

#: ../plugins/fn-financial/functions.c:2923
#: ../plugins/fn-financial/functions.c:2947
#: ../plugins/fn-financial/functions.c:2971
#: ../plugins/fn-financial/functions.c:2995
#: ../plugins/fn-financial/functions.c:3021
#: ../plugins/fn-financial/functions.c:3047
msgid "eom:end-of-month flag"
msgstr "eom:månedsafslutnings-flag"

#: ../plugins/fn-financial/functions.c:2924
msgid ""
"COUPDAYBS calculates the number of days from the beginning of the coupon "
"period to the settlement date."
msgstr ""
"COUPDAYBS beregner antallet af dage fra begyndelsen af kuponperioden til "
"afregningsdatoen."

#: ../plugins/fn-financial/functions.c:2942
msgid "COUPDAYS:number of days in the coupon period of the settlement date"
msgstr "COUPDAYS:Antal dage i kuponperioden for afregningsdatoen"

#: ../plugins/fn-financial/functions.c:2948
msgid ""
"COUPDAYS calculates the number of days in the coupon period of the "
"settlement date."
msgstr ""
"COUPDAYS beregner antallet af dage i kuponperioden for afregningsdatoen."

#: ../plugins/fn-financial/functions.c:2966
msgid ""
"COUPDAYSNC:number of days from the settlement date to the next coupon period"
msgstr "COUPDAYSNC:Antal dage fra afregningsdatoen til næste kuponperiode"

#: ../plugins/fn-financial/functions.c:2972
msgid ""
"COUPDAYSNC calculates number of days from the settlement date to the next "
"coupon period."
msgstr ""
"COUPDAYSNC beregner antallet af dage fra afregningsdatoen til den næste "
"kuponperiode."

#: ../plugins/fn-financial/functions.c:2990
msgid "COUPNCD:the next coupon date after settlement"
msgstr "COUPNCD:Næste kupondato efter afregning"

#: ../plugins/fn-financial/functions.c:2996
msgid "COUPNCD calculates the coupon date following settlement."
msgstr "COUPNCD beregner kupondatoen efter afviklingen."

#: ../plugins/fn-financial/functions.c:3016
msgid "COUPPCD:the last coupon date before settlement"
msgstr "COUPPCD:Sidste kupondato før afregning"

#: ../plugins/fn-financial/functions.c:3022
msgid "COUPPCD calculates the coupon date preceding settlement."
msgstr "COUPPCD beregner kupondatoen før afviklingen."

#: ../plugins/fn-financial/functions.c:3042
msgid "COUPNUM:number of coupons"
msgstr "COUPNUM:Antal kuponer"

#: ../plugins/fn-financial/functions.c:3048
msgid ""
"COUPNUM calculates the number of coupons to be paid between the settlement "
"and maturity dates, rounded up."
msgstr ""
"COUPNUM beregner antallet af kuponer der skal betales mellem afregnings- og "
"udløbsdatoerne, rundet op."

#: ../plugins/fn-financial/functions.c:3066
msgid "CUMIPMT:cumulative interest payment"
msgstr "CUMIPMT:Akkumuleret rentebetaling"

#: ../plugins/fn-financial/functions.c:3067
#: ../plugins/fn-financial/functions.c:3108
msgid "rate:interest rate per period"
msgstr "rate:rente per periode"

#: ../plugins/fn-financial/functions.c:3070
#: ../plugins/fn-financial/functions.c:3111
#: ../plugins/fn-financial/functions.c:3197
msgid "start_period:first period to accumulate for"
msgstr "start_period:første periode der skal akkumuleres for"

#: ../plugins/fn-financial/functions.c:3071
#: ../plugins/fn-financial/functions.c:3112
#: ../plugins/fn-financial/functions.c:3198
msgid "end_period:last period to accumulate for"
msgstr "end_period:sidste periode der skal akkumuleres for"

#: ../plugins/fn-financial/functions.c:3073
msgid ""
"CUMIPMT calculates the cumulative interest paid on a loan from "
"@{start_period} to @{end_period}."
msgstr ""
"CUMIPMT beregner den kumulative rente betalt på et lån fra @{start_period} "
"til @{end_period}."

#: ../plugins/fn-financial/functions.c:3107
msgid "CUMPRINC:cumulative principal"
msgstr "CUMPRINC:Kumuleret hovedstol"

#: ../plugins/fn-financial/functions.c:3114
msgid ""
"CUMPRINC calculates the cumulative principal paid on a loan from "
"@{start_period} to @{end_period}."
msgstr ""
"CUMPRINC beregner den kumulative hovedstol betalt på et lån fra "
"@{start_period} til @{end_period}."

#: ../plugins/fn-financial/functions.c:3148
msgid "MDURATION:the modified (Macaulay) duration of a security"
msgstr "MDURATION:Den modificerede (Macaulay) varighed af et værdipapir"

#: ../plugins/fn-financial/functions.c:3155
msgid "MDURATION calculates the modified (Macaulay) duration of a security."
msgstr ""
"MDURATION beregner den modificerede (Macaulay-)varighed for et værdipapir."

#: ../plugins/fn-financial/functions.c:3193
msgid "VDB:depreciation of an asset"
msgstr "VDB:Afskrivning af et aktiv"

#: ../plugins/fn-financial/functions.c:3200
msgid "no_switch:do not switch to straight-line depreciation"
msgstr "no_switch:skift ikke til lineær afskrivning"

#: ../plugins/fn-financial/functions.c:3201
msgid ""
"VDB calculates the depreciation of an asset for a given period range using "
"the variable-rate declining balance method."
msgstr ""
"VDB beregner afskrivningen af et aktiv for et givet periodeinterval ved "
"hjælp af variabel-rate faldende saldo-metoden."

#: ../plugins/fn-financial/functions.c:3202
msgid ""
"If @{no_switch} is FALSE, the calculation switches to straight-line "
"depreciation when depreciation is greater than the declining balance "
"calculation."
msgstr ""
"Hvis @{no_switch} er FALSK, skifter beregningen til lineær afskrivning når "
"afskrivningen er større end den faldende saldo-beregning."

#: ../plugins/fn-flt/functions.c:36
msgid "FLT.RADIX:return the floating point system's base"
msgstr "FLT.RADIX:Returner flydetalssystemets grundtal"

#: ../plugins/fn-flt/functions.c:37
msgid ""
"The FLT.RADIX function returns the base of the floating point number system "
"in use."
msgstr ""
"FLT.RADIX-funktionen returnerer grundtallet for det anvendte flydetals-"
"talsystem."

#: ../plugins/fn-flt/functions.c:52
msgid "FLT.MIN:return the smallest positive floating point number"
msgstr "FLT.MIN:Returner det mindste positive flydende kommatal"

#: ../plugins/fn-flt/functions.c:53
msgid ""
"The FLT.MIN function returns the smallest positive normal floating point "
"number that can be represented."
