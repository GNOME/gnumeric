#: ../plugins/fn-math/functions.c:3320
msgid "Solves the equation @{A}*X=@{B} and returns X."
msgstr "Løser ligningen @{A}*X=@{B} og returnerer X."

#: ../plugins/fn-math/functions.c:3321
msgid "If the matrix @{A} is singular, #VALUE! is returned."
msgstr "Hvis matrixen @{A} er singulær, så returneres fejlen #VÆRDI!"

#: ../plugins/fn-math/functions.c:3371
msgid "MDETERM:the determinant of the matrix @{matrix}"
msgstr "MDETERM:Determinanten af matrixen @{matrix}"

#: ../plugins/fn-math/functions.c:3373
msgid ""
"Let us assume that A1,...,A4 contain numbers 2, 3, 7, and 3; B1,..., B4 4, "
"2, 4, and 1; C1,...,C4 9, 4, 3; and 2; and D1,...,D4 7, 3, 6, and 5. Then "
"MDETERM(A1:D4) yields 148."
msgstr ""

#: ../plugins/fn-math/functions.c:3403
msgid "SUMPRODUCT:multiplies components and adds the results"
msgstr "SUMPRODUCT:Multiplicerer komponenter og adderer resultaterne"

#: ../plugins/fn-math/functions.c:3405 ../plugins/fn-math/functions.c:3428
msgid ""
"Multiplies corresponding data entries in the given arrays or ranges, and "
"then returns the sum of those products."
msgstr ""

#: ../plugins/fn-math/functions.c:3408
msgid "If an entry is not numeric, the value zero is used instead."
msgstr "Hvis en post ikke er numerisk, bruges værdien nul i stedet."

#: ../plugins/fn-math/functions.c:3409 ../plugins/fn-math/functions.c:3432
msgid ""
"If arrays or range arguments do not have the same dimensions, return #VALUE! "
"error."
msgstr ""
"Hvis matrixer eller intervalargumenter ikke har samme størrelse, så "
"returneres fejlen #VALUE!"

#: ../plugins/fn-math/functions.c:3411
msgid ""
"This function ignores logicals, so using SUMPRODUCT(A1:A5>0) will not work.  "
"Instead use SUMPRODUCT(--(A1:A5>0))"
msgstr ""

#: ../plugins/fn-math/functions.c:3420
msgid ""
"This function is not OpenFormula compatible. Use ODF.SUMPRODUCT instead."
msgstr ""

#: ../plugins/fn-math/functions.c:3426
msgid "ODF.SUMPRODUCT:multiplies components and adds the results"
msgstr "ODF.SUMPRODUCT:Multiplicerer komponenter og adderer resultaterne"

#: ../plugins/fn-math/functions.c:3431
msgid "If an entry is not numeric or logical, the value zero is used instead."
msgstr ""
"Hvis en post ikke er numerisk eller logisk, bruges værdien nul i stedet."

#: ../plugins/fn-math/functions.c:3434
msgid "This function differs from SUMPRODUCT by considering booleans."
msgstr ""
"Denne funktion adskiller sig fra SUMPRODUCT ved at tage hensyn til "
"sandhedsværdier."

#: ../plugins/fn-math/functions.c:3435
msgid "This function is not Excel compatible. Use SUMPRODUCT instead."
msgstr "Denne funktion er ikke kompatibel med Excel. Brug SUMPRODUCT i stedet."

#: ../plugins/fn-math/functions.c:3570
msgid "EIGEN:eigenvalues and eigenvectors of the symmetric @{matrix}"
msgstr "EIGEN:Egenværdier og egenvektorer for den symmetriske @{matrix}"

#: ../plugins/fn-math/functions.c:3571
msgid "matrix:a symmetric matrix"
msgstr "matrix:en symmetrisk matrix"

#: ../plugins/fn-math/functions.c:3572
msgid ""
"If @{matrix} is not symmetric, matching off-diagonal cells will be averaged "
"on the assumption that the non-symmetry is caused by unimportant rounding "
"errors."
msgstr ""

#: ../plugins/fn-math/functions.c:3573
msgid ""
"If @{matrix} does not contain an equal number of columns and rows, EIGEN "
"returns #VALUE!"
msgstr ""
"Hvis @{matrix} ikke indeholder et lige antal kolonner og rækker, så "
"returnerer EIGEN #VÆRDI!"

#: ../plugins/fn-numtheory/numtheory.c:336
msgid "NT_OMEGA:Number of distinct prime factors"
msgstr "NT_OMEGA:Antal forskellige primfaktorer"

#: ../plugins/fn-numtheory/numtheory.c:338
msgid "Returns the number of distinct prime factors without multiplicity."
msgstr "Returnerer antallet af forskellige primfaktorer uden multiplicitet."

#: ../plugins/fn-numtheory/numtheory.c:369
msgid "NT_PHI:Euler's totient function"
msgstr "NT_PHI:Eulers totient-funktion"

#: ../plugins/fn-numtheory/numtheory.c:371
msgid ""
"Euler's totient function gives the number of integers less than or equal to "
"@{n} that are relatively prime (coprime) to @{n}."
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:374
msgid "wiki:en:Euler's_totient_function"
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:403
msgid "NT_RADICAL:Radical function"
msgstr "NT_RADICAL:Radikalfunktion"

#: ../plugins/fn-numtheory/numtheory.c:405
msgid "The function computes the product of its distinct prime factors"
msgstr "Funktionen beregner produktet af dens forskellige primfaktorer"

#: ../plugins/fn-numtheory/numtheory.c:436
msgid "NT_MU:Möbius mu function"
msgstr "NT_MU:Möbius mu-funktion"

#: ../plugins/fn-numtheory/numtheory.c:439
msgid ""
"NT_MU function (Möbius mu function) returns 0  if @{n} is divisible by the "
"square of a prime. Otherwise, if @{n} has an odd  number of different prime "
"factors, NT_MU returns -1, and if @{n} has an even number of different prime "
"factors, it returns 1. If @{n} = 1, NT_MU returns 1."
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:446
msgid "wiki:en:Möbius_function"
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:447
msgid "wolfram:MoebiusFunction.html"
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:477
msgid "NT_D:number of divisors"
msgstr "NT_D:Antal divisorer"

#: ../plugins/fn-numtheory/numtheory.c:479
msgid "NT_D calculates the number of divisors of @{n}."
msgstr "NT_D beregner antallet af divisorer for @{n}."

#: ../plugins/fn-numtheory/numtheory.c:509
msgid "NT_SIGMA:sigma function"
msgstr "NT_SIGMA:Sigma-funktion"

#: ../plugins/fn-numtheory/numtheory.c:511
msgid "NT_SIGMA calculates the sum of the divisors of @{n}."
msgstr "NT_SIGMA beregner summen af divisorerne for @{n}."

#: ../plugins/fn-numtheory/numtheory.c:514
msgid "wiki:en:Divisor_function"
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:551
msgid "ITHPRIME:@{i}th prime"
msgstr "ITHPRIME:@{i}'ende primtal"

#: ../plugins/fn-numtheory/numtheory.c:552
msgid "i:positive integer"
msgstr "i:positivt heltal"

#: ../plugins/fn-numtheory/numtheory.c:553
msgid "ITHPRIME finds the @{i}th prime."
msgstr "ITHPRIME finder det @{i}'ende primtal."

#: ../plugins/fn-numtheory/numtheory.c:577
msgid "ISPRIME:whether @{n} is prime"
msgstr "ISPRIME:Hvorvidt @{n} er et primtal"

#: ../plugins/fn-numtheory/numtheory.c:579
msgid "ISPRIME returns TRUE if @{n} is prime and FALSE otherwise."
msgstr "ISPRIME returnerer SAND hvis @{n} er et primtal og FALSK ellers."

#: ../plugins/fn-numtheory/numtheory.c:582
msgid "wolfram:PrimeNumber.html"
msgstr ""

#: ../plugins/fn-numtheory/numtheory.c:632
msgid "PFACTOR:smallest prime factor"
msgstr "PFACTOR:Mindste primfaktor"

#: ../plugins/fn-numtheory/numtheory.c:634
msgid "PFACTOR finds the smallest prime factor of its argument."
msgstr "PFACTOR finder den mindste primfaktor af sit argument."

#: ../plugins/fn-numtheory/numtheory.c:635
msgid ""
"The argument @{n} must be at least 2. Otherwise a #VALUE! error is returned."
msgstr "Argumentet @{n} skal være mindst 2. Ellers returneres fejlen #VÆRDI!"

#: ../plugins/fn-numtheory/numtheory.c:663
msgid "NT_PI:number of primes upto @{n}"
msgstr "NT_PI:Antal primtal op til @{n}"

#: ../plugins/fn-numtheory/numtheory.c:665
msgid "NT_PI returns the number of primes less than or equal to @{n}."
msgstr "NT_PI returnerer antallet af primtal mindre end eller lig med @{n}."

#: ../plugins/fn-numtheory/numtheory.c:668
msgid "wolfram:PrimeCountingFunction.html"
msgstr ""

