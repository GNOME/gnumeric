msgid ""
"INDEX gives a reference to a cell in the given @{array}. The cell is "
"selected by @{row} and @{col}, which count the rows and columns in the array."
msgstr ""

#: ../plugins/fn-lookup/functions.c:1622
msgid ""
"If the reference falls outside the range of @{array}, INDEX returns #REF!"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1624
msgid ""
"Let us assume that the cells A1, A2, ..., A5 contain numbers 11.4, 17.3, "
"21.3, 25.9, and 40.1. Then INDEX(A1:A5,4,1,1) equals 25.9"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1731
msgid "COLUMN:vector of column numbers"
msgstr "COLUMN:Vektor af kolonnenumre"

#: ../plugins/fn-lookup/functions.c:1732 ../plugins/fn-lookup/functions.c:1884
msgid "x:reference, defaults to the position of the current expression"
msgstr "x:reference, standardværdi er positionen for det aktuelle udtryk"

#: ../plugins/fn-lookup/functions.c:1733
msgid ""
"COLUMN function returns a Nx1 array containing the sequence of integers from "
"the first column to the last column of @{x}."
msgstr ""

# mangler der ikke noget i den engelske streng her.
#: ../plugins/fn-lookup/functions.c:1736 ../plugins/fn-lookup/functions.c:1888
msgid ""
"If @{x} is neither an array nor a reference nor a range, returns #VALUE!"
msgstr ""

#: ../plugins/fn-lookup/functions.c:1740
msgid "COLUMN() in G13 equals 7."
msgstr "COLUMN() i G13 er lig med 7."

#: ../plugins/fn-lookup/functions.c:1780
msgid "COLUMNNUMBER:column number for the given column called @{name}"
msgstr "COLUMNNUMBER:Kolonnenummer for den givne kolonne kaldet @{name}"

#: ../plugins/fn-lookup/functions.c:1781
msgid "name:column name such as \"IV\""
msgstr "name:kolonnenavn såsom \"IV\""

#: ../plugins/fn-lookup/functions.c:1782
msgid "If @{name} is invalid, COLUMNNUMBER returns #VALUE!"
msgstr "Hvis @{name} er ugyldigt, så returnerer COLUMNNUMBER #VÆRDI!"

