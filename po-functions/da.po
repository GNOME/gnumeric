msgstr "value:oprindelig værdi"

#: ../plugins/fn-string/functions.c:1429
msgid "TEXT:@{value} as a string formatted as @{format}"
msgstr "TEXT:@{value} som en tekststreng formateret som @{format}"

#: ../plugins/fn-string/functions.c:1430
msgid "value:value to be formatted"
msgstr "value:værdi der skal formateres"

#: ../plugins/fn-string/functions.c:1431
msgid "format:desired format"
msgstr "format:ønsket format"

#: ../plugins/fn-string/functions.c:1483
msgid "TRIM:@{text} with only single spaces between words"
msgstr "TRIM:@{text} med kun enkelte mellemrum mellem ord"

#: ../plugins/fn-string/functions.c:1524
msgid "VALUE:numeric value of @{text}"
msgstr "VALUE:Numerisk værdi af @{text}"

#: ../plugins/fn-string/functions.c:1557
msgid "NUMBERVALUE:numeric value of @{text}"
msgstr "NUMBERVALUE:Numerisk værdi af @{text}"

#: ../plugins/fn-string/functions.c:1559
msgid "separator:decimal separator"
msgstr "separator:decimalskilletegn"

#: ../plugins/fn-string/functions.c:1560
msgid "group_separator:group separator"
msgstr "group_separator:tusindtalsskilletegn"

#: ../plugins/fn-string/functions.c:1561
msgid ""
"If @{text} does not look like a decimal number, NUMBERVALUE returns the "
"value VALUE would return (ignoring the given @{separator})."
msgstr ""
"Hvis @{text} ikke ligner et decimaltal, returnerer NUMBERVALUE den værdi "
"VALUE ville returnere (ignorerer den givne @{separator})."

#: ../plugins/fn-string/functions.c:1631
msgid "SUBSTITUTE:@{text} with all occurrences of @{old} replaced by @{new}"
msgstr ""
"SUBSTITUTE:@{text} hvor alle forekomster af @{old} er erstattet med @{new}"

#: ../plugins/fn-string/functions.c:1632 ../plugins/fn-string/functions.c:2414
msgid "text:original text"
msgstr "text:oprindelig tekst"

#: ../plugins/fn-string/functions.c:1633
msgid "old:string to be replaced"
msgstr "old:streng der skal erstattes"

#: ../plugins/fn-string/functions.c:1635
msgid ""
"num:if @{num} is specified and a number only the @{num}th occurrence of "
"@{old} is replaced"
msgstr ""
"num:hvis @{num} er angivet og et tal erstattes kun den @{num}'ende forekomst "
"af @{old}"

#: ../plugins/fn-string/functions.c:1705
msgid "TEXTBEFORE:text before @{delimiter}"
msgstr "TEXTBEFORE:tekst før @{delimiter}"

#: ../plugins/fn-string/functions.c:1707 ../plugins/fn-string/functions.c:1841
msgid "delimiter:delimiter string or array of strings"
msgstr "delimiter:skilletegn eller et array af skilletegn"

#: ../plugins/fn-string/functions.c:1708 ../plugins/fn-string/functions.c:1842
msgid "instance_num:the instance of the delimiter; defaults to 1"
msgstr "instance_num:forekomsten af skilletegnet; standard er 1"

#: ../plugins/fn-string/functions.c:1709 ../plugins/fn-string/functions.c:1843
#: ../plugins/fn-string/functions.c:1910
msgid "match_mode:0 for case-sensitive (default), 1 for case-insensitive"
msgstr ""

#: ../plugins/fn-string/functions.c:1710 ../plugins/fn-string/functions.c:1844
msgid ""
"match_end:0 for no match at the end (default), 1 to match the end of the text"
msgstr ""

#: ../plugins/fn-string/functions.c:1712
msgid "TEXTBEFORE returns the text that occurs before the given @{delimiter}."
msgstr ""

#: ../plugins/fn-string/functions.c:1839
msgid "TEXTAFTER:text after @{delimiter}"
msgstr "TEXTAFTER:tekst efter @{delimiter}"

#: ../plugins/fn-string/functions.c:1846
msgid "TEXTAFTER returns the text that occurs after the given @{delimiter}."
msgstr ""
"TEXTAFTER returnerer den tekst, der forekommer efter det givne @{delimiter}."

#: ../plugins/fn-string/functions.c:1905
msgid "TEXTSPLIT:split @{text} into an array using delimiters"
msgstr "TEXTSPLIT:opdel @{text} i et array ved brug af skilletegn"

#: ../plugins/fn-string/functions.c:1907
msgid "col_delimiter:delimiter(s) for columns"
msgstr "col_delimiter:skilletegn til kolonner"

#: ../plugins/fn-string/functions.c:1908
msgid "row_delimiter:delimiter(s) for rows; optional"
msgstr "row_delimiter:skilletegn til rækker; valgfri"

#: ../plugins/fn-string/functions.c:1909
msgid ""
"ignore_empty:TRUE to ignore empty cells in the result; defaults to FALSE"
msgstr ""
"ignore_empty:SAND for at ignorere tomme celler i resultatet; standard er "
"FALSK"

#: ../plugins/fn-string/functions.c:1911
msgid "pad_with:value to pad the result array with; defaults to #N/A"
msgstr ""

#: ../plugins/fn-string/functions.c:1912
msgid ""
"TEXTSPLIT splits @{text} into multiple cells using the provided column and "
"row delimiters."
msgstr ""
"TEXTSPLIT opdeler @{text} i flere celler ved hjælp af de angivne kolonne- og "
"rækkeskilletegn."

#: ../plugins/fn-string/functions.c:1994
msgid "DOLLAR:@{num} formatted as currency"
msgstr "DOLLAR:@{num} formateret som valuta"

#: ../plugins/fn-string/functions.c:1996
msgid "decimals:decimals"
msgstr "decimals:decimaler"

#: ../plugins/fn-string/functions.c:2066
msgid ""
"SEARCH:the location of the @{search} string within @{text} after position "
"@{start}"
msgstr "SEARCH:Positionen af @{search} i strengen @{text} efter @{start}"

#: ../plugins/fn-string/functions.c:2068 ../plugins/fn-string/functions.c:2111
msgid "search:search string"
msgstr "search:søgestreng"

#: ../plugins/fn-string/functions.c:2069 ../plugins/fn-string/functions.c:2112
msgid "text:search field"
msgstr "text:søgefelt"

#: ../plugins/fn-string/functions.c:2071 ../plugins/fn-string/functions.c:2114
msgid ""
"@{search} may contain wildcard characters (*) and question marks (?). A "
"question mark matches any single character, and a wildcard matches any "
"string including the empty string. To search for * or ?, precede the symbol "
"with ~."
msgstr ""
"@{search} kan indeholde jokertegn (*) og spørgsmålstegn (?). Et "
"spørgsmålstegn matcher et hvilket som helst enkelt tegn, og et jokertegn "
"matcher enhver streng inklusive den tomme streng. For at søge efter * "
"eller ?, sæt ~ foran symbolet."

#: ../plugins/fn-string/functions.c:2076 ../plugins/fn-string/functions.c:2119
msgid "This search is not case sensitive."
msgstr "Denne søgning skelner ikke mellem store og små bogstaver."

#: ../plugins/fn-string/functions.c:2077
msgid "If @{search} is not found, SEARCH returns #VALUE!"
msgstr "Hvis @{search} ikke findes, så returnerer SEARCH #VÆRDI!"

#: ../plugins/fn-string/functions.c:2078
msgid ""
"If @{start} is less than one or it is greater than the length of @{text}, "
"SEARCH returns #VALUE!"
msgstr ""
"Hvis @{start} er mindre end en eller den er større end længden af @{text}, "
"returnerer SEARCH #VÆRDI!"

#: ../plugins/fn-string/functions.c:2109
msgid ""
"SEARCHB:the location of the @{search} string within @{text} after byte "
"position @{start}"
msgstr ""
"SEARCHB:Placeringen af @{search}-strengen i @{text} efter byte-position "
"@{start}"

#: ../plugins/fn-string/functions.c:2120
msgid "If @{search} is not found, SEARCHB returns #VALUE!"
msgstr "Hvis @{search} ikke findes, så returnerer SEARCHB #VÆRDI!"

#: ../plugins/fn-string/functions.c:2121
msgid ""
"If @{start} is less than one or it is greater than the byte length of "
"@{text}, SEARCHB returns #VALUE!"
msgstr ""
"Hvis @{start} er mindre end en eller den er større end bytelængden på "
"@{text}, så returnerer SEARCHB #VÆRDI!"

#: ../plugins/fn-string/functions.c:2167
msgid ""
"ASC:text with full-width katakana and ASCII characters converted to half-"
"width"
msgstr ""
"ASC:Tekst hvor fuldbredde-katakana og ASCII-tegn er konverteret til "
"halvbredde"

#: ../plugins/fn-string/functions.c:2169
msgid ""
"ASC converts full-width katakana and ASCII characters to half-width "
"equivalent characters, copying all others."
msgstr ""
"ASC konverterer fuldbredde-katakana og ASCII-tegn til halvbreddeækvivalente "
"tegn og kopierer alle andre."

#: ../plugins/fn-string/functions.c:2170 ../plugins/fn-string/functions.c:2417
msgid ""
"The distinction between half-width and full-width characters is described in "
"http://www.unicode.org/reports/tr11/."
msgstr ""
"Forskellen mellem halvbredde- og fuldbredde-tegn er beskrevet i http://www."
"unicode.org/reports/tr11/."

#: ../plugins/fn-string/functions.c:2171 ../plugins/fn-string/functions.c:2419
msgid "For most strings, this function has the same effect as in Excel."
msgstr "For de fleste strenge har denne funktion samme effekt som i Excel."

#: ../plugins/fn-string/functions.c:2172
msgid ""
"While in obsolete encodings ASC used to translate between 2-byte and 1-byte "
"characters, this is not the case in UTF-8."
msgstr ""
"Selvom ASC i forældede kodninger plejede at oversætte mellem 2-byte og 1-"
"byte tegn, er dette ikke tilfældet i UTF-8."

#: ../plugins/fn-string/functions.c:2413
msgid ""
"JIS:text with half-width katakana and ASCII characters converted to full-"
"width"
msgstr ""
"JIS:Tekst hvor halvbredde-katakana og ASCII-tegn er konverteret til "
"fuldbredde"

#: ../plugins/fn-string/functions.c:2415
msgid ""
"JIS converts half-width katakana and ASCII characters to full-width "
"equivalent characters, copying all others."
msgstr ""
"JIS konverterer halvbredde-katakana og ASCII-tegn til fuldbreddeækvivalente "
"tegn og kopierer alle andre."

#: ../plugins/fn-string/functions.c:2420
msgid ""
"While in obsolete encodings JIS used to translate between 1-byte and 2-byte "
"characters, this is not the case in UTF-8."
msgstr ""
"Selvom JIS i forældede kodninger plejede at oversætte mellem 1-byte og 2-"
"byte tegn, er dette ikke tilfældet i UTF-8."

#: ../plugins/fn-tsa/functions.c:80
msgid ""
"Possible interpolation methods are:\n"
"0: linear;\n"
"1: linear with averaging;\n"
"2: staircase;\n"
"3: staircase with averaging;\n"
"4: natural cubic spline;\n"
"5: natural cubic spline with averaging."
msgstr ""
"Mulige interpolationsmetoder er:\n"
"0: lineær;\n"
"1: lineær med gennemsnitsdannelse;\n"
"2: trappeformet;\n"
"3: trappeformet med gennemsnitsdannelse;\n"
"4: naturlig kubisk spline;\n"
"5: naturlig kubisk spline med gennemsnitsdannelse."

#: ../plugins/fn-tsa/functions.c:365
msgid ""
"INTERPOLATION:interpolated values corresponding to the given abscissa targets"
msgstr "INTERPOLATION:Interpolerede værdier svarende til de givne abscisse-mål"

#: ../plugins/fn-tsa/functions.c:366
msgid "abscissae:abscissae of the given data points"
msgstr "abscissae:abscisser for de givne datapunkter"

#: ../plugins/fn-tsa/functions.c:367
msgid "ordinates:ordinates of the given data points"
msgstr "ordinates:ordinater for de givne datapunkter"

#: ../plugins/fn-tsa/functions.c:368
msgid "targets:abscissae of the interpolated data"
msgstr "targets:abscisser for de interpolerede data"

#: ../plugins/fn-tsa/functions.c:369
msgid "interpolation:method of interpolation, defaults to 0 ('linear')"
msgstr "interpolation:interpolationsmetode, standardværdi er 0 ('lineær')"

#: ../plugins/fn-tsa/functions.c:370 ../plugins/fn-tsa/functions.c:557
msgid "The output consists always of one column of numbers."
msgstr "Resultatet består altid af én kolonne med tal."

#: ../plugins/fn-tsa/functions.c:372
msgid ""
"The @{abscissae} should be given in increasing order. If the @{abscissae} is "
"not in increasing order the INTERPOLATION function is significantly slower."
msgstr ""
"@{abscissae} skal være givet i stigende rækkefølge. Hvis @{abscissae} ikke "
"er i stigende rækkefølge er INTERPOLATION-funktionen betydeligt langsommere."

#: ../plugins/fn-tsa/functions.c:374
msgid "If any two @{abscissae} values are equal an error is returned."
msgstr "Hvis to @{abscissae}-værdier er ens, så returneres en fejl."

#: ../plugins/fn-tsa/functions.c:375
msgid ""
"If any of interpolation methods 1 ('linear with averaging'), 3 ('staircase "
"with averaging'), and 5 ('natural cubic spline with averaging') is used, the "
"number of returned values is one less than the number of targets and the "
"target values must be given in increasing order. The values returned are the "
"average heights of the interpolation function on the intervals determined by "
"consecutive target values."
msgstr ""
"Hvis en af interpolationsmetoderne 1 ('lineær med gennemsnitsdannelse'), 3 "
"('trappeformet med gennemsnitsdannelse') og 5 ('naturlig kubisk spline med "
"gennemsnitsdannelse') bruges, er antallet af returnerede værdier én mindre "
"end antallet af mål og målværdierne skal være givet i stigende rækkefølge. "
"De returnerede værdier er gennemsnitshøjderne af interpolationsfunktionen på "
"intervallerne bestemt af på hinanden følgende målværdier."

#: ../plugins/fn-tsa/functions.c:382 ../plugins/fn-tsa/functions.c:564
msgid "Strings and empty cells in @{abscissae} and @{ordinates} are ignored."
msgstr "Strenge og tomme celler i @{abscissae} og @{ordinates} ignoreres."

#: ../plugins/fn-tsa/functions.c:383 ../plugins/fn-tsa/functions.c:565
msgid ""
"If several target data are provided they must be in the same column in "
"consecutive cells."
msgstr ""
"Hvis flere måldata leveres skal de være i samme kolonne i på hinanden "
"følgende celler."

#: ../plugins/fn-tsa/functions.c:550
msgid "PERIODOGRAM:periodogram of the given data"
msgstr "PERIODOGRAM:Periodogram for de givne data"

#: ../plugins/fn-tsa/functions.c:551
msgid "ordinates:ordinates of the given data"
msgstr "ordinates:ordinater for de givne data"

#: ../plugins/fn-tsa/functions.c:552
msgid "filter:windowing function to be used, defaults to no filter"
msgstr "filter:vinduefunktion der skal bruges, standardværdi er ingen filter"

#: ../plugins/fn-tsa/functions.c:553
msgid ""
"abscissae:abscissae of the given data, defaults to regularly spaced abscissae"
msgstr ""
"abscissae:abscisser for de givne data, standard er jævnt fordelte abscisser"

#: ../plugins/fn-tsa/functions.c:554
msgid "interpolation:method of interpolation, defaults to none"
msgstr "interpolation:interpolationsmetode, standardværdi er ingen"

#: ../plugins/fn-tsa/functions.c:555
msgid "number:number of interpolated data points"
msgstr "number:antal interpolerede datapunkter"

#: ../plugins/fn-tsa/functions.c:556
msgid ""
"If an interpolation method is used, the number of returned values is one "
"less than the number of targets and the targets values must be given in "
"increasing order."
msgstr ""
"Hvis en interpolationsmetode bruges, er antallet af returnerede værdier én "
"mindre end antallet af mål og målværdierne skal være givet i stigende "
"rækkefølge."

#: ../plugins/fn-tsa/functions.c:559
msgid ""
"Possible window functions are:\n"
"0: no filter (rectangular window)\n"
"1: Bartlett (triangular window)\n"
"2: Hahn (cosine window)\n"
"3: Welch (parabolic window)"
msgstr ""
"Mulige vinduefunktioner er:\n"
"0: intet filter (rektangulært vindue)\n"
"1: Bartlett (trekantet vindue)\n"
"2: Hahn (cosinus-vindue)\n"
"3: Welch (parabolsk vindue)"

#: ../plugins/fn-tsa/functions.c:808
msgid "FOURIER:Fourier or inverse Fourier transform"
msgstr "FOURIER:Fourier- eller invers Fourier-transformation"

#: ../plugins/fn-tsa/functions.c:809 ../plugins/fn-tsa/functions.c:905
msgid "Sequence:the data sequence to be transformed"
msgstr "Sequence:datasekvensen der skal transformeres"

#: ../plugins/fn-tsa/functions.c:810
msgid ""
"Inverse:if true, the inverse Fourier transform is calculated, defaults to "
"false"
msgstr ""
"Inverse:hvis sand, beregnes den inverse Fourier-transformation, "
"standardværdi er falsk"

#: ../plugins/fn-tsa/functions.c:811
msgid ""
"Separate:if true, the real and imaginary parts are given separately, "
"defaults to false"
msgstr ""
"Separate:hvis sand, gives de reelle og imaginære dele separat, standardværdi "
"er falsk"

#: ../plugins/fn-tsa/functions.c:812
msgid ""
"This array function returns the Fourier or inverse Fourier transform of the "
"given data sequence."
msgstr ""
"Denne matrix-funktion returnerer Fourier- eller inverse Fourier-"
"transformationen af den givne datasekvens."

#: ../plugins/fn-tsa/functions.c:813
msgid ""
"The output consists of one column of complex numbers if @{Separate} is false "
"and of two columns of real numbers if @{Separate} is true."
msgstr ""
"Outputtet består af én kolonne af komplekse tal hvis @{Separate} er falsk og "
"af to kolonner af reelle tal hvis @{Separate} er sand."

#: ../plugins/fn-tsa/functions.c:814
msgid ""
"If @{Separate} is true the first output column contains the real parts and "
"the second column the imaginary parts."
msgstr ""
"Hvis @{Separate} er sand indeholder den første outputkolonne de reelle dele "
"og den anden kolonne de imaginære dele."

#: ../plugins/fn-tsa/functions.c:815 ../plugins/fn-tsa/functions.c:909
msgid ""
"If @{Sequence} is neither an n by 1 nor 1 by n array, this function returns "
"#VALUE!"
msgstr ""
"Hvis @{Sequence} hverken er en n×1 eller 1×n matrix, returnerer denne "
"funktion #VÆRDI!"

#: ../plugins/fn-tsa/functions.c:904
msgid "HPFILTER:Hodrick Prescott Filter"
msgstr "HPFILTER:Hodrick-Prescott-filter"

#: ../plugins/fn-tsa/functions.c:906
msgid "λ:filter parameter λ, defaults to 1600"
msgstr "λ:filterparameter λ, standardværdi er 1600"

#: ../plugins/fn-tsa/functions.c:907
msgid ""
"This array function returns the trend and cyclical components obtained by "
"applying the Hodrick Prescott Filter with parameter @{λ} to the given data "
"sequence."
msgstr ""
"Denne matrix-funktion returnerer trend- og cykliske komponenter opnået ved "
"at anvende Hodrick Prescott-filteret med parameter @{λ} på den givne "
"datasekvens."

#: ../plugins/fn-tsa/functions.c:908
msgid ""
"The output consists of two columns of numbers, the first containing the "
"trend component, the second the cyclical component."
msgstr ""
"Outputtet består af to kolonner af tal, den første indeholder "
"trendkomponenten, den anden den cykliske komponent."

#: ../plugins/fn-tsa/functions.c:910
msgid ""
"If @{Sequence} contains less than 6 numerical values, this function returns "
"#VALUE!"
msgstr ""
"Hvis @{Sequence} indeholder færre end 6 numeriske værdier, returnerer denne "
"funktion #VÆRDI!"

#: ../plugins/gda/plugin-gda.c:372
msgid "EXECSQL:result of executing @{sql} in the libgda data source @{dsn}"
msgstr "EXECSQL:Resultat af udførelse af @{sql} i libgda-datakilden @{dsn}"

#: ../plugins/gda/plugin-gda.c:374 ../plugins/gda/plugin-gda.c:450
msgid "dsn:libgda data source"
msgstr "dsn:libgda-datakilde"

#: ../plugins/gda/plugin-gda.c:375 ../plugins/gda/plugin-gda.c:451
msgid "username:user name to access @{dsn}"
msgstr "username:brugernavn til adgang til @{dsn}"

#: ../plugins/gda/plugin-gda.c:376 ../plugins/gda/plugin-gda.c:452
msgid "password:password to access @{dsn} as @{username}"
msgstr "password:adgangskode til adgang til @{dsn} som @{username}"

#: ../plugins/gda/plugin-gda.c:377
msgid "sql:SQL command"
msgstr "sql:SQL-kommando"

#: ../plugins/gda/plugin-gda.c:378 ../plugins/gda/plugin-gda.c:454
msgid "Before using EXECSQL, you need to set up a libgda data source."
msgstr "Før brug af EXECSQL skal du opsætte en libgda-datakilde."

#: ../plugins/gda/plugin-gda.c:449
msgid "READDBTABLE:all rows of the table @{table} in @{dsn}"
msgstr "READDBTABLE:Alle rækker fra tabellen @{table} i @{dsn}"

#: ../plugins/gda/plugin-gda.c:453
msgid "table:SQL table to retrieve"
msgstr "table:SQL-tabel der skal hentes"

#: ../plugins/sample_datasource/sample_datasource.c:224
msgid "ATL_LAST:sample real-time data source"
msgstr "ATL_LAST:Eksempel på realtidsdatakilde"

#: ../plugins/sample_datasource/sample_datasource.c:225
msgid "tag:tag to watch"
msgstr "tag:mærke der skal overvåges"

#: ../plugins/sample_datasource/sample_datasource.c:226
msgid ""
"ATL_LAST is a sample implementation of a real time data source.  It takes a "
"string tag and monitors the named pipe ~/atl for changes to the value of "
"that tag."
msgstr ""
"ATL_LAST er en prøveimplementering af en realtids datakilde. Den tager et "
"streng-tag og overvåger den navngivne pipe ~/atl for ændringer i værdien af "
"det pågældende tag."

#: ../plugins/sample_datasource/sample_datasource.c:227
msgid "This is not intended to be generally enabled and is OFF by default."
msgstr ""
"Dette er ikke beregnet til at være generelt aktiveret og er FRA som standard."
