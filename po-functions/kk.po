msgstr "DSTDEV(A1:C7, \"Salary\", A9:B11) мәні 9135.112506-ға тең."

#: ../plugins/fn-database/functions.c:686
msgid "DSTDEVP:standard deviation of the population of values in @{field} in @{database} belonging to records that match @{criteria}"
msgstr "DSTDEVP: @{database} ішіндегі @{criteria} шартына сәйкес келетін жазбалардағы @{field} мәндерінің жиынтық стандартты ауытқуы"

#: ../plugins/fn-database/functions.c:696
msgid "DSTDEVP(A1:C7, \"Age\", A9:B11) equals 7."
msgstr "DSTDEVP(A1:C7, \"Age\", A9:B11) мәні 7-ге тең."

#: ../plugins/fn-database/functions.c:697
msgid "DSTDEVP(A1:C7, \"Salary\", A9:B11) equals 6459.5."
msgstr "DSTDEVP(A1:C7, \"Salary\", A9:B11) мәні 6459.5-ке тең."

#: ../plugins/fn-database/functions.c:720
msgid "DSUM:sum of the values in @{field} in @{database} belonging to records that match @{criteria}"
msgstr "DSUM: @{database} ішіндегі @{criteria} шартына сәйкес келетін жазбалардағы @{field} мәндерінің қосындысы"

#: ../plugins/fn-database/functions.c:729
msgid "DSUM(A1:C7, \"Age\", A9:B11) equals 72."
msgstr "DSUM(A1:C7, \"Age\", A9:B11) мәні 72-ге тең."

#: ../plugins/fn-database/functions.c:730
msgid "DSUM(A1:C7, \"Salary\", A9:B11) equals 81565."
msgstr "DSUM(A1:C7, \"Salary\", A9:B11) мәні 81565-ке тең."

#: ../plugins/fn-database/functions.c:754
msgid "DVAR:sample variance of the values in @{field} in @{database} belonging to records that match @{criteria}"
msgstr "DVAR: @{database} ішіндегі @{criteria} шартына сәйкес келетін жазбалардағы @{field} мәндерінің таңдамалы дисперсиясы"

#: ../plugins/fn-database/functions.c:763
msgid "DVAR(A1:C7, \"Age\", A9:B11) equals 98."
msgstr "DVAR(A1:C7, \"Age\", A9:B11) мәні 98-ге тең."

#: ../plugins/fn-database/functions.c:764
msgid "DVAR(A1:C7, \"Salary\", A9:B11) equals 83450280.5."
msgstr "DVAR(A1:C7, \"Salary\", A9:B11) мәні 83450280.5-ке тең."

#: ../plugins/fn-database/functions.c:787
msgid "DVARP:variance of the population of values in @{field} in @{database} belonging to records that match @{criteria}"
msgstr "DVARP: @{database} ішіндегі @{criteria} шартына сәйкес келетін жазбалардағы @{field} мәндерінің жиынтық дисперсиясы"

#: ../plugins/fn-database/functions.c:797
msgid "DVARP(A1:C7, \"Age\", A9:B11) equals 49."
msgstr "DVARP(A1:C7, \"Age\", A9:B11) мәні 49-ға тең."

#: ../plugins/fn-database/functions.c:798
msgid "DVARP(A1:C7, \"Salary\", A9:B11) equals 41725140.25."
msgstr "DVARP(A1:C7, \"Salary\", A9:B11) мәні 41725140.25-ке тең."

#: ../plugins/fn-database/functions.c:821
msgid "GETPIVOTDATA:summary data from a pivot table"
msgstr "GETPIVOTDATA: жиынтық кестеден алынған жиынтық деректер"

#: ../plugins/fn-database/functions.c:822
msgid "pivot_table:cell range containing the pivot table"
msgstr "pivot_table: жиынтық кестесі бар ұяшықтар ауқымы"

#: ../plugins/fn-database/functions.c:823
msgid "field_name:name of the field for which the summary data is requested"
msgstr "field_name: жиынтық деректер сұралатын өрістің аты"

#: ../plugins/fn-database/functions.c:824
msgid "If the summary data is unavailable, GETPIVOTDATA returns #REF!"
msgstr "Егер жиынтық деректер қолжетімсіз болса, GETPIVOTDATA функциясы #REF! қайтарады"

#: ../plugins/fn-date/functions.c:72
msgid "DATE:create a date serial value"
msgstr "DATE: сериялық күн мәнін жасау"

#: ../plugins/fn-date/functions.c:73
msgid "year:year of date"
msgstr "year: күннің жылы"

#: ../plugins/fn-date/functions.c:74
msgid "month:month of year"
msgstr "month: жылдың айы"

#: ../plugins/fn-date/functions.c:75
msgid "day:day of month"
msgstr "day: айдың күні"

#: ../plugins/fn-date/functions.c:76
msgid "The DATE function creates date serial values.  1-Jan-1900 is serial value 1, 2-Jan-1900 is serial value 2, and so on.  For compatibility reasons, a serial value is reserved for the non-existing date 29-Feb-1900."
msgstr "DATE функциясы сериялық күн мәндерін жасайды. 1-қаң-1900 — сериялық мәні 1, 2-қаң-1900 — сериялық мәні 2 және т.с.с. Үйлесімділік мақсатында 29-ақп-1900 жоқ күні үшін сериялық мән сақталған."

#: ../plugins/fn-date/functions.c:77
msgid "If @{month} or @{day} is less than 1 or too big, then the year and/or month will be adjusted."
msgstr "Егер @{month} немесе @{day} 1-ден кем немесе тым үлкен болса, онда жыл және/немесе ай реттеледі."

#: ../plugins/fn-date/functions.c:78
msgid "For spreadsheets created with the Mac version of Excel, serial 1 is 1-Jan-1904."
msgstr "Excel бағдарламасының Mac нұсқасымен жасалған кестелер үшін 1 сериялық мәні 1-қаң-1904 болып табылады."

#: ../plugins/fn-date/functions.c:135
msgid "UNIX2DATE:date value corresponding to the Unix timestamp @{t}"
msgstr "UNIX2DATE: @{t} Unix уақыт белгісіне сәйкес келетін күн мәні"

#: ../plugins/fn-date/functions.c:136
msgid "t:Unix time stamp"
msgstr "t: Unix уақыт белгісі"

#: ../plugins/fn-date/functions.c:137
msgid "The UNIX2DATE function translates Unix timestamps into the corresponding date.  A Unix timestamp is the number of seconds since midnight (0:00) of January 1st, 1970 GMT."
msgstr "UNIX2DATE функциясы Unix уақыт белгілерін сәйкес күнге айналдырады. Unix уақыт белгісі — 1970 жылғы 1 қаңтардағы Гринвич бойынша түн ортасынан (0:00) бергі секундтар саны."

#: ../plugins/fn-date/functions.c:165
msgid "DATE2UNIX:the Unix timestamp corresponding to a date @{d}"
msgstr "DATE2UNIX: @{d} күніне сәйкес келетін Unix уақыт белгісі"

#: ../plugins/fn-date/functions.c:166
msgid "d:date"
msgstr "d: күн"

#: ../plugins/fn-date/functions.c:167
msgid "The DATE2UNIX function translates a date into a Unix timestamp. A Unix timestamp is the number of seconds since midnight (0:00) of January 1st, 1970 GMT."
msgstr "DATE2UNIX функциясы күнді Unix уақыт белгісіне айналдырады. Unix уақыт белгісі — 1970 жылғы 1 қаңтардағы Гринвич бойынша түн ортасынан (0:00) бергі секундтар саны."

#: ../plugins/fn-date/functions.c:191
msgid "DATEVALUE:the date part of a date and time serial value"
msgstr "DATEVALUE: күн мен уақыттың сериялық мәнінің күн бөлігі"

#: ../plugins/fn-date/functions.c:192 ../plugins/fn-date/functions.c:490
msgid "serial:date and time serial value"
msgstr "serial: күн мен уақыттың сериялық мәні"

#: ../plugins/fn-date/functions.c:193
msgid "DATEVALUE returns the date serial value part of a date and time serial value."
msgstr "DATEVALUE функциясы күн мен уақыттың сериялық мәнінің сериялық күн мәні бөлігін қайтарады."

#: ../plugins/fn-date/functions.c:209
msgid "DATEDIF:difference between dates"
msgstr "DATEDIF: күндер арасындағы айырмашылық"

#: ../plugins/fn-date/functions.c:210 ../plugins/fn-date/functions.c:720 ../plugins/fn-date/functions.c:1038 ../plugins/fn-date/functions.c:1350 ../plugins/fn-date/functions.c:1380
msgid "start_date:starting date serial value"
msgstr "start_date: бастапқы күннің сериялық мәні"

#: ../plugins/fn-date/functions.c:211 ../plugins/fn-date/functions.c:721 ../plugins/fn-date/functions.c:1039 ../plugins/fn-date/functions.c:1351 ../plugins/fn-date/functions.c:1379
msgid "end_date:ending date serial value"
msgstr "end_date: соңғы күннің сериялық мәні"

#: ../plugins/fn-date/functions.c:212
msgid "interval:counting unit"
msgstr "interval: есептеу бірлігі"

#: ../plugins/fn-date/functions.c:213
msgid "DATEDIF returns the distance from @{start_date} to @{end_date} according to the unit specified by @{interval}.  This function exists primarly for compatibility reasons and the semantics is somewhat peculiar.  In particular, the concept of \"whole month\" is based on whether the ending day is larger than or equal to the beginning day and not on whether a whole calendar month in contained in the interval.  A similar treatment is given to \"whole year\"."
msgstr "DATEDIF функциясы @{start_date} күнінен @{end_date} күніне дейінгі қашықтықты @{interval} арқылы көрсетілген бірлік бойынша қайтарады. Бұл функция негізінен үйлесімділік үшін бар және оның семантикасы біршама ерекше. Атап айтқанда, «толық ай» концепциясы интервалда толық күнтізбелік айдың бар-жоғына емес, соңғы күннің бастапқы күннен үлкен немесе тең болуына негізделген. «Толық жыл» үшін де ұқсас есептеу қолданылады."

#: ../plugins/fn-date/functions.c:214
msgid "If @{interval} is \"y\", \"m\", or \"d\" then the distance is measured in whole years, months, or days respectively."
msgstr "Егер @{interval} мәні «y», «m» немесе «d» болса, онда қашықтық сәйкесінше толық жылдармен, айлармен немесе күндермен өлшенеді."

#: ../plugins/fn-date/functions.c:215
msgid "If @{interval} is \"ym\" or \"yd\" then the distance is measured in whole months or days, respectively, but excluding any difference covered by whole years."
msgstr "Егер @{interval} мәні «ym» немесе «yd» болса, онда қашықтық сәйкесінше толық айлармен немесе күндермен өлшенеді, бірақ толық жылдармен қамтылған кез келген айырмашылық алынып тасталады."

#: ../plugins/fn-date/functions.c:216
msgid "If @{interval} is \"md\" then the distance is measured in days but excluding any difference covered by whole months."
msgstr "Егер @{interval} мәні «md» болса, онда қашықтық күндермен өлшенеді, бірақ толық айлармен қамтылған кез келген айырмашылық алынып тасталады."

#: ../plugins/fn-date/functions.c:348
msgid "EDATE:adjust a date by a number of months"
msgstr "EDATE: күнді айлар санына реттеу"

#: ../plugins/fn-date/functions.c:349 ../plugins/fn-date/functions.c:578 ../plugins/fn-date/functions.c:602 ../plugins/fn-date/functions.c:626 ../plugins/fn-date/functions.c:650 ../plugins/fn-date/functions.c:762 ../plugins/fn-date/functions.c:802 ../plugins/fn-date/functions.c:1251 ../plugins/fn-date/functions.c:1275 ../plugins/fn-date/functions.c:1311
msgid "date:date serial value"
msgstr "date: күннің сериялық мәні"

#: ../plugins/fn-date/functions.c:350 ../plugins/fn-date/functions.c:763
msgid "months:signed number of months"
msgstr "months: айлардың таңбалы саны"

#: ../plugins/fn-date/functions.c:351
msgid "EDATE returns @{date} moved forward or backward the number of months specified by @{months}."
msgstr "EDATE функциясы @{months} арқылы көрсетілген айлар санына алға немесе артқа жылжытылған @{date} күнін қайтарады."

#: ../plugins/fn-date/functions.c:385
msgid "TODAY:the date serial value of today"
msgstr "TODAY: бүгінгі күннің сериялық мәні"

#: ../plugins/fn-date/functions.c:386
msgid "The TODAY function returns the date serial value of the day it is computed.  Recomputing on a later date will produce a different value."
msgstr "TODAY функциясы ол есептелген күннің сериялық мәнін қайтарады. Кейінірек қайта есептеу басқа мәнді береді."

#: ../plugins/fn-date/functions.c:402
msgid "NOW:the date and time serial value of the current time"
msgstr "NOW: ағымдағы уақыттың күн мен уақыт сериялық мәні"

#: ../plugins/fn-date/functions.c:403
msgid "The NOW function returns the date and time serial value of the moment it is computed.  Recomputing later will produce a different value."
msgstr "NOW функциясы ол есептелген сәттің күн мен уақыт сериялық мәнін қайтарады. Кейінірек қайта есептеу басқа мәнді береді."

#: ../plugins/fn-date/functions.c:422
msgid "TIME:create a time serial value"
msgstr "TIME: сериялық уақыт мәнін жасау"

#: ../plugins/fn-date/functions.c:423
msgid "hour:hour of the day"
msgstr "hour: тәулік сағаты"

#: ../plugins/fn-date/functions.c:424
msgid "minute:minute within the hour"
msgstr "minute: сағат ішіндегі минут"

#: ../plugins/fn-date/functions.c:425
msgid "second:second within the minute"
msgstr "second: минут ішіндегі секунд"

#: ../plugins/fn-date/functions.c:426
msgid "The TIME function computes the fractional day after midnight at the time given by @{hour}, @{minute}, and @{second}."
msgstr "TIME функциясы @{hour}, @{minute} және @{second} арқылы берілген уақыттағы түн ортасынан кейінгі бөлшек күнді есептейді."

#: ../plugins/fn-date/functions.c:427
msgid "While the return value is automatically formatted to look like a time between 0:00 and 24:00, the underlying serial time value is a number between 0 and 1."
msgstr "Қайтарылатын мән автоматты түрде 0:00 мен 24:00 арасындағы уақыт ретінде пішімделгенімен, негізгі сериялық уақыт мәні 0 мен 1 арасындағы сан болып табылады."

#: ../plugins/fn-date/functions.c:429
msgid "If any of @{hour}, @{minute}, and @{second} is negative, #NUM! is returned"
msgstr "Егер @{hour}, @{minute} немесе @{second} мәндерінің кез келгені теріс болса, #NUM! қайтарылады"

#: ../plugins/fn-date/functions.c:459
msgid "ODF.TIME:create a time serial value"
msgstr "ODF.TIME: сериялық уақыт мәнін жасау"

#: ../plugins/fn-date/functions.c:460
msgid "hour:hour"
msgstr "hour: сағат"

#: ../plugins/fn-date/functions.c:461
msgid "minute:minute"
msgstr "minute: минут"

#: ../plugins/fn-date/functions.c:462
msgid "second:second"
msgstr "second: секунд"

#: ../plugins/fn-date/functions.c:463
msgid "The ODF.TIME function computes the time given by @{hour}, @{minute}, and @{second} as a fraction of a day."
msgstr "ODF.TIME функциясы @{hour}, @{minute} және @{second} арқылы берілген уақытты күннің бөлшегі ретінде есептейді."

#: ../plugins/fn-date/functions.c:464
msgid "While the return value is automatically formatted to look like a time between 0:00 and 24:00, the underlying serial time value can be any number."
msgstr "Қайтарылатын мән автоматты түрде 0:00 мен 24:00 арасындағы уақыт ретінде пішімделгенімен, негізгі сериялық уақыт мәні кез келген сан болуы мүмкін."

#: ../plugins/fn-date/functions.c:468 ../plugins/fn-date/functions.c:811 ../plugins/fn-date/functions.c:1047 ../plugins/fn-date/functions.c:1382 ../plugins/fn-eng/functions.c:212 ../plugins/fn-eng/functions.c:316 ../plugins/fn-eng/functions.c:385 ../plugins/fn-eng/functions.c:832 ../plugins/fn-financial/functions.c:1314 ../plugins/fn-math/functions.c:570 ../plugins/fn-math/functions.c:1175 ../plugins/fn-math/functions.c:1202 ../plugins/fn-math/functions.c:1669
#: ../plugins/fn-math/functions.c:1689 ../plugins/fn-math/functions.c:2522 ../plugins/fn-math/functions.c:3186 ../plugins/fn-math/functions.c:3386 ../plugins/fn-stat/functions.c:1733 ../plugins/fn-stat/functions.c:2652 ../plugins/fn-stat/functions.c:5011 ../plugins/fn-string/functions.c:323 ../plugins/fn-string/functions.c:407 ../plugins/fn-string/functions.c:534 ../plugins/fn-string/functions.c:1222 ../plugins/fn-string/functions.c:1538
#: ../plugins/fn-string/functions.c:1668
msgid "This function is OpenFormula compatible."
msgstr "Бұл функция OpenFormula стандартымен үйлесімді."

#: ../plugins/fn-date/functions.c:489
msgid "TIMEVALUE:the time part of a date and time serial value"
msgstr "TIMEVALUE: күн мен уақыттың сериялық мәнінің уақыт бөлігі"

#: ../plugins/fn-date/functions.c:491
msgid "TIMEVALUE returns the time-of-day part of a date and time serial value."
msgstr "TIMEVALUE функциясы күн мен уақыттың сериялық мәнінің тәулік уақыты бөлігін қайтарады."

#: ../plugins/fn-date/functions.c:508
msgid "HOUR:compute hour part of fractional day"
msgstr "HOUR: бөлшек күннің сағат бөлігін есептеу"

#: ../plugins/fn-date/functions.c:509 ../plugins/fn-date/functions.c:532 ../plugins/fn-date/functions.c:555
msgid "time:time of day as fractional day"
msgstr "time: тәулік уақыты бөлшек күн ретінде"

#: ../plugins/fn-date/functions.c:510
msgid "The HOUR function computes the hour part of the fractional day given by @{time}."
msgstr "HOUR функциясы @{time} арқылы берілген бөлшек күннің сағат бөлігін есептейді."

#: ../plugins/fn-date/functions.c:531
msgid "MINUTE:compute minute part of fractional day"
msgstr "MINUTE: бөлшек күннің минут бөлігін есептеу"

#: ../plugins/fn-date/functions.c:533
msgid "The MINUTE function computes the minute part of the fractional day given by @{time}."
msgstr "MINUTE функциясы @{time} арқылы берілген бөлшек күннің минут бөлігін есептейді."

#: ../plugins/fn-date/functions.c:554
msgid "SECOND:compute seconds part of fractional day"
msgstr "SECOND: бөлшек күннің секунд бөлігін есептеу"

#: ../plugins/fn-date/functions.c:556
msgid "The SECOND function computes the seconds part of the fractional day given by @{time}."
msgstr "SECOND функциясы @{time} арқылы берілген бөлшек күннің секунд бөлігін есептейді."

#: ../plugins/fn-date/functions.c:577
msgid "YEAR:the year part of a date serial value"
msgstr "YEAR: сериялық күн мәнінің жыл бөлігі"

#: ../plugins/fn-date/functions.c:579
msgid "The YEAR function returns the year part of @{date}."
msgstr "YEAR функциясы @{date} күнінің жыл бөлігін қайтарады."

#: ../plugins/fn-date/functions.c:601
msgid "MONTH:the month part of a date serial value"
msgstr "MONTH: сериялық күн мәнінің ай бөлігі"

#: ../plugins/fn-date/functions.c:603
msgid "The MONTH function returns the month part of @{date}."
msgstr "MONTH функциясы @{date} күнінің ай бөлігін қайтарады."

#: ../plugins/fn-date/functions.c:625
msgid "DAY:the day-of-month part of a date serial value"
msgstr "DAY: сериялық күн мәнінің ай күні бөлігі"

#: ../plugins/fn-date/functions.c:627
msgid "The DAY function returns the day-of-month part of @{date}."
msgstr "DAY функциясы @{date} күнінің ай күні бөлігін қайтарады."

#: ../plugins/fn-date/functions.c:649
msgid "WEEKDAY:day-of-week"
msgstr "WEEKDAY: апта күні"

#: ../plugins/fn-date/functions.c:651 ../plugins/fn-date/functions.c:1312
msgid "method:numbering system, defaults to 1"
msgstr "method: нөмірлеу жүйесі, бастапқы мәні — 1"

#: ../plugins/fn-date/functions.c:652
msgid "The WEEKDAY function returns the day-of-week of @{date}.  The value of @{method} determines how days are numbered; it defaults to 1."
msgstr "WEEKDAY функциясы @{date} күнінің апта күнін қайтарады. @{method} мәні күндердің қалай нөмірленетінін анықтайды; бастапқы мәні — 1."

#: ../plugins/fn-date/functions.c:653
msgid "If @{method} is 1, then Sunday is 1, Monday is 2, etc."
msgstr "Егер @{method} 1 болса, онда жексенбі — 1, дүйсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:654
msgid "If @{method} is 2, then Monday is 1, Tuesday is 2, etc."
msgstr "Егер @{method} 2 болса, онда дүйсенбі — 1, сейсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:655
msgid "If @{method} is 3, then Monday is 0, Tuesday is 1, etc."
msgstr "Егер @{method} 3 болса, онда дүйсенбі — 0, сейсенбі — 1 және т.с.с."

#: ../plugins/fn-date/functions.c:656
msgid "If @{method} is 11, then Monday is 1, Tuesday is 2, etc."
msgstr "Егер @{method} 11 болса, онда дүйсенбі — 1, сейсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:657
msgid "If @{method} is 12, then Tuesday is 1, Wednesday is 2, etc."
msgstr "Егер @{method} 12 болса, онда сейсенбі — 1, сәрсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:658
msgid "If @{method} is 13, then Wednesday is 1, Thursday is 2, etc."
msgstr "Егер @{method} 13 болса, онда сәрсенбі — 1, бейсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:659
msgid "If @{method} is 14, then Thursday is 1, Friday is 2, etc."
msgstr "Егер @{method} 14 болса, онда бейсенбі — 1, жұма — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:660
msgid "If @{method} is 15, then Friday is 1, Saturday is 2, etc."
msgstr "Егер @{method} 15 болса, онда жұма — 1, сенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:661
msgid "If @{method} is 16, then Saturday is 1, Sunday is 2, etc."
msgstr "Егер @{method} 16 болса, онда сенбі — 1, жексенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:662
msgid "If @{method} is 17, then Sunday is 1, Monday is 2, etc."
msgstr "Егер @{method} 17 болса, онда жексенбі — 1, дүйсенбі — 2 және т.с.с."

#: ../plugins/fn-date/functions.c:719
msgid "DAYS360:days between dates"
msgstr "DAYS360: күндер арасындағы күндер саны"

#: ../plugins/fn-date/functions.c:722
msgid "method:counting method"
msgstr "method: есептеу әдісі"

#: ../plugins/fn-date/functions.c:723
msgid "DAYS360 returns the number of days from @{start_date} to @{end_date}."
msgstr "DAYS360 функциясы @{start_date} күнінен @{end_date} күніне дейінгі күндер санын қайтарады."

#: ../plugins/fn-date/functions.c:724
msgid "If @{method} is 0, the default, the MS Excel (tm) US method will be used. This is a somewhat complicated industry standard method where the last day of February is considered to be the 30th day of the month, but only for @{start_date}."
msgstr "Егер @{method} 0 (бастапқы мән) болса, MS Excel (tm) US әдісі қолданылады. Бұл — ақпанның соңғы күні айдың 30-күні болып есептелетін күрделі салалық стандартты әдіс, бірақ тек @{start_date} үшін."

#: ../plugins/fn-date/functions.c:725
msgid "If @{method} is 1, the European method will be used.  In this case, if the day of the month is 31 it will be considered as 30"
msgstr "Егер @{method} 1 болса, еуропалық әдіс қолданылады. Бұл жағдайда, егер айдың күні 31 болса, ол 30 болып есептеледі"

#: ../plugins/fn-date/functions.c:726
msgid "If @{method} is 2, a saner version of the US method is used in which both dates get the same February treatment."
msgstr "Егер @{method} 2 болса, US әдісінің анағұрлым дұрыс нұсқасы қолданылады, мұнда екі күнге де бірдей ақпан айының ережесі қолданылады."

#: ../plugins/fn-date/functions.c:761
msgid "EOMONTH:end of month"
msgstr "EOMONTH:айдың соңы"

#: ../plugins/fn-date/functions.c:764
msgid "EOMONTH returns the date serial value of the end of the month specified by @{date} adjusted forward or backward the number of months specified by @{months}."
msgstr "EOMONTH функциясы @{months} арқылы көрсетілген айлар санына алға немесе артқа жылжытылған @{date} айының соңғы күнінің сериялық мәнін қайтарады."

#: ../plugins/fn-date/functions.c:801
msgid "WORKDAY:add working days"
msgstr "WORKDAY: жұмыс күндерін қосу"

#: ../plugins/fn-date/functions.c:803
msgid "days:number of days to add"
msgstr "days: қосылатын күндер саны"

#: ../plugins/fn-date/functions.c:804 ../plugins/fn-date/functions.c:1040
msgid "holidays:array of holidays"
msgstr "holidays: мерекелер массиві"

#: ../plugins/fn-date/functions.c:805 ../plugins/fn-date/functions.c:1041
msgid "weekend:array of 0s and 1s, indicating whether a weekday (S, M, T, W, T, F, S) is on the weekend, defaults to {1,0,0,0,0,0,1}"
msgstr "weekend: апта күнінің (Ж, Д, С, С, Б, Ж, С) демалыс күні екенін көрсететін 0 мен 1-ден тұратын массив, бастапқы мәні — {1,0,0,0,0,0,1}"

#: ../plugins/fn-date/functions.c:807
msgid "WORKDAY adjusts @{date} by @{days} skipping over weekends and @{holidays} in the process."
msgstr "WORKDAY функциясы демалыс күндері мен @{holidays} мерекелерін өткізіп жібере отырып, @{date} күнін @{days} санына реттейді."

#: ../plugins/fn-date/functions.c:808
msgid "@{days} may be negative."
msgstr "@{days} теріс болуы мүмкін."

#: ../plugins/fn-date/functions.c:809 ../plugins/fn-date/functions.c:1045
msgid "If an entry of @{weekend} is non-zero, the corresponding weekday is not a work day."
msgstr "Егер @{weekend} элементі нөлге тең болмаса, сәйкес апта күні жұмыс күні болып есептелмейді."

#: ../plugins/fn-date/functions.c:810 ../plugins/fn-date/functions.c:1046
msgid "This function is Excel compatible if the last argument is omitted."
msgstr "Соңғы аргумент көрсетілмесе, бұл функция Excel бағдарламасымен үйлесімді."

#: ../plugins/fn-date/functions.c:1037
msgid "NETWORKDAYS:number of workdays in range"
msgstr "NETWORKDAYS: ауқымдағы жұмыс күндерінің саны"

#: ../plugins/fn-date/functions.c:1043
msgid "NETWORKDAYS calculates the number of days from @{start_date} to @{end_date} skipping weekends and @{holidays} in the process."
msgstr "NETWORKDAYS функциясы демалыс күндері мен @{holidays} мерекелерін өткізіп жібере отырып, @{start_date} күнінен @{end_date} күніне дейінгі күндер санын есептейді."

#: ../plugins/fn-date/functions.c:1250
msgid "ISOWEEKNUM:ISO week number"
msgstr "ISOWEEKNUM: ISO апта нөмірі"

#: ../plugins/fn-date/functions.c:1252
msgid "ISOWEEKNUM calculates the week number according to the ISO 8601 standard.  Weeks start on Mondays and week 1 contains the first Thursday of the year."
msgstr "ISOWEEKNUM функциясы апта нөмірін ISO 8601 стандартына сәйкес есептейді. Апталар дүйсенбіде басталады және 1-апта жылдың алғашқы бейсенбісін қамтиды."

#: ../plugins/fn-date/functions.c:1253 ../plugins/fn-date/functions.c:1277
msgid "January 1 of a year is sometimes in week 52 or 53 of the previous year.  Similarly, December 31 is sometimes in week 1 of the following year."
msgstr "Жылдың 1 қаңтары кейде алдыңғы жылдың 52 немесе 53-аптасына келеді. Сол сияқты, 31 желтоқсан кейде келесі жылдың 1-аптасына келеді."

#: ../plugins/fn-date/functions.c:1274
msgid "ISOYEAR:year corresponding to the ISO week number"
msgstr "ISOYEAR: ISO апта нөміріне сәйкес келетін жыл"

#: ../plugins/fn-date/functions.c:1276
msgid "ISOYEAR calculates the year to go with week number according to the ISO 8601 standard."
msgstr "ISOYEAR ISO 8601 стандартына сәйкес апта нөмірімен бірге жүретін жылды есептейді."

#: ../plugins/fn-date/functions.c:1310
msgid "WEEKNUM:week number"
msgstr "WEEKNUM:апта нөмірі"

#: ../plugins/fn-date/functions.c:1313
msgid "WEEKNUM calculates the week number according to @{method} which defaults to 1."
msgstr "WEEKNUM @{method} бойынша апта нөмірін есептейді, ол бастапқыда 1-ге тең."

#: ../plugins/fn-date/functions.c:1314
msgid "If @{method} is 1, then weeks start on Sundays and January 1 is in week 1."
msgstr "Егер @{method} 1 болса, онда апта жексенбіден басталады және 1 қаңтар 1-аптада болады."

#: ../plugins/fn-date/functions.c:1315
msgid "If @{method} is 2, then weeks start on Mondays and January 1 is in week 1."
msgstr "Егер @{method} 2 болса, онда апта дүйсенбіден басталады және 1 қаңтар 1-аптада болады."

#: ../plugins/fn-date/functions.c:1316
msgid "If @{method} is 150, then the ISO 8601 numbering is used."
msgstr "Егер @{method} 150 болса, онда ISO 8601 нөмірлеуі қолданылады."

#: ../plugins/fn-date/functions.c:1349
msgid "YEARFRAC:fractional number of years between dates"
msgstr "YEARFRAC: күндер арасындағы жылдардың бөлшек саны"

#: ../plugins/fn-date/functions.c:1352 ../plugins/fn-financial/functions.c:453 ../plugins/fn-financial/functions.c:492 ../plugins/fn-financial/functions.c:530 ../plugins/fn-financial/functions.c:571 ../plugins/fn-financial/functions.c:608 ../plugins/fn-financial/functions.c:652 ../plugins/fn-financial/functions.c:1898 ../plugins/fn-financial/functions.c:2264 ../plugins/fn-financial/functions.c:2314 ../plugins/fn-financial/functions.c:2421
#: ../plugins/fn-financial/functions.c:2467 ../plugins/fn-financial/functions.c:2509 ../plugins/fn-financial/functions.c:2660 ../plugins/fn-financial/functions.c:2755 ../plugins/fn-financial/functions.c:2833 ../plugins/fn-financial/functions.c:2910 ../plugins/fn-financial/functions.c:2966 ../plugins/fn-financial/functions.c:3009 ../plugins/fn-financial/functions.c:3033 ../plugins/fn-financial/functions.c:3057 ../plugins/fn-financial/functions.c:3081
#: ../plugins/fn-financial/functions.c:3107 ../plugins/fn-financial/functions.c:3133 ../plugins/fn-financial/functions.c:3247
msgid "basis:calendar basis"
msgstr "basis: күнтізбе негізі"

#: ../plugins/fn-date/functions.c:1353
msgid "YEARFRAC calculates the number of days from @{start_date} to @{end_date} according to the calendar specified by @{basis}, which defaults to 0, and expresses the result as a fractional number of years."
msgstr "YEARFRAC @{basis} арқылы көрсетілген күнтізбе бойынша (бастапқы мәні 0) @{start_date} күнінен @{end_date} күніне дейінгі күндер санын есептейді және нәтижені жылдардың бөлшек саны ретінде өрнектейді."

#: ../plugins/fn-date/functions.c:1378
msgid "DAYS:difference between dates in days"
msgstr "DAYS: күндер арасындағы айырмашылық күнмен"

#: ../plugins/fn-date/functions.c:1381
msgid "DAYS returns the positive or negative number of days from @{start_date} to @{end_date}."
msgstr "DAYS @{start_date} күнінен @{end_date} күніне дейінгі оң немесе теріс күндер санын қайтарады."

#. Some common decriptors
#: ../plugins/fn-derivatives/options.c:44
msgid "call_put_flag:'c' for a call and 'p' for a put"
msgstr "call_put_flag: сатып алу опционы (call) үшін «c» және сату опционы (put) үшін «p»"

#: ../plugins/fn-derivatives/options.c:45
msgid "spot:spot price"
msgstr "spot: спот бағасы"

#: ../plugins/fn-derivatives/options.c:46
msgid "strike:strike price"
msgstr "strike: страйк бағасы"

#: ../plugins/fn-derivatives/options.c:47
msgid "time:time to maturity in years"
msgstr "time: өтеуге дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:48
msgid "time:time to maturity in days"
msgstr "time: өтеуге дейінгі уақыт күнмен"

#: ../plugins/fn-derivatives/options.c:49
msgid "time_payout:time to dividend payout"
msgstr "time_payout: дивиденд төлеуге дейінгі уақыт"

#: ../plugins/fn-derivatives/options.c:50
msgid "time_exp:time to expiration"
msgstr "time_exp: мерзімі аяқталғанға дейінгі уақыт"

#: ../plugins/fn-derivatives/options.c:51
msgid "rate:risk-free interest rate to the exercise date in percent"
msgstr "rate: орындалу күніне дейінгі тәуекелсіз пайыздық мөлшерлеме пайызбен"

#: ../plugins/fn-derivatives/options.c:52
msgid "rate:annualized interest rate"
msgstr "rate: жылдық пайыздық мөлшерлеме"

#: ../plugins/fn-derivatives/options.c:53
msgid "rate:annualized risk-free interest rate"
msgstr "rate: жылдық тәуекелсіз пайыздық мөлшерлеме"

#: ../plugins/fn-derivatives/options.c:54
msgid "volatility:annualized volatility of the asset in percent for the period through to the exercise date"
msgstr "volatility: орындалу күніне дейінгі кезең үшін активтің жылдық құбылмалылығы пайызбен"

#: ../plugins/fn-derivatives/options.c:55
msgid "volatility:annualized volatility of the asset"
msgstr "volatility: активтің жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:56
msgid "d:amount of the dividend to be paid expressed in currency"
msgstr "d: валютамен өрнектелген төленетін дивиденд сомасы"

#: ../plugins/fn-derivatives/options.c:57
msgid "cost_of_carry:net cost of holding the underlying asset (for common stocks, the risk free rate less the dividend yield), defaults to 0"
msgstr "cost_of_carry: негізгі активті иеленудің таза құны (жай акциялар үшін дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме), бастапқыда 0"

#: ../plugins/fn-derivatives/options.c:58
msgid "cost_of_carry:net cost of holding the underlying asset"
msgstr "cost_of_carry: негізгі активті иеленудің таза құны"

#: ../plugins/fn-derivatives/options.c:60
msgid "The returned value will be expressed in the same units as @{strike} and @{spot}."
msgstr "Қайтарылатын мән @{strike} және @{spot} мәндерімен бірдей бірліктермен өрнектеледі."

#: ../plugins/fn-derivatives/options.c:190
msgid "CUM_BIV_NORM_DIST:cumulative bivariate normal distribution"
msgstr "CUM_BIV_NORM_DIST: кумулятивті бивариатты қалыпты үлестірім"

#: ../plugins/fn-derivatives/options.c:191
msgid "a:limit for first random variable"
msgstr "a: бірінші кездейсоқ айнымалы үшін шек"

#: ../plugins/fn-derivatives/options.c:192
msgid "b:limit for second random variable"
msgstr "b: екінші кездейсоқ айнымалы үшін шек"

#: ../plugins/fn-derivatives/options.c:193
msgid "rho:correlation of the two random variables"
msgstr "rho: екі кездейсоқ айнымалының корреляциясы"

#: ../plugins/fn-derivatives/options.c:194
msgid "CUM_BIV_NORM_DIST calculates the probability that two standard normal distributed random variables with correlation @{rho} are respectively each less than @{a} and @{b}."
msgstr "CUM_BIV_NORM_DIST корреляциясы @{rho} болатын екі стандартты қалыпты үлестірілген кездейсоқ айнымалының әрқайсысының сәйкесінше @{a} және @{b} мәндерінен кіші болу ықтималдығын есептейді."

#: ../plugins/fn-derivatives/options.c:243
msgid "OPT_BS:price of a European option"
msgstr "OPT_BS: еуропалық опционның бағасы"

#: ../plugins/fn-derivatives/options.c:251
msgid "OPT_BS uses the Black-Scholes model to calculate the price of a European option struck at @{strike} on an asset with spot price @{spot}."
msgstr "OPT_BS спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның бағасын есептеу үшін Блэк-Шоулз моделін қолданады."

#: ../plugins/fn-derivatives/options.c:300
msgid "OPT_BS_DELTA:delta of a European option"
msgstr "OPT_BS_DELTA: еуропалық опционның дельтасы"

#: ../plugins/fn-derivatives/options.c:308
msgid "OPT_BS_DELTA uses the Black-Scholes model to calculate the 'delta' of a European option struck at @{strike} on an asset with spot price @{spot}."
msgstr "OPT_BS_DELTA спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «дельтасын» есептеу үшін Блэк-Шоулз моделін қолданады."

#: ../plugins/fn-derivatives/options.c:342
msgid "OPT_BS_GAMMA:gamma of a European option"
msgstr "OPT_BS_GAMMA: еуропалық опционның гаммасы"

#: ../plugins/fn-derivatives/options.c:349
msgid "OPT_BS_GAMMA uses the Black-Scholes model to calculate the 'gamma' of a European option struck at @{strike} on an asset with spot price @{spot}. The gamma of an option is the second derivative of its price with respect to the price of the underlying asset."
msgstr "OPT_BS_GAMMA спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «гаммасын» есептеу үшін Блэк-Шоулз моделін қолданады. Опционның гаммасы — оның бағасының негізгі актив бағасына қатысты екінші туындысы."

#: ../plugins/fn-derivatives/options.c:354
msgid "Gamma is expressed as the rate of change of delta per unit change in @{spot}."
msgstr "Гамма @{spot} мәнінің бірлік өзгеруіне шаққандағы дельтаның өзгеру жылдамдығы ретінде өрнектеледі."

#: ../plugins/fn-derivatives/options.c:356
msgid "Gamma is the same for calls and puts."
msgstr "Гамма сатып алу (call) және сату (put) опциондары үшін бірдей."

#: ../plugins/fn-derivatives/options.c:399
msgid "OPT_BS_THETA:theta of a European option"
msgstr "OPT_BS_THETA: еуропалық опционның тетасы"

#: ../plugins/fn-derivatives/options.c:407
msgid "OPT_BS_THETA uses the Black-Scholes model to calculate the 'theta' of a European option struck at @{strike} on an asset with spot price @{spot}. The theta of an option is the rate of change of its price with respect to time to expiry."
msgstr "OPT_BS_THETA спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «тетасын» есептеу үшін Блэк-Шоулз моделін қолданады. Опционның тетасы — оның бағасының мерзімі аяқталғанға дейінгі уақытқа қатысты өзгеру жылдамдығы."

#: ../plugins/fn-derivatives/options.c:412
msgid "Theta is expressed as the negative of the rate of change of the option value, per 365.25 days."
msgstr "Тета 365,25 күнге шаққандағы опцион құнының өзгеру жылдамдығының теріс мәні ретінде өрнектеледі."

#: ../plugins/fn-derivatives/options.c:443
msgid "OPT_BS_VEGA:vega of a European option"
msgstr "OPT_BS_VEGA: еуропалық опционның вегасы"

#: ../plugins/fn-derivatives/options.c:450
msgid "OPT_BS_VEGA uses the Black-Scholes model to calculate the 'vega' of a European option struck at @{strike} on an asset with spot price @{spot}. The vega of an option is the rate of change of its price with respect to volatility."
msgstr "OPT_BS_VEGA спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «вегасын» есептеу үшін Блэк-Шоулз моделін қолданады. Опционның вегасы — оның бағасының құбылмалылыққа қатысты өзгеру жылдамдығы."

#: ../plugins/fn-derivatives/options.c:455
msgid "Vega is the same for calls and puts."
msgstr "Вега сатып алу (call) және сату (put) опциондары үшін бірдей."

#: ../plugins/fn-derivatives/options.c:457
#, no-c-format
msgid "Vega is expressed as the rate of change of option value, per 100% volatility."
msgstr "Вега 100% құбылмалылыққа шаққандағы опцион құнының өзгеру жылдамдығы ретінде өрнектеледі."

#: ../plugins/fn-derivatives/options.c:508
msgid "OPT_BS_RHO:rho of a European option"
msgstr "OPT_BS_RHO: еуропалық опционның росы"

#: ../plugins/fn-derivatives/options.c:516
msgid "OPT_BS_RHO uses the Black-Scholes model to calculate the 'rho' of a European option struck at @{strike} on an asset with spot price @{spot}. The rho of an option is the rate of change of its price with respect to the risk free interest rate."
msgstr "OPT_BS_RHO спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «росын» есептеу үшін Блэк-Шоулз моделін қолданады. Опционның росы — оның бағасының тәуекелсіз пайыздық мөлшерлемеге қатысты өзгеру жылдамдығы."

#: ../plugins/fn-derivatives/options.c:522
#, no-c-format
msgid "Rho is expressed as the rate of change of the option value, per 100% change in @{rate}."
msgstr "Ро @{rate} мәнінің 100% өзгеруіне шаққандағы опцион құнының өзгеру жылдамдығы ретінде өрнектеледі."

#: ../plugins/fn-derivatives/options.c:564
msgid "OPT_BS_CARRYCOST:elasticity of a European option"
msgstr "OPT_BS_CARRYCOST: еуропалық опционның икемділігі"

#: ../plugins/fn-derivatives/options.c:572
msgid "OPT_BS_CARRYCOST uses the Black-Scholes model to calculate the 'elasticity' of a European option struck at @{strike} on an asset with spot price @{spot}. The elasticity of an option is the rate of change of its price with respect to its @{cost_of_carry}."
msgstr "OPT_BS_CARRYCOST спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық опционның «икемділігін» есептеу үшін Блэк-Шоулз моделін қолданады. Опционның икемділігі — оның бағасының @{cost_of_carry} мәніне қатысты өзгеру жылдамдығы."

#: ../plugins/fn-derivatives/options.c:578
#, no-c-format
msgid "Elasticity is expressed as the rate of change of the option value, per 100% volatility."
msgstr "Икемділік 100% құбылмалылыққа шаққандағы опцион құнының өзгеру жылдамдығы ретінде өрнектеледі."

#: ../plugins/fn-derivatives/options.c:622
msgid "OPT_GARMAN_KOHLHAGEN:theoretical price of a European currency option"
msgstr "OPT_GARMAN_KOHLHAGEN: еуропалық валюталық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:626
msgid "time:number of days to exercise"
msgstr "time: орындалғанға дейінгі күндер саны"

#: ../plugins/fn-derivatives/options.c:627
msgid "domestic_rate:domestic risk-free interest rate to the exercise date in percent"
msgstr "domestic_rate: орындалу күніне дейінгі ішкі тәуекелсіз пайыздық мөлшерлеме пайызбен"

#: ../plugins/fn-derivatives/options.c:628
msgid "foreign_rate:foreign risk-free interest rate to the exercise date in percent"
msgstr "foreign_rate: орындалу күніне дейінгі сыртқы тәуекелсіз пайыздық мөлшерлеме пайызбен"

#: ../plugins/fn-derivatives/options.c:630
msgid "OPT_GARMAN_KOHLHAGEN values the theoretical price of a European currency option struck at @{strike} on an asset with spot price @{spot}."
msgstr "OPT_GARMAN_KOHLHAGEN спот бағасы @{spot} актив бойынша @{strike} страйкі бар еуропалық валюталық опционның теориялық бағасын бағалайды."

#: ../plugins/fn-derivatives/options.c:676
msgid "OPT_FRENCH:theoretical price of a European option adjusted for trading day volatility"
msgstr "OPT_FRENCH: сауда күнінің құбылмалылығына түзетілген еуропалық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:680
msgid "time:ratio of the number of calendar days to exercise and the number of calendar days in the year"
msgstr "time: орындалғанға дейінгі күнтізбелік күндер санының жылдағы күнтізбелік күндер санына қатынасы"

#: ../plugins/fn-derivatives/options.c:681
msgid "ttime:ratio of the number of trading days to exercise and the number of trading days in the year"
msgstr "ttime: орындалғанға дейінгі сауда күндері санының жылдағы сауда күндері санына қатынасы"

#: ../plugins/fn-derivatives/options.c:685
msgid "OPT_FRENCH values the theoretical price of a European option adjusted for trading day volatility, struck at @{strike} on an asset with spot price @{spot}."
msgstr "OPT_FRENCH спот бағасы @{spot} актив бойынша @{strike} страйкі бар, сауда күнінің құбылмалылығына түзетілген еуропалық опционның теориялық бағасын бағалайды."

#: ../plugins/fn-derivatives/options.c:729
msgid "OPT_JUMP_DIFF:theoretical price of an option according to the Jump Diffusion process"
msgstr "OPT_JUMP_DIFF: секіріс-диффузиялық процесс бойынша опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:734
msgid "rate:the annualized rate of interest"
msgstr "rate: жылдық пайыздық мөлшерлеме"

#: ../plugins/fn-derivatives/options.c:736
msgid "lambda:expected number of 'jumps' per year"
msgstr "lambda: жылына күтілетін «секірістер» саны"

#: ../plugins/fn-derivatives/options.c:737
msgid "gamma:proportion of volatility explained by the 'jumps'"
msgstr "gamma: «секірістермен» түсіндірілетін құбылмалылық үлесі"

#: ../plugins/fn-derivatives/options.c:738
msgid "OPT_JUMP_DIFF models the theoretical price of an option according to the Jump Diffusion process (Merton)."
msgstr "OPT_JUMP_DIFF секіріс-диффузиялық процесс (Мертон) бойынша опционның теориялық бағасын модельдейді."

#: ../plugins/fn-derivatives/options.c:816
msgid "OPT_MILTERSEN_SCHWARTZ:theoretical price of options on commodities futures according to Miltersen & Schwartz"
msgstr "OPT_MILTERSEN_SCHWARTZ: Милтерсен мен Шварц бойынша тауарлық фьючерстерге опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:818
msgid "p_t:zero coupon bond with expiry at option maturity"
msgstr "p_t: опционның өтелу мерзімінде аяқталатын нөлдік купондық облигация"

#: ../plugins/fn-derivatives/options.c:819
msgid "f_t:futures price"
msgstr "f_t: фьючерстік баға"

#: ../plugins/fn-derivatives/options.c:821
msgid "t1:time to maturity of the option"
msgstr "t1: опционның өтелуіне дейінгі уақыт"

#: ../plugins/fn-derivatives/options.c:822
msgid "t2:time to maturity of the underlying commodity futures contract"
msgstr "t2: негізгі тауарлық фьючерстік келісімшарттың өтелуіне дейінгі уақыт"

#: ../plugins/fn-derivatives/options.c:823
msgid "v_s:volatility of the spot commodity price"
msgstr "v_s: тауардың спот бағасының құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:824
msgid "v_e:volatility of the future convenience yield"
msgstr "v_e: болашақ қолайлылық кірістілігінің құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:825
msgid "v_f:volatility of the forward rate of interest"
msgstr "v_f: форвардтық пайыздық мөлшерлеменің құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:826
msgid "rho_se:correlation between the spot commodity price and the convenience yield"
msgstr "rho_se: тауардың спот бағасы мен қолайлылық кірістілігі арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:827
msgid "rho_sf:correlation between the spot commodity price and the forward interest rate"
msgstr "rho_sf: тауардың спот бағасы мен форвардтық пайыздық мөлшерлеме арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:828
msgid "rho_ef:correlation between the forward interest rate and the convenience yield"
msgstr "rho_ef: форвардтық пайыздық мөлшерлеме мен қолайлылық кірістілігі арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:829
msgid "kappa_e:speed of mean reversion of the convenience yield"
msgstr "kappa_e: қолайлылық кірістілігінің орташа мәнге қайту жылдамдығы"

#: ../plugins/fn-derivatives/options.c:830
msgid "kappa_f:speed of mean reversion of the forward interest rate"
msgstr "kappa_f: форвардтық пайыздық мөлшерлеменің орташа мәнге қайту жылдамдығы"

#: ../plugins/fn-derivatives/options.c:913
msgid "OPT_RGW:theoretical price of an American option according to the Roll-Geske-Whaley approximation"
msgstr "OPT_RGW: Ролл-Геске-Уэйли жуықтауы бойынша американдық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:956
msgid "OPT_BAW_AMER:theoretical price of an option according to the Barone Adesie & Whaley approximation"
msgstr "OPT_BAW_AMER: Бароне-Адези мен Уэйли жуықтауы бойынша опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1128
msgid "OPT_BJER_STENS:theoretical price of American options according to the Bjerksund & Stensland approximation technique"
msgstr "OPT_BJER_STENS: Бьерксунд пен Стенсланд жуықтау әдісі бойынша американдық опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1202
msgid "OPT_EXEC:theoretical price of executive stock options"
msgstr "OPT_EXEC: басшыларға арналған акциялық опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1210
msgid "lambda:jump rate for executives"
msgstr "lambda: басшылар үшін секіріс мөлшерлемесі"

#: ../plugins/fn-derivatives/options.c:1211
msgid "The model assumes executives forfeit their options if they leave the company."
msgstr "Модель басшылар компаниядан кеткен жағдайда өз опциондарынан айырылады деп болжайды."

#: ../plugins/fn-derivatives/options.c:1238
msgid "OPT_FORWARD_START:theoretical price of forward start options"
msgstr "OPT_FORWARD_START: форвардтық старт опциондарының теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1241
msgid "alpha:fraction setting the strike price at the future date @{time_start}"
msgstr "alpha: болашақ @{time_start} күніндегі страйк бағасын белгілейтін үлес"

#: ../plugins/fn-derivatives/options.c:1242
msgid "time_start:time until the option starts in days"
msgstr "time_start: опцион басталғанға дейінгі уақыт күнмен"

#: ../plugins/fn-derivatives/options.c:1290
msgid "OPT_TIME_SWITCH:theoretical price of time switch options"
msgstr "OPT_TIME_SWITCH: тайм-свитч опциондарының теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1294
msgid "a:amount received for each time period"
msgstr "a: әрбір уақыт кезеңі үшін алынған сома"

#: ../plugins/fn-derivatives/options.c:1296
msgid "m:number of time units the option has already met the condition"
msgstr "m: опцион шартқа сәйкес келген уақыт бірліктерінің саны"

#: ../plugins/fn-derivatives/options.c:1297
msgid "dt:agreed upon discrete time period expressed as a fraction of a year"
msgstr "dt: жылдың үлесі ретінде өрнектелген келісілген дискретті уақыт кезеңі"

#: ../plugins/fn-derivatives/options.c:1302
msgid "OPT_TIME_SWITCH models the theoretical price of time switch options. (Pechtl 1995). The holder receives @{a} * @{dt} for each period that the asset price was greater than @{strike} (for a call) or below it (for a put)."
msgstr "OPT_TIME_SWITCH тайм-свитч опциондарының теориялық бағасын модельдейді (Пехтл 1995). Иеленуші актив бағасы @{strike} мәнінен жоғары (call үшін) немесе төмен (put үшін) болған әрбір кезең үшін @{a} * @{dt} алады."

#: ../plugins/fn-derivatives/options.c:1332
msgid "OPT_SIMPLE_CHOOSER:theoretical price of a simple chooser option"
msgstr "OPT_SIMPLE_CHOOSER: қарапайым таңдаулы (chooser) опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1336
msgid "time1:time in years until the holder chooses a put or a call option"
msgstr "time1: иеленуші сату (put) немесе сатып алу (call) опционын таңдағанға дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1337
msgid "time2:time in years until the chosen option expires"
msgstr "time2: таңдалған опционның мерзімі аяқталғанға дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1381
msgid "OPT_COMPLEX_CHOOSER:theoretical price of a complex chooser option"
msgstr "OPT_COMPLEX_CHOOSER: күрделі таңдаулы (chooser) опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1383
msgid "strike_call:strike price, if exercised as a call option"
msgstr "strike_call: сатып алу (call) опционы ретінде орындалған жағдайдағы страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1384
msgid "strike_put:strike price, if exercised as a put option"
msgstr "strike_put: сату (put) опционы ретінде орындалған жағдайдағы страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1385
msgid "time:time in years until the holder chooses a put or a call option"
msgstr "time: иеленуші сату (put) немесе сатып алу (call) опционын таңдағанға дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1386
msgid "time_call:time in years to maturity of the call option if chosen"
msgstr "time_call: таңдалған жағдайда сатып алу (call) опционының өтелуіне дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1387
msgid "time_put:time in years  to maturity of the put option if chosen"
msgstr "time_put: таңдалған жағдайда сату (put) опционының өтелуіне дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1482
msgid "OPT_ON_OPTIONS:theoretical price of options on options"
msgstr "OPT_ON_OPTIONS: опциондарға опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1483
msgid "type_flag:'cc' for calls on calls, 'cp' for calls on puts, and so on for 'pc', and 'pp'"
msgstr "type_flag: сатып алуға сатып алу үшін «cc», сатуға сатып алу үшін «cp», және сол сияқты «pc» және «pp» үшін"

#: ../plugins/fn-derivatives/options.c:1485
msgid "strike1:strike price at which the option being valued is struck"
msgstr "strike1: бағаланатын опцион орындалатын страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1486
msgid "strike2:strike price at which the underlying option is struck"
msgstr "strike2: негізгі опцион орындалатын страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1487
msgid "time1:time in years to maturity of the option"
msgstr "time1: опционның өтелуіне дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1488
msgid "time2:time in years to the maturity of the underlying option"
msgstr "time2: негізгі опционның өтелуіне дейінгі уақыт жылмен"

#: ../plugins/fn-derivatives/options.c:1490
msgid "cost_of_carry:net cost of holding the underlying asset of the underlying option"
msgstr "cost_of_carry: негізгі опционның негізгі активін иеленудің таза құны"

#: ../plugins/fn-derivatives/options.c:1491
msgid "volatility:annualized volatility in price of the underlying asset of the underlying option"
msgstr "volatility: негізгі опционның негізгі активі бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1492
msgid "For common stocks, @{cost_of_carry} is the risk free rate less the dividend yield."
msgstr "Жай акциялар үшін @{cost_of_carry} — дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме."

#: ../plugins/fn-derivatives/options.c:1493
msgid "@{time2} ≥ @{time1}"
msgstr "@{time2} ≥ @{time1}"

#: ../plugins/fn-derivatives/options.c:1559
msgid "OPT_EXTENDIBLE_WRITER:theoretical price of extendible writer options"
msgstr "OPT_EXTENDIBLE_WRITER: ұзартылатын райтерлік опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1562
msgid "strike1:strike price at which the option is struck"
msgstr "strike1: опцион орындалатын страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1563
msgid "strike2:strike price at which the option is re-struck if out of the money at @{time1}"
msgstr "strike2: егер @{time1} кезінде ұтылыста болса, опцион қайта орындалатын страйк бағасы"

#: ../plugins/fn-derivatives/options.c:1564
msgid "time1:initial maturity of the option in years"
msgstr "time1: опционның бастапқы өтелу мерзімі жылмен"

#: ../plugins/fn-derivatives/options.c:1565
msgid "time2:extended maturity in years if chosen"
msgstr "time2: таңдалған жағдайдағы ұзартылған өтелу мерзімі жылмен"

#: ../plugins/fn-derivatives/options.c:1569
msgid "OPT_EXTENDIBLE_WRITER models the theoretical price of extendible writer options. These are options that have their maturity extended to @{time2} if the option is out of the money at @{time1}."
msgstr "OPT_EXTENDIBLE_WRITER ұзартылатын райтерлік опциондардың теориялық бағасын модельдейді. Бұл егер @{time1} кезінде опцион ұтылыста болса, өтелу мерзімі @{time2} мәніне дейін ұзартылатын опциондар."

#: ../plugins/fn-derivatives/options.c:1611
msgid "OPT_2_ASSET_CORRELATION:theoretical price of options on 2 assets with correlation @{rho}"
msgstr "OPT_2_ASSET_CORRELATION: корреляциясы @{rho} болатын 2 активке опциондардың теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1613
msgid "spot1:spot price of the underlying asset of the first option"
msgstr "spot1: бірінші опционның негізгі активінің спот бағасы"

#: ../plugins/fn-derivatives/options.c:1614
msgid "spot2:spot price of the underlying asset of the second option"
msgstr "spot2: екінші опционның негізгі активінің спот бағасы"

#: ../plugins/fn-derivatives/options.c:1615
msgid "strike1:strike prices of the first option"
msgstr "strike1: бірінші опционның страйк бағалары"

#: ../plugins/fn-derivatives/options.c:1616
msgid "strike2:strike prices of the second option"
msgstr "strike2: екінші опционның страйк бағалары"

#: ../plugins/fn-derivatives/options.c:1618
msgid "cost_of_carry1:net cost of holding the underlying asset of the first option (for common stocks, the risk free rate less the dividend yield)"
msgstr "cost_of_carry1: бірінші опционның негізгі активін иеленудің таза құны (жай акциялар үшін дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме)"

#: ../plugins/fn-derivatives/options.c:1620
msgid "cost_of_carry2:net cost of holding the underlying asset of the second option (for common stocks, the risk free rate less the dividend yield)"
msgstr "cost_of_carry2: екінші опционның негізгі активін иеленудің таза құны (жай акциялар үшін дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме)"

#: ../plugins/fn-derivatives/options.c:1623
msgid "volatility1:annualized volatility in price of the underlying asset of the first option"
msgstr "volatility1: бірінші опционның негізгі активі бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1624
msgid "volatility2:annualized volatility in price of the underlying asset of the second option"
msgstr "volatility2: екінші опционның негізгі активі бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1625
msgid "rho:correlation between the two underlying assets"
msgstr "rho: екі негізгі актив арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:1626
msgid "OPT_2_ASSET_CORRELATION models the theoretical price of options on 2 assets with correlation @{rho}. The payoff for a call is max(@{spot2} - @{strike2},0) if @{spot1} > @{strike1} or 0 otherwise. The payoff for a put is max (@{strike2} - @{spot2}, 0) if @{spot1} < @{strike1} or 0 otherwise."
msgstr "OPT_2_ASSET_CORRELATION корреляциясы @{rho} болатын 2 активке опциондардың теориялық бағасын модельдейді. Сатып алу (call) үшін төлем егер @{spot1} > @{strike1} болса max(@{spot2} - @{strike2},0), әйтпесе 0-ге тең. Сату (put) үшін төлем егер @{spot1} < @{strike1} болса max (@{strike2} - @{spot2}, 0), әйтпесе 0-ге тең."

#: ../plugins/fn-derivatives/options.c:1661
msgid "OPT_EURO_EXCHANGE:theoretical price of a European option to exchange assets"
msgstr "OPT_EURO_EXCHANGE: активтерді айырбастауға арналған еуропалық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1662 ../plugins/fn-derivatives/options.c:1706
msgid "spot1:spot price of asset 1"
msgstr "spot1: 1-активтің спот бағасы"

#: ../plugins/fn-derivatives/options.c:1663 ../plugins/fn-derivatives/options.c:1707
msgid "spot2:spot price of asset 2"
msgstr "spot2: 2-активтің спот бағасы"

#: ../plugins/fn-derivatives/options.c:1664 ../plugins/fn-derivatives/options.c:1708
msgid "qty1:quantity of asset 1"
msgstr "qty1: 1-активтің саны"

#: ../plugins/fn-derivatives/options.c:1665 ../plugins/fn-derivatives/options.c:1709
msgid "qty2:quantity of asset 2"
msgstr "qty2: 2-активтің саны"

#: ../plugins/fn-derivatives/options.c:1668 ../plugins/fn-derivatives/options.c:1712
msgid "cost_of_carry1:net cost of holding asset 1 (for common stocks, the risk free rate less the dividend yield)"
msgstr "cost_of_carry1: 1-активті иеленудің таза құны (жай акциялар үшін дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме)"

#: ../plugins/fn-derivatives/options.c:1670 ../plugins/fn-derivatives/options.c:1714
msgid "cost_of_carry2:net cost of holding asset 2 (for common stocks, the risk free rate less the dividend yield)"
msgstr "cost_of_carry2: 2-активті иеленудің таза құны (жай акциялар үшін дивидендтік кірісті шегергендегі тәуекелсіз мөлшерлеме)"

#: ../plugins/fn-derivatives/options.c:1672 ../plugins/fn-derivatives/options.c:1716
msgid "volatility1:annualized volatility in price of asset 1"
msgstr "volatility1: 1-актив бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1673 ../plugins/fn-derivatives/options.c:1717
msgid "volatility2:annualized volatility in price of asset 2"
msgstr "volatility2: 2-актив бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1674 ../plugins/fn-derivatives/options.c:1718
msgid "rho:correlation between the prices of the two assets"
msgstr "rho: екі актив бағасы арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:1675
msgid "OPT_EURO_EXCHANGE models the theoretical price of a European option to exchange one asset with quantity @{qty2} and spot price @{spot2} for another with quantity @{qty1} and spot price @{spot1}."
msgstr "OPT_EURO_EXCHANGE саны @{qty2} және спот бағасы @{spot2} болатын бір активті саны @{qty1} және спот бағасы @{spot1} болатын басқа активке айырбастауға арналған еуропалық опционның теориялық бағасын модельдейді."

#: ../plugins/fn-derivatives/options.c:1705
msgid "OPT_AMER_EXCHANGE:theoretical price of an American option to exchange assets"
msgstr "OPT_AMER_EXCHANGE: активтерді айырбастауға арналған американдық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1719
msgid "OPT_AMER_EXCHANGE models the theoretical price of an American option to exchange one asset with quantity @{qty2} and spot price @{spot2} for another with quantity @{qty1} and spot price @{spot1}."
msgstr "OPT_AMER_EXCHANGE саны @{qty2} және спот бағасы @{spot2} болатын бір активті саны @{qty1} және спот бағасы @{spot1} болатын басқа активке айырбастауға арналған американдық опционның теориялық бағасын модельдейді."

#: ../plugins/fn-derivatives/options.c:1749
msgid "OPT_SPREAD_APPROX:theoretical price of a European option on the spread between two futures contracts"
msgstr "OPT_SPREAD_APPROX: екі фьючерстік келісімшарт арасындағы спрэдке еуропалық опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1751
msgid "fut_price1:price of the first futures contract"
msgstr "fut_price1: бірінші фьючерстік келісімшарттың бағасы"

#: ../plugins/fn-derivatives/options.c:1752
msgid "fut_price2:price of the second futures contract"
msgstr "fut_price2: екінші фьючерстік келісімшарттың бағасы"

#: ../plugins/fn-derivatives/options.c:1756
msgid "volatility1:annualized volatility in price of the first underlying futures contract"
msgstr "volatility1: бірінші негізгі фьючерстік келісімшарт бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1757
msgid "volatility2:annualized volatility in price of the second underlying futures contract"
msgstr "volatility2: екінші негізгі фьючерстік келісімшарт бағасының жылдық құбылмалылығы"

#: ../plugins/fn-derivatives/options.c:1758
msgid "rho:correlation between the two futures contracts"
msgstr "rho: екі фьючерстік келісімшарт арасындағы корреляция"

#: ../plugins/fn-derivatives/options.c:1804
msgid "OPT_FLOAT_STRK_LKBK:theoretical price of floating-strike lookback option"
msgstr "OPT_FLOAT_STRK_LKBK: өзгермелі страйкі бар лукбэк (lookback) опционының теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1807 ../plugins/fn-derivatives/options.c:1871
msgid "spot_min:minimum spot price of the underlying asset so far observed"
msgstr "spot_min: осы уақытқа дейін бақыланған негізгі активтің минималды спот бағасы"

#: ../plugins/fn-derivatives/options.c:1808 ../plugins/fn-derivatives/options.c:1872
msgid "spot_max:maximum spot price of the underlying asset so far observed"
msgstr "spot_max: осы уақытқа дейін бақыланған негізгі активтің максималды спот бағасы"

#: ../plugins/fn-derivatives/options.c:1813
msgid "OPT_FLOAT_STRK_LKBK determines the theoretical price of a floating-strike lookback option where the holder of the option may exercise on expiry at the most favourable price observed during the options life of the underlying asset."
msgstr "OPT_FLOAT_STRK_LKBK өзгермелі страйкі бар лукбэк опционының теориялық бағасын анықтайды, мұнда опцион иеленушісі мерзімі аяқталған кезде негізгі активтің опцион қолданылу мерзімінде байқалған ең қолайлы бағасы бойынша орындай алады."

#: ../plugins/fn-derivatives/options.c:1868
msgid "OPT_FIXED_STRK_LKBK:theoretical price of a fixed-strike lookback option"
msgstr "OPT_FIXED_STRK_LKBK: бекітілген страйкі бар лукбэк опционының теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1878
msgid "OPT_FIXED_STRK_LKBK determines the theoretical price of a fixed-strike lookback option where the holder of the option may exercise on expiry at the most favourable price observed during the options life of the underlying asset."
msgstr "OPT_FIXED_STRK_LKBK бекітілген страйкі бар лукбэк опционының теориялық бағасын анықтайды, мұнда опцион иеленушісі мерзімі аяқталған кезде негізгі активтің опцион қолданылу мерзімінде байқалған ең қолайлы бағасы бойынша орындай алады."

#: ../plugins/fn-derivatives/options.c:1952
msgid "OPT_BINOMIAL:theoretical price of either an American or European style option using a binomial tree"
msgstr "OPT_BINOMIAL: биномдық ағашты қолдана отырып, американдық немесе еуропалық стильдегі опционның теориялық бағасы"

#: ../plugins/fn-derivatives/options.c:1953
msgid "amer_euro_flag:'a' for an American style option or 'e' for a European style option"
msgstr "amer_euro_flag: американдық стильдегі опцион үшін «a» немесе еуропалық стильдегі опцион үшін «e»"

#: ../plugins/fn-derivatives/options.c:1955
msgid "num_time_steps:number of time steps used in the valuation"
msgstr "num_time_steps: бағалауда қолданылатын уақыт қадамдарының саны"

#: ../plugins/fn-derivatives/options.c:1962
msgid "A larger @{num_time_steps} yields greater accuracy but  OPT_BINOMIAL is slower to calculate."
msgstr "@{num_time_steps} мәнінің үлкен болуы жоғарырақ дәлдікті береді, бірақ OPT_BINOMIAL есептеуі баяулайды."

#: ../plugins/fn-eng/functions.c:206
msgid "BASE:string of digits representing the number @{n} in base @{b}"
msgstr "BASE: @{n} санын @{b} санау жүйесінде өрнектейтін цифрлар жолы"

#: ../plugins/fn-eng/functions.c:207 ../plugins/fn-numtheory/numtheory.c:733 ../plugins/fn-numtheory/numtheory.c:763
msgid "n:integer"
msgstr "n: бүтін сан"

#: ../plugins/fn-eng/functions.c:208
msgid "b:base (2 ≤ @{b} ≤ 36)"
msgstr "b: негізі (2 ≤ @{b} ≤ 36)"

#: ../plugins/fn-eng/functions.c:209
msgid "length:minimum length of the resulting string"
msgstr "length: алынған жолдың минималды ұзындығы"

#: ../plugins/fn-eng/functions.c:210
msgid "BASE converts @{n} to its string representation in base @{b}. Leading zeroes will be added to reach the minimum length given by @{length}."
msgstr "BASE @{n} санын @{b} негізіндегі жол ретіндегі түріне түрлендіреді. @{length} арқылы берілген минималды ұзындыққа жету үшін алдына нөлдер қосылады."

#: ../plugins/fn-eng/functions.c:235
msgid "BIN2DEC:decimal representation of the binary number @{x}"
msgstr "BIN2DEC: @{x} екілік санының ондық өрнектелуі"

