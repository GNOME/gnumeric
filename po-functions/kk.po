msgstr "Бұл функция Excel 2010 бағдарламасымен үйлесімді."

#: ../plugins/fn-stat/functions.c:215
msgid "Let us assume that the cells A1, A2, ..., A5 contain numbers 11.4, 17.3, 21.3, 25.9, and 25.9."
msgstr "A1, A2, ..., A5 ұяшықтарында 11.4, 17.3, 21.3, 25.9 және 25.9 сандары бар деп есептейік."

#: ../plugins/fn-stat/functions.c:216
msgid "Then RANK.AVG(17.3,A1:A5) equals 4."
msgstr "Онда RANK.AVG(17.3,A1:A5) мәні 4-ке тең болады."

#: ../plugins/fn-stat/functions.c:217
msgid "Then RANK.AVG(25.9,A1:A5) equals 1.5."
msgstr "Онда RANK.AVG(25.9,A1:A5) мәні 1.5-ке тең болады."

