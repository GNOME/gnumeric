msgid "If @{row_num} or @{col_num} is less than one, ADDRESS returns #VALUE!"
msgstr "Егер @{row_num} немесе @{col_num} бірден аз болса, ADDRESS функциясы #VALUE! қайтарады"

#: ../plugins/fn-lookup/functions.c:815
msgid "If @{abs_num} is greater than 4 ADDRESS returns #VALUE!"
msgstr "Егер @{abs_num} мәні 4-тен үлкен болса, ADDRESS функциясы #VALUE! қайтарады"

#: ../plugins/fn-lookup/functions.c:902
msgid "AREAS:number of areas in @{reference}"
msgstr "AREAS:@{reference} ішіндегі облыстар саны"

#: ../plugins/fn-lookup/functions.c:903
msgid "reference:range"
msgstr "reference:ауқым"

#: ../plugins/fn-lookup/functions.c:970
msgid "CHOOSE:the (@{index}+1)th argument"
msgstr "CHOOSE:(@{index}+1)-ші аргумент"

#: ../plugins/fn-lookup/functions.c:971
msgid "index:positive number"
msgstr "index:оң сан"

#: ../plugins/fn-lookup/functions.c:972
msgid "value1:first value"
msgstr "value1:бірінші мән"

#: ../plugins/fn-lookup/functions.c:973
msgid "value2:second value"
msgstr "value2:екінші мән"

#: ../plugins/fn-lookup/functions.c:974
msgid "CHOOSE returns its (@{index}+1)th argument."
msgstr "CHOOSE функциясы өзінің (@{index}+1)-ші аргументін қайтарады."

