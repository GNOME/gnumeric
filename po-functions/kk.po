msgid "If @{z} is not a valid complex number, #VALUE! is returned."
msgstr "Егер @{z} жарамды кешенді сан болмаса, #VALUE! қайтарылады."

#: ../plugins/fn-complex/functions.c:136
msgid "IMABS:the absolute value of the complex number @{z}"
msgstr "IMABS: @{z} кешенді санының абсолютті мәні"

#: ../plugins/fn-complex/functions.c:160
msgid "IMREAL:the real part of the complex number @{z}"
msgstr "IMREAL: @{z} кешенді санының нақты бөлігі"

#: ../plugins/fn-complex/functions.c:187
msgid "IMCONJUGATE:the complex conjugate of the complex number @{z}"
msgstr "IMCONJUGATE: @{z} кешенді санының түйіндес кешенді саны"

#: ../plugins/fn-complex/functions.c:211
msgid "IMINV:the reciprocal, or inverse, of the complex number @{z}"
msgstr "IMINV: @{z} кешенді санына кері сан"

#: ../plugins/fn-complex/functions.c:233
msgid "IMNEG:the negative of the complex number @{z}"
msgstr "IMNEG: @{z} кешенді санына қарама-қарсы сан"

#: ../plugins/fn-complex/functions.c:255
msgid "IMCOS:the cosine of the complex number @{z}"
msgstr "IMCOS: @{z} кешенді санының косинусы"

#: ../plugins/fn-complex/functions.c:280
msgid "IMTAN:the tangent of the complex number @{z}"
msgstr "IMTAN: @{z} кешенді санының тангенсі"

#: ../plugins/fn-complex/functions.c:305
msgid "IMSEC:the secant of the complex number @{z}"
msgstr "IMSEC: @{z} кешенді санының секансы"

#: ../plugins/fn-complex/functions.c:307
msgid "IMSEC(@{z}) = 1/IMCOS(@{z})."
msgstr "IMSEC(@{z}) = 1/IMCOS(@{z})."

#: ../plugins/fn-complex/functions.c:330
msgid "IMCSC:the cosecant of the complex number @{z}"
msgstr "IMCSC: @{z} кешенді санының косекансы"

#: ../plugins/fn-complex/functions.c:332
msgid "IMCSC(@{z}) = 1/IMSIN(@{z})."
msgstr "IMCSC(@{z}) = 1/IMSIN(@{z})."

#: ../plugins/fn-complex/functions.c:354
msgid "IMCOT:the cotangent of the complex number @{z}"
msgstr "IMCOT: @{z} кешенді санының котангенсі"

#: ../plugins/fn-complex/functions.c:356
msgid "IMCOT(@{z}) = IMCOS(@{z})/IMSIN(@{z})."
msgstr "IMCOT(@{z}) = IMCOS(@{z})/IMSIN(@{z})."

#: ../plugins/fn-complex/functions.c:379
msgid "IMEXP:the exponential of the complex number @{z}"
msgstr "IMEXP: @{z} кешенді санының экспонентасы"

#: ../plugins/fn-complex/functions.c:405
msgid "IMARGUMENT:the argument theta of the complex number @{z}"
msgstr "IMARGUMENT: @{z} кешенді санының тета аргументі"

#: ../plugins/fn-complex/functions.c:407
msgid "The argument theta of a complex number is its angle in radians from the real axis."
msgstr "Кешенді санның тета аргументі — оның нақты осьтен радианмен есептелген бұрышы."

#: ../plugins/fn-complex/functions.c:409
msgid "If @{z} is 0, 0 is returned.  This is different from Excel which returns an error."
msgstr "Егер @{z} мәні 0 болса, 0 қайтарылады. Бұл қате қайтаратын Excel-ден өзгеше."

#: ../plugins/fn-complex/functions.c:430
msgid "IMLN:the natural logarithm of the complex number @{z}"
msgstr "IMLN: @{z} кешенді санының натурал логарифмі"

#: ../plugins/fn-complex/functions.c:432
msgid ""
"The result will have an imaginary part between -π and +π.\n"
"The natural logarithm is not uniquely defined on complex numbers. You may need to add or subtract an even multiple of π to the imaginary part."
msgstr ""
"Нәтижесіндегі жорамал бөлік -π мен +π аралығында болады.\n"
"Кешенді сандарда натурал логарифм бірмағыналы анықталмаған. Жорамал бөлікке π-дің жұп еселіктерін қосу немесе одан алу қажет болуы мүмкін."

#: ../plugins/fn-complex/functions.c:457
msgid "IMLOG2:the base-2 logarithm of the complex number @{z}"
msgstr "IMLOG2: @{z} кешенді санының 2 негізі бойынша логарифмі"

#: ../plugins/fn-complex/functions.c:482
msgid "IMLOG10:the base-10 logarithm of the complex number @{z}"
msgstr "IMLOG10: @{z} кешенді санының 10 негізі бойынша логарифмі"

#: ../plugins/fn-complex/functions.c:506
msgid "IMPOWER:the complex number @{z1} raised to the @{z2}th power"
msgstr "IMPOWER: @{z1} кешенді санының @{z2} дәрежесі"

#: ../plugins/fn-complex/functions.c:507 ../plugins/fn-complex/functions.c:538 ../plugins/fn-complex/functions.c:1139 ../plugins/fn-complex/functions.c:1168 ../plugins/fn-complex/functions.c:1237
msgid "z1:a complex number"
msgstr "z1: кешенді сан"

#: ../plugins/fn-complex/functions.c:508 ../plugins/fn-complex/functions.c:539 ../plugins/fn-complex/functions.c:1140 ../plugins/fn-complex/functions.c:1169 ../plugins/fn-complex/functions.c:1238
msgid "z2:a complex number"
msgstr "z2: кешенді сан"

#: ../plugins/fn-complex/functions.c:509 ../plugins/fn-complex/functions.c:540 ../plugins/fn-complex/functions.c:1141
