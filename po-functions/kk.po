#: ../plugins/fn-stat/functions.c:2404 ../plugins/fn-stat/functions.c:2462
msgid "If data set is empty this function returns a #NUM! error."
msgstr "Егер деректер жиынтығы бос болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2405 ../plugins/fn-stat/functions.c:2463
msgid "If @{k} <= 0 or @{k} is greater than the number of data items given this function returns a #NUM! error."
msgstr "Егер @{k} <= 0 немесе @{k} берілген деректер элементтерінің санынан көп болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2410
msgid "Then LARGE(A1:A5,2) equals 25.9. LARGE(A1:A5,4) equals 17.3."
msgstr "Онда LARGE(A1:A5,2) 25.9-ға тең. LARGE(A1:A5,4) 17.3-ке тең болады."

#: ../plugins/fn-stat/functions.c:2459
msgid "SMALL:@{k}-th smallest value in a data set"
msgstr "SMALL: деректер жиынтығындағы @{k}-ші ең кіші мән"

#: ../plugins/fn-stat/functions.c:2468
msgid "Then SMALL(A1:A5,2) equals 17.3. SMALL(A1:A5,4) equals 25.9."
msgstr "Онда SMALL(A1:A5,2) 17.3-ке тең. SMALL(A1:A5,4) 25.9-ға тең болады."

#: ../plugins/fn-stat/functions.c:2502
msgid "PROB:probability of an interval for a discrete (and finite) probability distribution"
msgstr "PROB: дискретті (және шекті) ықтималдық үлестірімі үшін интервалдың ықтималдығы"

#: ../plugins/fn-stat/functions.c:2503
msgid "x_range:possible values"
msgstr "x_range: мүмкін мәндер"

#: ../plugins/fn-stat/functions.c:2504
msgid "prob_range:probabilities of the corresponding values"
msgstr "prob_range: сәйкес мәндердің ықтималдықтары"

#: ../plugins/fn-stat/functions.c:2505
msgid "lower_limit:lower interval limit"
msgstr "lower_limit: интервалдың төменгі шегі"

#: ../plugins/fn-stat/functions.c:2506
msgid "upper_limit:upper interval limit, defaults to @{lower_limit}"
msgstr "upper_limit: интервалдың жоғарғы шегі, бастапқы мәні @{lower_limit}"

#: ../plugins/fn-stat/functions.c:2507
msgid "If the sum of the probabilities in @{prob_range} is not equal to 1 this function returns a #NUM! error."
msgstr "Егер @{prob_range} ішіндегі ықтималдықтардың қосындысы 1-ге тең болмаса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2509
msgid "If any value in @{prob_range} is <=0 or > 1, this function returns a #NUM! error."
msgstr "Егер @{prob_range} ішіндегі кез келген мән <= 0 немесе > 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2511
msgid "If @{x_range} and @{prob_range} contain a different number of data entries, this function returns a #N/A error."
msgstr "Егер @{x_range} және @{prob_range} деректер элементтерінің саны әртүрлі болса, бұл функция #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2588
msgid "STEYX:standard error of the predicted y-value in the regression"
msgstr "STEYX: регрессиядағы болжамды y-мәннің стандартты қатесі"

#: ../plugins/fn-stat/functions.c:2589 ../plugins/fn-stat/functions.c:3883 ../plugins/fn-stat/functions.c:3999 ../plugins/fn-stat/functions.c:4241 ../plugins/fn-stat/functions.c:4339 ../plugins/fn-stat/functions.c:4443 ../plugins/fn-stat/functions.c:4502 ../plugins/fn-stat/functions.c:4554
msgid "known_ys:known y-values"
msgstr "known_ys: белгілі y-мәндері"

#: ../plugins/fn-stat/functions.c:2590 ../plugins/fn-stat/functions.c:4000 ../plugins/fn-stat/functions.c:4444 ../plugins/fn-stat/functions.c:4503 ../plugins/fn-stat/functions.c:4555
msgid "known_xs:known x-values"
msgstr "known_xs: белгілі x-мәндері"

#: ../plugins/fn-stat/functions.c:2591
msgid "If @{known_ys} and @{known_xs} are empty or have a different number of arguments then this function returns a #N/A error."
msgstr "Егер @{known_ys} және @{known_xs} бос болса немесе олардың аргументтер саны әртүрлі болса, бұл функция #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2597
msgid "Then STEYX(A1:A5,B1:B5) equals 1.101509979."
msgstr "Онда STEYX(A1:A5,B1:B5) 1.101509979-ға тең болады."

#: ../plugins/fn-stat/functions.c:2641
msgid "ZTEST:the probability of observing a sample mean as large as or larger than the mean of the given sample"
msgstr "ZTEST: таңдаманың орташа мәні берілген таңдаманың орташа мәніне тең немесе одан үлкен болу ықтималдығы"

#: ../plugins/fn-stat/functions.c:2643
msgid "ref:data set (sample)"
msgstr "ref: деректер жиынтығы (таңдама)"

#: ../plugins/fn-stat/functions.c:2644
msgid "x:population mean"
msgstr "x: бас жиынтықтың орташа мәні"

#: ../plugins/fn-stat/functions.c:2645
msgid "stddev:population standard deviation, defaults to the sample standard deviation"
msgstr "stddev: бас жиынтықтың стандартты ауытқуы, бастапқы мәні — таңдамалы стандартты ауытқу"

#: ../plugins/fn-stat/functions.c:2646
msgid "ZTEST calculates the probability of observing a sample mean as large as or larger than the mean of the given sample for samples drawn from a normal distribution with mean @{x} and standard deviation @{stddev}."
msgstr "ZTEST орташа мәні @{x} және стандартты ауытқуы @{stddev} болатын қалыпты үлестірімнен алынған таңдамалар үшін таңдаманың орташа мәні берілген таңдаманың орташа мәніне тең немесе одан үлкен болу ықтималдығын есептейді."

#: ../plugins/fn-stat/functions.c:2649
msgid "If @{ref} contains less than two data items ZTEST returns #DIV/0! error."
msgstr "Егер @{ref} екіден аз деректер элементін қамтыса, ZTEST #DIV/0! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2655
msgid "Then ZTEST(A1:A5,20) equals 0.254717826."
msgstr "Онда ZTEST(A1:A5,20) 0.254717826-ға тең болады."

#: ../plugins/fn-stat/functions.c:2706
msgid "AVERAGEA:average of all the values and cells"
msgstr "AVERAGEA: барлық мәндер мен ұяшықтардың орташа мәні"

#: ../plugins/fn-stat/functions.c:2730
msgid "MAXA:largest value, with negative numbers considered smaller than positive numbers"
msgstr "MAXA: ең үлкен мән, теріс сандар оң сандардан кіші деп есептеледі"

#: ../plugins/fn-stat/functions.c:2755
msgid "MINA:smallest value, with negative numbers considered smaller than positive numbers"
msgstr "MINA: ең кіші мән, теріс сандар оң сандардан кіші деп есептеледі"

#: ../plugins/fn-stat/functions.c:2780
msgid "VARA:sample variance of the given sample"
msgstr "VARA: берілген таңдаманың таңдамалы дисперсиясы"

#: ../plugins/fn-stat/functions.c:2783
msgid "VARA is also known as the N-1-variance."
msgstr "VARA сонымен қатар N-1-дисперсия ретінде белгілі."

#: ../plugins/fn-stat/functions.c:2784
msgid "To get the true variance of a complete population use VARPA."
msgstr "Толық бас жиынтықтың нақты дисперсиясын алу үшін VARPA пайдаланыңыз."

#: ../plugins/fn-stat/functions.c:2809
msgid "VARPA:variance of an entire population"
msgstr "VARPA: бүкіл бас жиынтықтың дисперсиясы"

#: ../plugins/fn-stat/functions.c:2812
msgid "VARPA is also known as the N-variance."
msgstr "VARPA сонымен қатар N-дисперсия ретінде белгілі."

#: ../plugins/fn-stat/functions.c:2834
msgid "STDEVA:sample standard deviation of the given sample"
msgstr "STDEVA: берілген таңдаманың таңдамалы стандартты ауытқуы"

#: ../plugins/fn-stat/functions.c:2838
msgid "STDEVA is also known as the N-1-standard deviation."
msgstr "STDEVA сонымен қатар N-1-стандартты ауытқу ретінде белгілі."

#: ../plugins/fn-stat/functions.c:2839
msgid "To obtain the population standard deviation of a whole population use STDEVPA."
msgstr "Бүкіл бас жиынтықтың стандартты ауытқуын алу үшін STDEVPA пайдаланыңыз."

#: ../plugins/fn-stat/functions.c:2862
msgid "STDEVPA:population standard deviation of an entire population"
msgstr "STDEVPA: бүкіл бас жиынтықтың стандартты ауытқуы"

#: ../plugins/fn-stat/functions.c:2887
msgid "PERCENTRANK:rank of a data point in a data set (Hyndman-Fan method 7: N-1 basis)"
msgstr "PERCENTRANK: деректер жиынтығындағы деректер нүктесінің рангі (Хайндман-Фан 7-әдісі: N-1 негізі)"

#: ../plugins/fn-stat/functions.c:2888 ../plugins/fn-stat/functions.c:2992
msgid "array:range of numeric values"
msgstr "array: сандық мәндер массиві"

#: ../plugins/fn-stat/functions.c:2889 ../plugins/fn-stat/functions.c:2993
msgid "x:data point to be ranked"
msgstr "x: рангіленетін деректер нүктесі"

#: ../plugins/fn-stat/functions.c:2890 ../plugins/fn-stat/functions.c:2994
msgid "significance:number of significant digits, defaults to 3"
msgstr "significance: мәнді цифрлар саны, бастапқы мәні 3"

#: ../plugins/fn-stat/functions.c:2891 ../plugins/fn-stat/functions.c:2995
msgid "If @{array} contains no data points, this function returns a #NUM! error."
msgstr "Егер @{array} массивінде деректер нүктелері болмаса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2893 ../plugins/fn-stat/functions.c:2997
msgid "If @{significance} is less than one, this function returns a #NUM! error."
msgstr "Егер @{significance} бірден аз болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2895 ../plugins/fn-stat/functions.c:2999
msgid "If @{x} exceeds the largest value or is less than the smallest value in @{array}, this function returns an #N/A error."
msgstr "Егер @{x} @{array} массивіндегі ең үлкен мәннен асса немесе ең кіші мәннен аз болса, бұл функция #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:2897 ../plugins/fn-stat/functions.c:3001
msgid "If @{x} does not match any of the values in @{array} or @{x} matches more than once, this function interpolates the returned value."
msgstr "Егер @{x} @{array} массивіндегі ешбір мәнге сәйкес келмесе немесе @{x} бірнеше рет сәйкес келсе, бұл функция қайтарылатын мәнді интерполяциялайды."

#: ../plugins/fn-stat/functions.c:2991
msgid "PERCENTRANK.EXC:rank of a data point in a data set (Hyndman-Fan method 6: N+1 basis)"
msgstr "PERCENTRANK.EXC: деректер жиынтығындағы деректер нүктесінің рангі (Хайндман-Фан 6-әдісі: N+1 негізі)"

#: ../plugins/fn-stat/functions.c:3092
msgid "PERCENTILE:determines the 100*@{k}-th percentile of the given data points (Hyndman-Fan method 7: N-1 basis)"
msgstr "PERCENTILE: берілген деректер нүктелерінің 100*@{k}-ші процентилін анықтайды (Хайндман-Фан 7-әдісі: N-1 негізі)"

#: ../plugins/fn-stat/functions.c:3093 ../plugins/fn-stat/functions.c:3135 ../plugins/fn-stat/functions.c:3180 ../plugins/fn-stat/functions.c:3223
msgid "array:data points"
msgstr "array: деректер нүктелерінің массиві"

#: ../plugins/fn-stat/functions.c:3094 ../plugins/fn-stat/functions.c:3136
msgid "k:which percentile to calculate"
msgstr "k: қай процентильді есептеу керек"

#: ../plugins/fn-stat/functions.c:3096 ../plugins/fn-stat/functions.c:3138
msgid "If @{k} < 0 or @{k} > 1, this function returns a #NUM! error."
msgstr "Егер @{k} < 0 немесе @{k} > 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3099
msgid "Then PERCENTILE(A1:A5,0.42) equals 20.02."
msgstr "Онда PERCENTILE(A1:A5,0.42) 20.02-ге тең болады."

#: ../plugins/fn-stat/functions.c:3134
msgid "PERCENTILE.EXC:determines the 100*@{k}-th percentile of the given data points (Hyndman-Fan method 6: N+1 basis)"
msgstr "PERCENTILE.EXC: берілген деректер нүктелерінің 100*@{k}-ші процентилін анықтайды (Хайндман-Фан 6-әдісі: N+1 негізі)"

#: ../plugins/fn-stat/functions.c:3141
msgid "Then PERCENTILE.EXC(A1:A5,0.42) equals 20.02."
msgstr "Онда PERCENTILE.EXC(A1:A5,0.42) 20.02-ге тең болады."

#: ../plugins/fn-stat/functions.c:3179
msgid "QUARTILE:the @{quart}-th quartile of the data points (Hyndman-Fan method 7: N-1 basis)"
msgstr "QUARTILE: деректер нүктелерінің @{quart}-ші квартилі (Хайндман-Фан 7-әдісі: N-1 негізі)"

#: ../plugins/fn-stat/functions.c:3181
msgid "quart:a number from 0 to 4, indicating which quartile to calculate"
msgstr "quart: есептелетін квартильді көрсететін 0-ден 4-ке дейінгі сан"

#: ../plugins/fn-stat/functions.c:3183 ../plugins/fn-stat/functions.c:3226
msgid "If @{quart} < 0 or @{quart} > 4, this function returns a #NUM! error. If @{quart} = 0, the smallest value of @{array} to be returned."
msgstr "Егер @{quart} < 0 немесе @{quart} > 4 болса, бұл функция #NUM! қатесін қайтарады. Егер @{quart} = 0 болса, @{array} массивінің ең кіші мәні қайтарылады."

#: ../plugins/fn-stat/functions.c:3184 ../plugins/fn-stat/functions.c:3227
msgid "If @{quart} is not an integer, it is truncated."
msgstr "Егер @{quart} бүтін сан болмаса, ол қиып жіберіледі."

#: ../plugins/fn-stat/functions.c:3187
msgid "Then QUARTILE(A1:A5,1) equals 17.3."
msgstr "Онда QUARTILE(A1:A5,1) 17.3-ке тең болады."

#: ../plugins/fn-stat/functions.c:3222
msgid "QUARTILE.EXC:the @{quart}-th quartile of the data points (Hyndman-Fan method 6: N+1 basis)"
msgstr "QUARTILE.EXC: деректер нүктелерінің @{quart}-ші квартилі (Хайндман-Фан 6-әдісі: N+1 негізі)"

#: ../plugins/fn-stat/functions.c:3224
msgid "quart:a number from 1 to 3, indicating which quartile to calculate"
msgstr "quart: есептелетін квартильді көрсететін 1-ден 3-ке дейінгі сан"

#: ../plugins/fn-stat/functions.c:3230
msgid "Then QUARTILE.EXC(A1:A5,1) equals 14.35."
msgstr "Онда QUARTILE.EXC(A1:A5,1) 14.35-ке тең болады."

#: ../plugins/fn-stat/functions.c:3268
msgid "FTEST:p-value for the two-tailed hypothesis test comparing the variances of two populations"
msgstr "FTEST: екі бас жиынтықтың дисперсияларын салыстыратын екі жақты гипотеза тесті үшін p-мәні"

#: ../plugins/fn-stat/functions.c:3270 ../plugins/fn-stat/functions.c:3327
msgid "array1:sample from the first population"
msgstr "array1: бірінші бас жиынтықтан алынған массив таңдамасы"

#: ../plugins/fn-stat/functions.c:3271 ../plugins/fn-stat/functions.c:3328
msgid "array2:sample from the second population"
msgstr "array2: екінші бас жиынтықтан алынған массив таңдамасы"

#: ../plugins/fn-stat/functions.c:3276
msgid "Then FTEST(A1:A5,B1:B5) equals 0.510815017."
msgstr "Онда FTEST(A1:A5,B1:B5) 0.510815017-ге тең болады."

#: ../plugins/fn-stat/functions.c:3325
msgid "TTEST:p-value for a hypothesis test comparing the means of two populations using the Student t-distribution"
msgstr "TTEST: Стьюденттің t-үлестірімін пайдаланып, екі бас жиынтықтың орташа мәндерін салыстыратын гипотеза тесті үшін p-мәні"

#: ../plugins/fn-stat/functions.c:3329
msgid "tails:number of tails to consider"
msgstr "tails: ескерілетін құйрықтар саны"

#: ../plugins/fn-stat/functions.c:3330
msgid "type:Type of test to perform. 1 indicates a test for paired variables, 2 a test of unpaired variables with equal variances, and 3 a test of unpaired variables with unequal variances"
msgstr "type: орындалатын тест түрі. 1 — жұпталған айнымалылар тестін, 2 — дисперсиялары тең жұпталмаған айнымалылар тестін, ал 3 — дисперсиялары тең емес жұпталмаған айнымалылар тестін білдіреді."

#: ../plugins/fn-stat/functions.c:3333
msgid "If the data sets contain a different number of data points and the test is paired (@{type} one), TTEST returns the #N/A error."
msgstr "Егер деректер жиынтықтарындағы деректер нүктелерінің саны әртүрлі болса және тест жұпталған болса (@{type} 1), TTEST #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3335
msgid "@{tails} and @{type} are truncated to integers."
msgstr "@{tails} және @{type} мәндері бүтін сандарға дейін қиып жіберіледі."

#: ../plugins/fn-stat/functions.c:3336
msgid "If @{tails} is not one or two, this function returns a #NUM! error."
msgstr "Егер @{tails} 1 немесе 2 болмаса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3337
msgid "If @{type} is any other than one, two, or three, this function returns a #NUM! error."
msgstr "Егер @{type} 1, 2 немесе 3-тен басқа мән болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3342
msgid "Then TTEST(A1:A5,B1:B5,1,1) equals 0.003127619. TTEST(A1:A5,B1:B5,2,1) equals 0.006255239. TTEST(A1:A5,B1:B5,1,2) equals 0.111804322. TTEST(A1:A5,B1:B5,1,3) equals 0.113821797."
msgstr "Онда TTEST(A1:A5,B1:B5,1,1) 0.003127619-ға тең. TTEST(A1:A5,B1:B5,2,1) 0.006255239-ға тең. TTEST(A1:A5,B1:B5,1,2) 0.111804322-ге тең. TTEST(A1:A5,B1:B5,1,3) 0.113821797-ге тең болады."

#: ../plugins/fn-stat/functions.c:3500
msgid "FREQUENCY:frequency table"
msgstr "FREQUENCY: жиіліктер кестесі"

#: ../plugins/fn-stat/functions.c:3501
msgid "data_array:data values"
msgstr "data_array: деректер массивінің мәндері"

#: ../plugins/fn-stat/functions.c:3502
msgid "bins_array:array of cutoff values"
msgstr "bins_array: шекті мәндер массиві"

#: ../plugins/fn-stat/functions.c:3503
msgid "The results are given as an array."
msgstr "Нәтижелер массив түрінде беріледі."

#: ../plugins/fn-stat/functions.c:3504
msgid "If the @{bins_array} is empty, this function returns the number of data points in @{data_array}."
msgstr "Егер @{bins_array} бос болса, бұл функция @{data_array} ішіндегі деректер нүктелерінің санын қайтарады."

#: ../plugins/fn-stat/functions.c:3568
msgid "LEVERAGE:calculate regression leverage"
msgstr "LEVERAGE: регрессия рычагын есептеу"

#: ../plugins/fn-stat/functions.c:3571
msgid "Returns the diagonal of @{A} (@{A}^T @{A})^-1 @{A}^T as a column vector."
msgstr "@{A} (@{A}^T @{A})^-1 @{A}^T диагоналін бағандық вектор ретінде қайтарады."

#: ../plugins/fn-stat/functions.c:3572
msgid "If the matrix is singular, #VALUE! is returned."
msgstr "Егер матрица ерекше (singular) болса, #VALUE! мәні қайтарылады."

#: ../plugins/fn-stat/functions.c:3776
msgid "LINEST:multiple linear regression coefficients and statistics"
msgstr "LINEST: көптік сызықтық регрессия коэффициенттері мен статистикасы"

#: ../plugins/fn-stat/functions.c:3777 ../plugins/fn-stat/functions.c:4094
msgid "known_ys:vector of values of dependent variable"
msgstr "known_ys: тәуелді айнымалы мәндерінің векторы"

#: ../plugins/fn-stat/functions.c:3778 ../plugins/fn-stat/functions.c:4095
msgid "known_xs:array of values of independent variables, defaults to a single vector {1,…,n}"
msgstr "known_xs: тәуелсіз айнымалылар мәндерінің массиві, үнсіз келісім бойынша {1,…,n} жалғыз векторы"

#: ../plugins/fn-stat/functions.c:3779 ../plugins/fn-stat/functions.c:3885 ../plugins/fn-stat/functions.c:4097 ../plugins/fn-stat/functions.c:4243 ../plugins/fn-stat/functions.c:4342
msgid "affine:if true, the model contains a constant term, defaults to true"
msgstr "affine: егер ақиқат болса, модель тұрақты мүшені қамтиды, үнсіз келісім бойынша ақиқат"

#: ../plugins/fn-stat/functions.c:3780
msgid "stats:if true, some additional statistics are provided, defaults to false"
msgstr "stats: егер ақиқат болса, кейбір қосымша статистика беріледі, үнсіз келісім бойынша жалған"

#: ../plugins/fn-stat/functions.c:3781
msgid "This function returns an array with the first row giving the regression coefficients for the independent variables x_m, x_(m-1),…,x_2, x_1 followed by the y-intercept if @{affine} is true."
msgstr "Бұл функция массивті қайтарады, оның бірінші жолында x_m, x_(m-1),…,x_2, x_1 тәуелсіз айнымалылары үшін регрессия коэффициенттері, содан кейін @{affine} ақиқат болған жағдайда y-қиылысу мәні беріледі."

#: ../plugins/fn-stat/functions.c:3784
msgid "If @{stats} is true, the second row contains the corresponding standard errors of the regression coefficients. In this case, the third row contains the R^2 value and the standard error for the predicted value. The fourth row contains the observed F value and its degrees of freedom. Finally, the fifth row contains the regression sum of squares and the residual sum of squares."
msgstr "Егер @{stats} ақиқат болса, екінші жолда регрессия коэффициенттерінің тиісті стандартты қателері болады. Бұл жағдайда үшінші жолда R^2 мәні мен болжамды мәннің стандартты қатесі болады. Төртінші жолда бақыланатын F мәні мен оның еркіндік дәрежесі болады. Соңында, бесінші жолда регрессиялық квадраттар қосындысы мен қалдық квадраттар қосындысы болады."

#: ../plugins/fn-stat/functions.c:3791
msgid "If @{affine} is false, R^2 is the uncentered version of the coefficient of determination; that is the proportion of the sum of squares explained by the model."
msgstr "Егер @{affine} жалған болса, R^2 — детерминация коэффициентінің орталықтандырылмаған нұсқасы; бұл модельмен түсіндірілетін квадраттар қосындысының үлесі."

#: ../plugins/fn-stat/functions.c:3794 ../plugins/fn-stat/functions.c:4098
msgid "If the length of @{known_ys} does not match the corresponding length of @{known_xs}, this function returns a #NUM! error."
msgstr "Егер @{known_ys} ұзындығы @{known_xs} сәйкес ұзындығына сәйкес келмесе, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3882
msgid "LOGREG:the logarithmic regression"
msgstr "LOGREG: логарифмдік регрессия"

#: ../plugins/fn-stat/functions.c:3884 ../plugins/fn-stat/functions.c:4340
msgid "known_xs:known x-values; defaults to the array {1, 2, 3, …}"
msgstr "known_xs: белгілі x-мәндері; үнсіз келісім бойынша {1, 2, 3, …} массиві"

#: ../plugins/fn-stat/functions.c:3886 ../plugins/fn-stat/functions.c:4244
msgid "stat:if true, extra statistical information will be returned; defaults to FALSE"
msgstr "stat: егер ақиқат болса, қосымша статистикалық ақпарат қайтарылады; үнсіз келісім бойынша FALSE"

#: ../plugins/fn-stat/functions.c:3887
msgid "LOGREG function transforms your x's to z=ln(x) and applies the “least squares” method to fit the linear equation y = m * z + b to your y's and z's --- equivalent to fitting the equation y = m * ln(x) + b to y's and x's. LOGREG returns an array having two columns and one row. m is given in the first column and b in the second."
msgstr "LOGREG функциясы x-теріңізді z=ln(x) түріне түрлендіреді және y және z-теріңізге y = m * z + b сызықтық теңдеуін сәйкестендіру үшін «ең кіші квадраттар» әдісін қолданады --- бұл y және x-теріңізге y = m * ln(x) + b теңдеуін сәйкестендірумен тең. LOGREG екі бағаннан және бір жолдан тұратын массивті қайтарады. m бірінші бағанда, ал b екінші бағанда беріледі."

#: ../plugins/fn-stat/functions.c:3895
msgid ""
"Any extra statistical information is written below m and b in the result array.  This extra statistical information consists of four rows of data:  In the first row the standard error values for the coefficients m, b are given.  The second row contains the square of R and the standard error for the y estimate. The third row contains the F-observed value and the degrees of freedom.  The last row contains the regression sum of squares and the residual sum of squares. "
"The default of @{stat} is FALSE."
msgstr ""
"Кез келген қосымша статистикалық ақпарат нәтиже массивінде m және b мәндерінен төмен жазылады. Бұл қосымша статистикалық ақпарат төрт деректер жолынан тұрады: Бірінші жолда m, b коэффициенттері үшін стандартты қате мәндері беріледі. Екінші жолда R квадраты және y бағалауы үшін стандартты қате болады. Үшінші жолда бақыланатын F-мәні және еркіндік дәрежесі болады. Соңғы жолда регрессиялық квадраттар қосындысы және қалдық квадраттар қосындысы болады. @{stat} параметрінің "
"үнсіз келісім мәні — FALSE."

#: ../plugins/fn-stat/functions.c:3904 ../plugins/fn-stat/functions.c:4259 ../plugins/fn-stat/functions.c:4351
msgid "If @{known_ys} and @{known_xs} have unequal number of data points, this function returns a #NUM! error."
msgstr "Егер @{known_ys} және @{known_xs} деректер нүктелерінің саны тең болмаса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:3998
msgid "LOGFIT:logarithmic least square fit (using a trial and error method)"
msgstr "LOGFIT: логарифмдік ең кіші квадраттар сәйкестігі (сынақ пен қате әдісін қолдану арқылы)"

#: ../plugins/fn-stat/functions.c:4002
msgid "LOGFIT function applies the “least squares” method to fit the logarithmic equation y = a + b * ln(sign * (x - c)) ,   sign = +1 or -1 to your data. The graph of the equation is a logarithmic curve moved horizontally by c and possibly mirrored across the y-axis (if sign = -1)."
msgstr "LOGFIT функциясы деректеріңізге y = a + b * ln(sign * (x - c)) , sign = +1 немесе -1 логарифмдік теңдеуін сәйкестендіру үшін «ең кіші квадраттар» әдісін қолданады. Теңдеу графигі — c мәніне горизонталды жылжытылған және y осі бойынша шағылысуы мүмкін (егер sign = -1 болса) логарифмдік қисық."

#: ../plugins/fn-stat/functions.c:4008
msgid "LOGFIT returns an array having five columns and one row. `Sign' is given in the first column, `a', `b', and `c' are given in columns 2 to 4. Column 5 holds the sum of squared residuals."
msgstr "LOGFIT бес бағаннан және бір жолдан тұратын массивті қайтарады. `Sign' мәні бірінші бағанда, `a', `b' және `c' мәндері 2-ден 4-ке дейінгі бағандарда беріледі. 5-бағанда қалдықтардың квадраттар қосындысы сақталады."

#: ../plugins/fn-stat/functions.c:4012
msgid "An error is returned when there are less than 3 different x's or y's, or when the shape of the point cloud is too different from a ``logarithmic'' one."
msgstr "3-тен аз әртүрлі x немесе y болғанда немесе нүктелер жиынтығының пішіні «логарифмдік» пішіннен тым ерекше болғанда қате қайтарылады."

#: ../plugins/fn-stat/functions.c:4015
msgid "You can use the above formula = a + b * ln(sign * (x - c)) or rearrange it to = (exp((y - a) / b)) / sign + c to compute unknown y's or x's, respectively."
msgstr "Белгісіз y немесе x мәндерін есептеу үшін жоғарыдағы = a + b * ln(sign * (x - c)) формуласын қолдануға немесе оны сәйкесінше = (exp((y - a) / b)) / sign + c түріне өзгертуге болады."

#: ../plugins/fn-stat/functions.c:4020
msgid "This is non-linear fitting by trial-and-error. The accuracy of `c' is: width of x-range -> rounded to the next smaller (10^integer), times 0.000001. There might be cases in which the returned fit is not the best possible."
msgstr "Бұл сынақ пен қате әдісі арқылы сызықтық емес сәйкестендіру. `c' дәлдігі: x-ауқымының ені -> келесі кіші (10^бүтін сан) мәніне дейін дөңгелектенеді, 0.000001-ге көбейтіледі. Қайтарылған сәйкестік ең жақсы нұсқа болмайтын жағдайлар болуы мүмкін."

#: ../plugins/fn-stat/functions.c:4093
msgid "TREND:estimates future values of a given data set using a least squares approximation"
msgstr "TREND: ең кіші квадраттар жуықтауын қолданып, берілген деректер жиынтығының болашақ мәндерін бағалайды"

#: ../plugins/fn-stat/functions.c:4096
msgid "new_xs:array of x-values for which to estimate the y-values; defaults to @{known_xs}"
msgstr "new_xs: y-мәндерін бағалауға арналған x-мәндерінің массиві; үнсіз келісім бойынша @{known_xs}"

#: ../plugins/fn-stat/functions.c:4100
msgid "Let us assume that the cells A1, A2, …, A5 contain numbers 11.4, 17.3, 21.3, 25.9, and 40.1, and the cells B1, B2, ... B5 23.2, 25.8, 29.9, 33.5, and 42.7."
msgstr "A1, A2, …, A5 ұяшықтарында 11.4, 17.3, 21.3, 25.9 және 40.1 сандары, ал B1, B2, ... B5 ұяшықтарында 23.2, 25.8, 29.9, 33.5 және 42.7 сандары бар деп есептейік."

#: ../plugins/fn-stat/functions.c:4103
msgid "Then TREND(A1:A5,B1:B5) equals {12.1, 15.7, 21.6, 26.7, 39.7}."
msgstr "Онда TREND(A1:A5,B1:B5) мәні {12.1, 15.7, 21.6, 26.7, 39.7} тең болады."

#: ../plugins/fn-stat/functions.c:4240
msgid "LOGEST:exponential least square fit"
msgstr "LOGEST: экспоненциалды ең кіші квадраттар сәйкестігі"

#: ../plugins/fn-stat/functions.c:4242
msgid "known_xs:known x-values; default to an array {1, 2, 3, …}"
msgstr "known_xs: белгілі x-мәндері; үнсіз келісім бойынша {1, 2, 3, …} массиві"

#: ../plugins/fn-stat/functions.c:4245
msgid "LOGEST function applies the “least squares” method to fit an exponential curve of the form\ty = b * m{1}^x{1} * m{2}^x{2}... to your data."
msgstr "LOGEST функциясы деректеріңізге y = b * m{1}^x{1} * m{2}^x{2}... түріндегі экспоненциалды қисықты сәйкестендіру үшін «ең кіші квадраттар» әдісін қолданады."

#: ../plugins/fn-stat/functions.c:4249
msgid "LOGEST returns an array { m{n},m{n-1}, ...,m{1},b }."
msgstr "LOGEST { m{n},m{n-1}, ...,m{1},b } массивін қайтарады."

#: ../plugins/fn-stat/functions.c:4250
msgid ""
"Extra statistical information is written below the regression line coefficients in the result array.  Extra statistical information consists of four rows of data.  In the first row the standard error values for the coefficients m1, (m2, ...), b are represented.  The second row contains the square of R and the standard error for the y estimate.  The third row contains the F-observed value and the degrees of freedom.  The last row contains the regression sum of squares "
"and the residual sum of squares."
msgstr ""
"Қосымша статистикалық ақпарат нәтиже массивінде регрессия сызығының коэффициенттерінен төмен жазылады. Қосымша статистикалық ақпарат төрт деректер жолынан тұрады. Бірінші жолда m1, (m2, ...), b коэффициенттері үшін стандартты қате мәндері берілген. Екінші жолда R квадраты және y бағалауы үшін стандартты қате болады. Үшінші жолда бақыланатын F-мәні және еркіндік дәрежесі болады. Соңғы жолда регрессиялық квадраттар қосындысы және қалдық квадраттар қосындысы болады."

#: ../plugins/fn-stat/functions.c:4338
msgid "GROWTH:exponential growth prediction"
msgstr "GROWTH: экспоненциалды өсуді болжау"

#: ../plugins/fn-stat/functions.c:4341
msgid "new_xs:x-values for which to estimate the y-values; defaults to @{known_xs}"
msgstr "new_xs: y-мәндерін бағалауға арналған x-мәндері; үнсіз келісім бойынша @{known_xs}"

#: ../plugins/fn-stat/functions.c:4343
msgid "GROWTH function applies the “least squares” method to fit an exponential curve to your data and predicts the exponential growth by using this curve."
msgstr "GROWTH функциясы деректеріңізге экспоненциалды қисықты сәйкестендіру үшін «ең кіші квадраттар» әдісін қолданады және осы қисық арқылы экспоненциалды өсуді болжайды."

#: ../plugins/fn-stat/functions.c:4348
msgid "GROWTH returns an array having one column and a row for each data point in @{new_xs}."
msgstr "GROWTH функциясы бір бағаннан және @{new_xs} ішіндегі әрбір деректер нүктесі үшін бір жолдан тұратын массивті қайтарады."

#: ../plugins/fn-stat/functions.c:4440
msgid "FORECAST:estimates a future value according to existing values using simple linear regression"
msgstr "FORECAST: қарапайым сызықтық регрессияны қолданып, бар мәндер негізінде болашақ мәнді бағалайды"

#: ../plugins/fn-stat/functions.c:4442
msgid "x:x-value whose matching y-value should be forecast"
msgstr "x: сәйкес y-мәні болжануы тиіс x-мәні"

#: ../plugins/fn-stat/functions.c:4445
msgid "This function estimates a future value according to existing values using simple linear regression."
msgstr "Бұл функция қарапайым сызықтық регрессияны қолданып, бар мәндер негізінде болашақ мәнді бағалайды."

#: ../plugins/fn-stat/functions.c:4447 ../plugins/fn-stat/functions.c:4504 ../plugins/fn-stat/functions.c:4557
msgid "If @{known_xs} or @{known_ys} contains no data entries or different number of data entries, this function returns a #N/A error."
msgstr "Егер @{known_xs} немесе @{known_ys} ішінде деректер болмаса немесе деректер саны әртүрлі болса, бұл функция #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:4449
msgid "If the variance of the @{known_xs} is zero, this function returns a #DIV/0 error."
msgstr "Егер @{known_xs} дисперсиясы нөлге тең болса, бұл функция #DIV/0 қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:4455
msgid "Then FORECAST(7,A1:A5,B1:B5) equals -10.859397661."
msgstr "Онда FORECAST(7,A1:A5,B1:B5) мәні -10.859397661 тең болады."

#: ../plugins/fn-stat/functions.c:4501
msgid "INTERCEPT:the intercept of a linear regression line"
msgstr "INTERCEPT: сызықтық регрессия сызығының қиылысуы"

#: ../plugins/fn-stat/functions.c:4506 ../plugins/fn-stat/functions.c:4559
msgid "If the variance of the @{known_xs} is zero, this function returns #DIV/0 error."
msgstr "Егер @{known_xs} дисперсиясы нөлге тең болса, бұл функция #DIV/0 қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:4512
msgid "Then INTERCEPT(A1:A5,B1:B5) equals -20.785117212."
msgstr "Онда INTERCEPT(A1:A5,B1:B5) мәні -20.785117212 тең болады."

#: ../plugins/fn-stat/functions.c:4553
msgid "SLOPE:the slope of a linear regression line"
msgstr "SLOPE: сызықтық регрессия сызығының көлбеуі"

#: ../plugins/fn-stat/functions.c:4564
msgid "Then SLOPE(A1:A5,B1:B5) equals 1.417959936."
msgstr "Онда SLOPE(A1:A5,B1:B5) мәні 1.417959936 тең болады."

#: ../plugins/fn-stat/functions.c:4605
msgid "SUBTOTAL:the subtotal of the given list of arguments"
msgstr "SUBTOTAL: берілген аргументтер тізімінің аралық жиынтығы"

#: ../plugins/fn-stat/functions.c:4606
msgid ""
"function_nbr:determines which function to use according to the following table:\n"
"\t1   AVERAGE\n"
"\t2   COUNT\n"
"\t3   COUNTA\n"
"\t4   MAX\n"
"\t5   MIN\n"
"\t6   PRODUCT\n"
"\t7   STDEV\n"
"\t8   STDEVP\n"
"\t9   SUM\n"
"\t10   VAR\n"
"\t11   VARP"
msgstr ""
"function_nbr: келесі кестеге сәйкес қай функцияны қолдану керектігін анықтайды:\n"
"\t1   AVERAGE\n"
"\t2   COUNT\n"
"\t3   COUNTA\n"
"\t4   MAX\n"
"\t5   MIN\n"
"\t6   PRODUCT\n"
"\t7   STDEV\n"
"\t8   STDEVP\n"
"\t9   SUM\n"
"\t10   VAR\n"
"\t11   VARP"

#: ../plugins/fn-stat/functions.c:4619
msgid "ref1:first value"
msgstr "ref1:бірінші мән"

#: ../plugins/fn-stat/functions.c:4620
msgid "ref2:second value"
msgstr "ref2:екінші мән"

#: ../plugins/fn-stat/functions.c:4622
msgid "Let us assume that the cells A1, A2, ..., A5 contain numbers 23, 27, 28, 33, and 39."
msgstr "A1, A2, ..., A5 ұяшықтарында 23, 27, 28, 33 және 39 сандары бар деп есептейік."

#: ../plugins/fn-stat/functions.c:4623
msgid "Then SUBTOTAL(1,A1:A5) equals 30. SUBTOTAL(6,A1:A5) equals 22378356. SUBTOTAL(7,A1:A5) equals 6.164414003. SUBTOTAL(9,A1:A5) equals 150. SUBTOTAL(11,A1:A5) equals 30.4."
msgstr "Онда SUBTOTAL(1,A1:A5) мәні 30 тең. SUBTOTAL(6,A1:A5) мәні 22378356 тең. SUBTOTAL(7,A1:A5) мәні 6.164414003 тең. SUBTOTAL(9,A1:A5) мәні 150 тең. SUBTOTAL(11,A1:A5) мәні 30.4 тең."

#: ../plugins/fn-stat/functions.c:4695
msgid "CRONBACH:Cronbach's alpha"
msgstr "CRONBACH: Кронбах альфасы"

#: ../plugins/fn-stat/functions.c:4696
msgid "ref1:first data set"
msgstr "ref1: бірінші деректер жиынтығы"

#: ../plugins/fn-stat/functions.c:4697
msgid "ref2:second data set"
msgstr "ref2: екінші деректер жиынтығы"

#: ../plugins/fn-stat/functions.c:4794
msgid "GEOMDIST:probability mass or cumulative distribution function of the geometric distribution"
msgstr "GEOMDIST: геометриялық үлестірімнің ықтималдық массасы немесе кумулятивті үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:4795
msgid "k:number of trials"
msgstr "k: сынақтар саны"

#: ../plugins/fn-stat/functions.c:4796
msgid "p:probability of success in any trial"
msgstr "p: кез келген сынақтағы сәттілік ықтималдығы"

#: ../plugins/fn-stat/functions.c:4798
msgid "If @{k} < 0 this function returns a #NUM! error."
msgstr "Егер @{k} < 0 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:4825
msgid "LOGISTIC:probability density function of the logistic distribution"
msgstr "LOGISTIC: логистикалық үлестірімнің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4856
msgid "PARETO:probability density function of the Pareto distribution"
msgstr "PARETO: Парето үлестірімінің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4858
msgid "a:exponent"
msgstr "a: көрсеткіш"

#: ../plugins/fn-stat/functions.c:4859 ../plugins/fn-stat/functions.c:4952
msgid "b:scale parameter"
msgstr "b: масштаб параметрі"

#: ../plugins/fn-stat/functions.c:4890
msgid "RAYLEIGH:probability density function of the Rayleigh distribution"
msgstr "RAYLEIGH: Рэлей үлестірімінің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4892 ../plugins/fn-stat/functions.c:4913
msgid "sigma:scale parameter"
msgstr "sigma: масштаб параметрі"

#: ../plugins/fn-stat/functions.c:4910
msgid "RAYLEIGHTAIL:probability density function of the Rayleigh tail distribution"
msgstr "RAYLEIGHTAIL: Рэлейдің «құйрықты» үлестірімінің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4912
msgid "a:lower limit"
msgstr "a: төменгі шек"

#: ../plugins/fn-stat/functions.c:4948
msgid "EXPPOWDIST:the probability density function of the Exponential Power distribution"
msgstr "EXPPOWDIST: экспоненциалды-дәрежелік үлестірімнің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4954
msgid "This distribution has been recommended for lifetime analysis when a U-shaped hazard function is desired. This corresponds to rapid failure once the product starts to wear out after a period of steady or even improving reliability."
msgstr "Бұл үлестірім U-тәрізді қауіп функциясы қажет болған кездегі қызмет мерзімін талдау үшін ұсынылады. Бұл өнім тұрақты немесе жақсартылған сенімділік кезеңінен кейін тоза бастағандағы жылдам істен шығуына сәйкес келеді."

#: ../plugins/fn-stat/functions.c:4982
msgid "LAPLACE:probability density function of the Laplace distribution"
msgstr "LAPLACE: Лаплас үлестірімінің ықтималдық тығыздығы функциясы"

#: ../plugins/fn-stat/functions.c:4984
msgid "a:mean"
msgstr "a: орташа мән"

#: ../plugins/fn-stat/functions.c:5005
msgid "PERMUTATIONA:the number of permutations of @{y} objects chosen from @{x} objects with repetition allowed"
msgstr "PERMUTATIONA: қайталануға рұқсат етілген жағдайда @{x} объектісінен таңдалған @{y} объектісінің алмастырулар саны"

#: ../plugins/fn-stat/functions.c:5006
msgid "x:total number of objects"
msgstr "x: объектілердің жалпы саны"

#: ../plugins/fn-stat/functions.c:5007
msgid "y:number of selected objects"
msgstr "y: таңдалған объектілер саны"

#: ../plugins/fn-stat/functions.c:5008
msgid "If both @{x} and @{y} equal 0, PERMUTATIONA returns 1."
msgstr "Егер @{x} және @{y} екеуі де 0-ге тең болса, PERMUTATIONA 1-ді қайтарады."

#: ../plugins/fn-stat/functions.c:5009
msgid "If @{x} < 0 or @{y} < 0, PERMUTATIONA returns #NUM!"
msgstr "Егер @{x} < 0 немесе @{y} < 0 болса, PERMUTATIONA #NUM! мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:5010
msgid "If @{x} or @{y} are not integers, they are truncated."
msgstr "Егер @{x} немесе @{y} бүтін сандар болмаса, олар қиып тасталады."

#: ../plugins/fn-stat/functions.c:5036
msgid "LKSTEST:Lilliefors (Kolmogorov-Smirnov) Test of Normality"
msgstr "LKSTEST: Лиллиефорс (Колмогоров-Смирнов) нормальдік тесті"

#: ../plugins/fn-stat/functions.c:5037 ../plugins/fn-stat/functions.c:5155 ../plugins/fn-stat/functions.c:5240 ../plugins/fn-stat/functions.c:5324
msgid "x:array of sample values"
msgstr "x: таңдама мәндерінің массиві"

#: ../plugins/fn-stat/functions.c:5038
msgid "This function returns an array with the first row giving the p-value of the Lilliefors (Kolmogorov-Smirnov) Test, the second row the test statistic of the test, and the third the number of observations in the sample."
msgstr "Бұл функция массивті қайтарады, оның бірінші жолында Лиллиефорс (Колмогоров-Смирнов) тестінің p-мәні, екінші жолында тест статистикасы, ал үшінші жолында таңдамадағы бақылаулар саны беріледі."

#: ../plugins/fn-stat/functions.c:5040
msgid "If there are less than 5 sample values, LKSTEST returns #VALUE!"
msgstr "Егер 5-тен аз таңдама мәні болса, LKSTEST #VALUE! мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:5042
msgid "wiki:en:Lilliefors_test"
msgstr "wiki:en:Lilliefors_test"

#: ../plugins/fn-stat/functions.c:5154
msgid "SFTEST:Shapiro-Francia Test of Normality"
msgstr "SFTEST: Шапиро-Франсия нормальдік тесті"

#: ../plugins/fn-stat/functions.c:5156
msgid "This function returns an array with the first row giving the p-value of the Shapiro-Francia Test, the second row the test statistic of the test, and the third the number of observations in the sample."
msgstr "Бұл функция массивті қайтарады, оның бірінші жолында Шапиро-Франсия тестінің p-мәні, екінші жолында тест статистикасы, ал үшінші жолында таңдамадағы бақылаулар саны беріледі."

#: ../plugins/fn-stat/functions.c:5158
msgid "If there are less than 5 or more than 5000 sample values, SFTEST returns #VALUE!"
msgstr "Егер 5-тен аз немесе 5000-нан көп таңдама мәні болса, SFTEST #VALUE! мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:5239
msgid "CVMTEST:Cramér-von Mises Test of Normality"
msgstr "CVMTEST: Крамер-фон Мизес нормальдік тесті"

#: ../plugins/fn-stat/functions.c:5241
msgid "This function returns an array with the first row giving the p-value of the Cramér-von Mises Test, the second row the test statistic of the test, and the third the number of observations in the sample."
msgstr "Бұл функция массивті қайтарады, оның бірінші жолында Крамер-фон Мизес тестінің p-мәні, екінші жолында тест статистикасы, ал үшінші жолында таңдамадағы бақылаулар саны беріледі."

#: ../plugins/fn-stat/functions.c:5243
msgid "If there are less than 8 sample values, CVMTEST returns #VALUE!"
msgstr "Егер 8-ден аз таңдама мәні болса, CVMTEST #VALUE! мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:5245
msgid "wiki:en:Cramér–von-Mises_criterion"
msgstr "wiki:en:Cramér–von-Mises_criterion"

#: ../plugins/fn-stat/functions.c:5323
msgid "ADTEST:Anderson-Darling Test of Normality"
msgstr "ADTEST: Андерсон-Дарлинг нормальдік тесті"

#: ../plugins/fn-stat/functions.c:5325
msgid "This function returns an array with the first row giving the p-value of the Anderson-Darling Test, the second row the test statistic of the test, and the third the number of observations in the sample."
msgstr "Бұл функция массивті қайтарады, оның бірінші жолында Андерсон-Дарлинг тестінің p-мәні, екінші жолында тест статистикасы, ал үшінші жолында таңдамадағы бақылаулар саны беріледі."

#: ../plugins/fn-stat/functions.c:5327
msgid "If there are less than 8 sample values, ADTEST returns #VALUE!"
msgstr "Егер 8-ден аз таңдама мәні болса, ADTEST #VALUE! мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:5329
msgid "wiki:en:Anderson–Darling_test"
msgstr "wiki:en:Anderson–Darling_test"

#: ../plugins/fn-string/functions.c:54
msgid "CHAR:the CP1252 (Windows-1252) character for the code point @{x}"
msgstr "CHAR: @{x} кодтық нүктесі үшін CP1252 (Windows-1252) таңбасы"

#: ../plugins/fn-string/functions.c:55
msgid "x:code point"
msgstr "x: кодтық нүкте"

#: ../plugins/fn-string/functions.c:56
msgid "CHAR(@{x}) returns the CP1252 (Windows-1252) character with code @{x}."
msgstr "CHAR(@{x}) функциясы @{x} коды бар CP1252 (Windows-1252) таңбасын қайтарады."

#: ../plugins/fn-string/functions.c:57
msgid "@{x} must be in the range 1 to 255."
msgstr "@{x} мәні 1 мен 255 ауқымында болуы тиіс."

#: ../plugins/fn-string/functions.c:58 ../plugins/fn-string/functions.c:134
msgid "CP1252 (Windows-1252) is also known as the \"ANSI code page\", but it is not an ANSI standard."
msgstr "CP1252 (Windows-1252) сонымен қатар «ANSI кодтық беті» ретінде де белгілі, бірақ ол ANSI стандарты емес."

#: ../plugins/fn-string/functions.c:60
msgid "CP1252 (Windows-1252) is based on an early draft of ISO-8859-1, and contains all of its printable characters. It also contains all of ISO-8859-15's printable characters (but partially at different positions.)"
msgstr "CP1252 (Windows-1252) ISO-8859-1 стандартының ерте жобасына негізделген және оның барлық басып шығарылатын таңбаларын қамтиды. Ол сондай-ақ ISO-8859-15 стандартының барлық басып шығарылатын таңбаларын қамтиды (бірақ ішінара басқа орындарда)."

#: ../plugins/fn-string/functions.c:64 ../plugins/fn-string/functions.c:136
msgid "In CP1252 (Windows-1252), 129, 141, 143, 144, and 157 do not have matching characters."
msgstr "CP1252 (Windows-1252) ішінде 129, 141, 143, 144 және 157 кодтарының сәйкес таңбалары жоқ."

#: ../plugins/fn-string/functions.c:65 ../plugins/fn-string/functions.c:137
msgid "For @{x} from 1 to 255 except 129, 141, 143, 144, and 157 we have CODE(CHAR(@{x}))=@{x}."
msgstr "129, 141, 143, 144 және 157 кодтарынан басқа 1-ден 255-ке дейінгі @{x} мәндері үшін CODE(CHAR(@{x}))=@{x} теңдігі орындалады."

#: ../plugins/fn-string/functions.c:103
msgid "UNICHAR:the Unicode character represented by the Unicode code point @{x}"
msgstr "UNICHAR: @{x} Юникод кодтық нүктесімен берілген Юникод таңбасы"

#: ../plugins/fn-string/functions.c:104
msgid "x:Unicode code point"
msgstr "x: Юникод кодтық нүктесі"

#: ../plugins/fn-string/functions.c:131
msgid "CODE:the CP1252 (Windows-1252) code point for the character @{c}"
msgstr "CODE: @{c} таңбасы үшін CP1252 (Windows-1252) кодтық нүктесі"

#: ../plugins/fn-string/functions.c:132 ../plugins/fn-string/functions.c:177
msgid "c:character"
msgstr "c:таңба"

#: ../plugins/fn-string/functions.c:133
msgid "@{c} must be a valid CP1252 (Windows-1252) character."
msgstr "@{c} жарамды CP1252 (Windows-1252) таңбасы болуы тиіс."

#: ../plugins/fn-string/functions.c:135
msgid "CP1252 (Windows-1252) is based on an early draft of ISO-8859-1, and contains all of its printable characters (but partially at different positions.)"
msgstr "CP1252 (Windows-1252) ISO-8859-1 стандартының ерте жобасына негізделген және оның барлық басып шығарылатын таңбаларын қамтиды (бірақ ішінара басқа орындарда)."

#: ../plugins/fn-string/functions.c:176
msgid "UNICODE:the Unicode code point for the character @{c}"
msgstr "UNICODE: @{c} таңбасы үшін Юникод кодтық нүктесі"

#: ../plugins/fn-string/functions.c:246
msgid "EXACT:TRUE if @{string1} is exactly equal to @{string2}"
msgstr "EXACT: егер @{string1} мәні @{string2} мәніне дәл тең болса, TRUE"

#: ../plugins/fn-string/functions.c:247
msgid "string1:first string"
msgstr "string1:бірінші жол"

#: ../plugins/fn-string/functions.c:248
msgid "string2:second string"
msgstr "string2:екінші жол"

#: ../plugins/fn-string/functions.c:266
msgid "ENCODEURL:encode a string for use in a URL"
msgstr "ENCODEURL: жолды URL мекенжайында қолдану үшін кодтау"

#: ../plugins/fn-string/functions.c:267
msgid "string:string to encode"
msgstr "string: кодталатын жол"

#: ../plugins/fn-string/functions.c:283
msgid "LEN:the number of characters of the string @{s}"
msgstr "LEN: @{s} жолындағы таңбалар саны"

#: ../plugins/fn-string/functions.c:284 ../plugins/fn-string/functions.c:301 ../plugins/fn-string/functions.c:319 ../plugins/fn-string/functions.c:351 ../plugins/fn-string/functions.c:403 ../plugins/fn-string/functions.c:443 ../plugins/fn-string/functions.c:530 ../plugins/fn-string/functions.c:566
msgid "s:the string"
msgstr "s:жол"

#: ../plugins/fn-string/functions.c:300
msgid "LENB:the number of bytes in the string @{s}"
msgstr "LENB: @{s} жолындағы байттар саны"

#: ../plugins/fn-string/functions.c:318
msgid "LEFT:the first @{num_chars} characters of the string @{s}"
msgstr "LEFT: @{s} жолының алғашқы @{num_chars} таңбасы"

#: ../plugins/fn-string/functions.c:320 ../plugins/fn-string/functions.c:531
msgid "num_chars:the number of characters to return (defaults to 1)"
msgstr "num_chars: қайтарылатын таңбалар саны (үнсіз келісім бойынша 1)"

#: ../plugins/fn-string/functions.c:321
msgid "If the string @{s} is in a right-to-left script, the returned first characters are from the right of the string."
msgstr "Егер @{s} жолы оңнан солға қарай жазылатын жазуда болса, қайтарылатын алғашқы таңбалар жолдың оң жағынан алынады."

#: ../plugins/fn-string/functions.c:350
msgid "LEFTB:the first characters of the string @{s} comprising at most @{num_bytes} bytes"
msgstr "LEFTB: @{s} жолының ең көп дегенде @{num_bytes} байттан тұратын алғашқы таңбалары"

#: ../plugins/fn-string/functions.c:352 ../plugins/fn-string/functions.c:445 ../plugins/fn-string/functions.c:567
msgid "num_bytes:the maximum number of bytes to return (defaults to 1)"
msgstr "num_bytes: қайтарылатын байттардың максималды саны (үнсіз келісім бойынша 1)"

#: ../plugins/fn-string/functions.c:353 ../plugins/fn-string/functions.c:446 ../plugins/fn-string/functions.c:568 ../plugins/fn-string/functions.c:1012 ../plugins/fn-string/functions.c:1478
msgid "The semantics of this function is subject to change as various applications implement it."
msgstr "Түрлі қолданбалардың іске асыруына байланысты бұл функцияның семантикасы өзгеруі мүмкін."

#: ../plugins/fn-string/functions.c:354
msgid "If the string is in a right-to-left script, the returned first characters are from the right of the string."
msgstr "Егер жол оңнан солға қарай жазылатын жазуда болса, қайтарылатын алғашқы таңбалар жолдың оң жағынан алынады."

#: ../plugins/fn-string/functions.c:355 ../plugins/fn-string/functions.c:447 ../plugins/fn-string/functions.c:491 ../plugins/fn-string/functions.c:570 ../plugins/fn-string/functions.c:1013 ../plugins/fn-string/functions.c:1479
msgid "While this function is syntactically Excel compatible, the differences in the underlying text encoding will usually yield different results."
msgstr "Бұл функция Excel бағдарламасымен синтаксистік жағынан үйлесімді болғанымен, мәтінді кодтаудың айырмашылықтары әдетте әртүрлі нәтижелерге әкеледі."

#: ../plugins/fn-string/functions.c:356 ../plugins/fn-string/functions.c:449 ../plugins/fn-string/functions.c:493 ../plugins/fn-string/functions.c:571 ../plugins/fn-string/functions.c:1015 ../plugins/fn-string/functions.c:1481
msgid "While this function is OpenFormula compatible, most of its behavior is, at this time, implementation specific."
msgstr "Бұл функция OpenFormula стандартымен үйлесімді болғанымен, қазіргі уақытта оның мінез-құлқының көп бөлігі іске асыруға байланысты."

#: ../plugins/fn-string/functions.c:384
msgid "LOWER:a lower-case version of the string @{text}"
msgstr "LOWER: @{text} жолының кіші әріпті нұсқасы"

#: ../plugins/fn-string/functions.c:402
msgid "MID:the substring of the string @{s} starting at position @{position} consisting of @{length} characters"
msgstr "MID: @{s} жолының @{position} позициясынан басталатын @{length} таңбадан тұратын бөлігі"

#: ../plugins/fn-string/functions.c:404
msgid "position:the starting position"
msgstr "position: бастапқы позиция"

#: ../plugins/fn-string/functions.c:405
msgid "length:the number of characters to return"
msgstr "length: қайтарылатын таңбалар саны"

#: ../plugins/fn-string/functions.c:442
msgid "MIDB:the characters following the first @{start_pos} bytes comprising at most @{num_bytes} bytes"
msgstr "MIDB: алғашқы @{start_pos} байттан кейінгі ең көп дегенде @{num_bytes} байттан тұратын таңбалар"

#: ../plugins/fn-string/functions.c:444
msgid "start_pos:the number of the byte with which to start (defaults to 1)"
msgstr "start_pos: басталатын байттың нөмірі (үнсіз келісім бойынша 1)"

#: ../plugins/fn-string/functions.c:486
msgid "FINDB:first byte position of @{string1} in @{string2} following byte position @{start}"
msgstr "FINDB: @{start} байт позициясынан кейінгі @{string2} ішіндегі @{string1} жолының бірінші байт позициясы"

#: ../plugins/fn-string/functions.c:487 ../plugins/fn-string/functions.c:814
msgid "string1:search string"
msgstr "string1: іздеу жолы"

#: ../plugins/fn-string/functions.c:488 ../plugins/fn-string/functions.c:815
msgid "string2:search field"
msgstr "string2: іздеу өрісі"

#: ../plugins/fn-string/functions.c:489 ../plugins/fn-string/functions.c:1468
msgid "start:starting byte position, defaults to 1"
msgstr "start: бастапқы байт позициясы, үнсіз келісім бойынша 1"

#: ../plugins/fn-string/functions.c:490 ../plugins/fn-string/functions.c:817
msgid "This search is case-sensitive."
msgstr "Бұл іздеу регистрге тәуелді."

#: ../plugins/fn-string/functions.c:529
msgid "RIGHT:the last @{num_chars} characters of the string @{s}"
msgstr "RIGHT: @{s} жолының соңғы @{num_chars} таңбасы"

#: ../plugins/fn-string/functions.c:532 ../plugins/fn-string/functions.c:569
msgid "If the string @{s} is in a right-to-left script, the returned last characters are from the left of the string."
msgstr "Егер @{s} жолы оңнан солға қарай жазылатын жазуда болса, қайтарылатын соңғы таңбалар жолдың сол жағынан алынады."

#: ../plugins/fn-string/functions.c:565
msgid "RIGHTB:the last characters of the string @{s} comprising at most @{num_bytes} bytes"
msgstr "RIGHTB: @{s} жолының ең көп дегенде @{num_bytes} байттан тұратын соңғы таңбалары"

#: ../plugins/fn-string/functions.c:600
msgid "UPPER:an upper-case version of the string @{text}"
msgstr "UPPER: @{text} жолының бас әріпті нұсқасы"

#: ../plugins/fn-string/functions.c:619
msgid "CONCATENATE:the concatenation of the strings @{s1}, @{s2},…"
msgstr "CONCATENATE: @{s1}, @{s2},… жолдарын біріктіру"

#: ../plugins/fn-string/functions.c:620 ../plugins/fn-string/functions.c:641 ../plugins/fn-string/functions.c:662
msgid "s1:first string"
msgstr "s1:бірінші жол"

#: ../plugins/fn-string/functions.c:621 ../plugins/fn-string/functions.c:642 ../plugins/fn-string/functions.c:663
msgid "s2:second string"
msgstr "s2:екінші жол"

#: ../plugins/fn-string/functions.c:640
msgid "CONCAT:the concatenation of the strings @{s1}, @{s2},…"
msgstr "CONCAT: @{s1}, @{s2},… жолдарын біріктіру"

#: ../plugins/fn-string/functions.c:645
msgid "This function is identical to CONCATENATE"
msgstr "Бұл функция CONCATENATE функциясымен бірдей"

#: ../plugins/fn-string/functions.c:659
msgid "TEXTJOIN:the concatenation of the strings @{s1}, @{s2},… delimited by @{del}"
msgstr "TEXTJOIN: @{del} ажыратқышымен бөлінген @{s1}, @{s2},… жолдарын біріктіру"

#: ../plugins/fn-string/functions.c:660
msgid "del:delimiter"
msgstr "del: ажыратқыш"

#: ../plugins/fn-string/functions.c:661
msgid "blank:ignore blanks"
msgstr "blank: бос орындарды елемеу"

#: ../plugins/fn-string/functions.c:740
msgid "REPT:@{num} repetitions of string @{text}"
msgstr "REPT: @{text} жолының @{num} рет қайталануы"

#: ../plugins/fn-string/functions.c:742
msgid "num:non-negative integer"
msgstr "num:теріс емес бүтін сан"

#: ../plugins/fn-string/functions.c:784
msgid "CLEAN:@{text} with any non-printable characters removed"
msgstr "CLEAN: барлық басып шығарылмайтын таңбалары өшірілген @{text} жолы"

#: ../plugins/fn-string/functions.c:786
msgid "CLEAN removes non-printable characters from its argument leaving only regular characters and white-space."
msgstr "CLEAN функциясы аргументтен басып шығарылмайтын таңбаларды өшіріп, тек қана қарапайым таңбалар мен бос орындарды қалдырады."

#: ../plugins/fn-string/functions.c:813
msgid "FIND:first position of @{string1} in @{string2} following position @{start}"
msgstr "FIND: @{start} позициясынан кейінгі @{string2} ішіндегі @{string1} жолының бірінші позициясы"

#: ../plugins/fn-string/functions.c:816 ../plugins/fn-string/functions.c:1425
msgid "start:starting position, defaults to 1"
msgstr "start: бастапқы позиция, үнсіз келісім бойынша 1"

#: ../plugins/fn-string/functions.c:851
msgid "FIXED:formatted string representation of @{num}"
msgstr "FIXED: @{num} санының пішімделген жол түріндегі көрінісі"

#: ../plugins/fn-string/functions.c:852 ../plugins/fn-string/functions.c:1350
msgid "num:number"
msgstr "num:сан"

#: ../plugins/fn-string/functions.c:853
msgid "decimals:number of decimals"
msgstr "decimals: ондық таңбалар саны"

#: ../plugins/fn-string/functions.c:854
msgid "no_commas:TRUE if no thousand separators should be used, defaults to FALSE"
msgstr "no_commas: егер мыңдық ажыратқыштар қолданылмаса, TRUE, үнсіз келісім бойынша FALSE"

#: ../plugins/fn-string/functions.c:911
msgid "PROPER:@{text} with initial of each word capitalised"
msgstr "PROPER: әр сөздің бірінші әрпі бас әріпке өзгертілген @{text}"

#: ../plugins/fn-string/functions.c:953
msgid "REPLACE:string @{old} with @{num} characters starting at @{start} replaced by @{new}"
msgstr "REPLACE: @{start} позициясынан басталатын @{num} таңбасы @{new} жолына ауыстырылған @{old} жолы"

#: ../plugins/fn-string/functions.c:955 ../plugins/fn-string/functions.c:1006
msgid "old:original text"
msgstr "old:бастапқы мәтін"

#: ../plugins/fn-string/functions.c:956
msgid "start:starting position"
msgstr "start: бастапқы позиция"

#: ../plugins/fn-string/functions.c:957
msgid "num:number of characters to be replaced"
msgstr "num: ауыстырылатын таңбалар саны"

#: ../plugins/fn-string/functions.c:958 ../plugins/fn-string/functions.c:1009 ../plugins/fn-string/functions.c:1278
msgid "new:replacement string"
msgstr "new: ауыстыру жолы"

#: ../plugins/fn-string/functions.c:1004
msgid "REPLACEB:string @{old} with up to @{num} bytes starting at @{start} replaced by @{new}"
msgstr "REPLACEB: @{start} байтынан басталатын @{num} байтқа дейінгі бөлігі @{new} жолына ауыстырылған @{old} жолы"

#: ../plugins/fn-string/functions.c:1007
msgid "start:starting byte position"
msgstr "start: бастапқы байт позициясы"

#: ../plugins/fn-string/functions.c:1008
msgid "num:number of bytes to be replaced"
msgstr "num: ауыстырылатын байттар саны"

#: ../plugins/fn-string/functions.c:1010
msgid "REPLACEB replaces the string of valid unicode characters starting at the byte @{start} and ending at @{start}+@{num}-1 with the string @{new}."
msgstr "REPLACEB функциясы @{start} байтынан басталып, @{start}+@{num}-1 байтымен аяқталатын жарамды юникод таңбаларының жолын @{new} жолына ауыстырады."

#: ../plugins/fn-string/functions.c:1059
msgid "T:@{value} if and only if @{value} is text, otherwise empty"
msgstr "T: егер @{value} мәні мәтін болса ғана сол мәнді қайтарады, әйтпесе бос болады"

#: ../plugins/fn-string/functions.c:1060
msgid "value:original value"
msgstr "value:бастапқы мәні"

#: ../plugins/fn-string/functions.c:1082
msgid "TEXT:@{value} as a string formatted as @{format}"
msgstr "TEXT: @{format} ретінде пішімделген жол түріндегі @{value} мәні"

#: ../plugins/fn-string/functions.c:1083
msgid "value:value to be formatted"
msgstr "value:пішімделетін мән"

#: ../plugins/fn-string/functions.c:1084
msgid "format:desired format"
msgstr "format:керек пішім"

#: ../plugins/fn-string/functions.c:1136
msgid "TRIM:@{text} with only single spaces between words"
msgstr "TRIM: сөздер арасында тек жалғыз бос орын қалдырылған @{text} жолы"

#: ../plugins/fn-string/functions.c:1183
msgid "VALUE:numeric value of @{text}"
msgstr "VALUE: @{text} жолының сандық мәні"

#: ../plugins/fn-string/functions.c:1216
msgid "NUMBERVALUE:numeric value of @{text}"
msgstr "NUMBERVALUE: @{text} жолының сандық мәні"

#: ../plugins/fn-string/functions.c:1218
msgid "separator:decimal separator"
msgstr "separator: ондық ажыратқыш"

#: ../plugins/fn-string/functions.c:1219
msgid "If @{text} does not look like a decimal number, NUMBERVALUE returns the value VALUE would return (ignoring the given @{separator})."
msgstr "Егер @{text} ондық санға ұқсамаса, NUMBERVALUE функциясы VALUE функциясы қайтаратын мәнді қайтарады (берілген @{separator} ажыратқышы ескерілмейді)."

#: ../plugins/fn-string/functions.c:1275
msgid "SUBSTITUTE:@{text} with all occurrences of @{old} replaced by @{new}"
msgstr "SUBSTITUTE: @{old} мәнінің барлық кездесулері @{new} мәніне ауыстырылған @{text} жолы"

#: ../plugins/fn-string/functions.c:1276 ../plugins/fn-string/functions.c:1660
msgid "text:original text"
msgstr "text:бастапқы мәтін"

#: ../plugins/fn-string/functions.c:1277
msgid "old:string to be replaced"
msgstr "old:алмастырылатын жол"

#: ../plugins/fn-string/functions.c:1279
msgid "num:if @{num} is specified and a number only the @{num}th occurrence of @{old} is replaced"
msgstr "num: егер @{num} көрсетілсе және ол сан болса, онда @{old} мәнінің тек @{num}-ші кездесуі ғана ауыстырылады"

#: ../plugins/fn-string/functions.c:1349
msgid "DOLLAR:@{num} formatted as currency"
msgstr "DOLLAR: валюта ретінде пішімделген @{num}"

#: ../plugins/fn-string/functions.c:1351
msgid "decimals:decimals"
msgstr "decimals: ондық таңбалар"

#: ../plugins/fn-string/functions.c:1421
msgid "SEARCH:the location of the @{search} string within @{text} after position @{start}"
msgstr "SEARCH: @{start} позициясынан кейінгі @{text} ішіндегі @{search} жолының орны"

#: ../plugins/fn-string/functions.c:1423 ../plugins/fn-string/functions.c:1466
msgid "search:search string"
msgstr "search:жолды іздеу"

#: ../plugins/fn-string/functions.c:1424 ../plugins/fn-string/functions.c:1467
msgid "text:search field"
msgstr "text:іздеу өрісі"

#: ../plugins/fn-string/functions.c:1426 ../plugins/fn-string/functions.c:1469
msgid "@{search} may contain wildcard characters (*) and question marks (?). A question mark matches any single character, and a wildcard matches any string including the empty string. To search for * or ?, precede the symbol with ~."
msgstr "@{search} құрамында алмастыру таңбалары (*) және сұрақ белгілері (?) болуы мүмкін. Сұрақ белгісі кез келген жалғыз таңбаға сәйкес келеді, ал жұлдызша кез келген жолға, соның ішінде бос жолға сәйкес келеді. * немесе ? белгілерін іздеу үшін таңба алдына ~ белгісін қойыңыз."

#: ../plugins/fn-string/functions.c:1431 ../plugins/fn-string/functions.c:1474
msgid "This search is not case sensitive."
msgstr "Бұл іздеу регистрге тәуелсіз."

#: ../plugins/fn-string/functions.c:1432
msgid "If @{search} is not found, SEARCH returns #VALUE!"
msgstr "Егер @{search} табылмаса, SEARCH #VALUE! мәнін қайтарады."

#: ../plugins/fn-string/functions.c:1433
msgid "If @{start} is less than one or it is greater than the length of @{text}, SEARCH returns #VALUE!"
msgstr "Егер @{start} бірден кіші немесе ол @{text} ұзындығынан үлкен болса, SEARCH #VALUE! мәнін қайтарады."

#: ../plugins/fn-string/functions.c:1464
msgid "SEARCHB:the location of the @{search} string within @{text} after byte position @{start}"
msgstr "SEARCHB: @{start} байт позициясынан кейінгі @{text} ішіндегі @{search} жолының орны"

#: ../plugins/fn-string/functions.c:1475
msgid "If @{search} is not found, SEARCHB returns #VALUE!"
msgstr "Егер @{search} табылмаса, SEARCHB #VALUE! мәнін қайтарады."

#: ../plugins/fn-string/functions.c:1476
msgid "If @{start} is less than one or it is greater than the byte length of @{text}, SEARCHB returns #VALUE!"
msgstr "Егер @{start} бірден кіші немесе ол @{text} байт ұзындығынан үлкен болса, SEARCHB #VALUE! мәнін қайтарады."

#: ../plugins/fn-string/functions.c:1532
msgid "ASC:text with full-width katakana and ASCII characters converted to half-width"
msgstr "ASC: толық енді катакана және ASCII таңбалары жарты енді таңбаларға түрлендірілген мәтін"

#: ../plugins/fn-string/functions.c:1534
msgid "ASC converts full-width katakana and ASCII characters to half-width equivalent characters, copying all others."
msgstr "ASC толық енді катакана және ASCII таңбаларын жарты енді баламалы таңбаларға түрлендіреді, ал қалғандарын өзгеріссіз қалдырады."

#: ../plugins/fn-string/functions.c:1535 ../plugins/fn-string/functions.c:1663
msgid "The distinction between half-width and full-width characters is described in http://www.unicode.org/reports/tr11/."
msgstr "Жарты енді және толық енді таңбалар арасындағы айырмашылық http://www.unicode.org/reports/tr11/ адресінде сипатталған."

#: ../plugins/fn-string/functions.c:1536 ../plugins/fn-string/functions.c:1665
msgid "For most strings, this function has the same effect as in Excel."
msgstr "Көптеген жолдар үшін бұл функцияның әсері Excel-дегідей болады."

#: ../plugins/fn-string/functions.c:1537
msgid "While in obsolete encodings ASC used to translate between 2-byte and 1-byte characters, this is not the case in UTF-8."
msgstr "Ескірген кодтауларда ASC 2-байттық және 1-байттық таңбалар арасында аудару үшін қолданылса, UTF-8 кодтауында бұлай емес."

#: ../plugins/fn-string/functions.c:1659
msgid "JIS:text with half-width katakana and ASCII characters converted to full-width"
msgstr "JIS: жарты енді катакана және ASCII таңбалары толық енді таңбаларға түрлендірілген мәтін"

#: ../plugins/fn-string/functions.c:1661
msgid "JIS converts half-width katakana and ASCII characters to full-width equivalent characters, copying all others."
msgstr "JIS жарты енді катакана және ASCII таңбаларын толық енді баламалы таңбаларға түрлендіреді, ал қалғандарын өзгеріссіз қалдырады."

#: ../plugins/fn-string/functions.c:1666
msgid "While in obsolete encodings JIS used to translate between 1-byte and 2-byte characters, this is not the case in UTF-8."
msgstr "Ескірген кодтауларда JIS 1-байттық және 2-байттық таңбалар арасында аудару үшін қолданылса, UTF-8 кодтауында бұлай емес."

#: ../plugins/fn-tsa/functions.c:80
msgid ""
"Possible interpolation methods are:\n"
"0: linear;\n"
"1: linear with averaging;\n"
"2: staircase;\n"
"3: staircase with averaging;\n"
"4: natural cubic spline;\n"
"5: natural cubic spline with averaging."
msgstr ""
"Мүмкін интерполяция әдістері:\n"
"0: сызықтық;\n"
"1: орташалау арқылы сызықтық;\n"
"2: сатылы;\n"
"3: орташалау арқылы сатылы;\n"
"4: табиғи кубтық сплайн;\n"
"5: орташалау арқылы табиғи кубтық сплайн."

#: ../plugins/fn-tsa/functions.c:365
msgid "INTERPOLATION:interpolated values corresponding to the given abscissa targets"
msgstr "INTERPOLATION: берілген абсцисса мақсаттарына сәйкес келетін интерполяцияланған мәндер"

#: ../plugins/fn-tsa/functions.c:366
msgid "abscissae:abscissae of the given data points"
msgstr "abscissae: берілген деректер нүктелерінің абсциссалары"

#: ../plugins/fn-tsa/functions.c:367
msgid "ordinates:ordinates of the given data points"
msgstr "ordinates: берілген деректер нүктелерінің ординаталары"

#: ../plugins/fn-tsa/functions.c:368
msgid "targets:abscissae of the interpolated data"
msgstr "targets: интерполяцияланған деректердің абсциссалары"

#: ../plugins/fn-tsa/functions.c:369
msgid "interpolation:method of interpolation, defaults to 0 ('linear')"
msgstr "interpolation: интерполяция әдісі, үнсіз келісім бойынша 0 ('linear')"

#: ../plugins/fn-tsa/functions.c:370 ../plugins/fn-tsa/functions.c:559
msgid "The output consists always of one column of numbers."
msgstr "Шығыс әрқашан сандардың бір бағанынан тұрады."

#: ../plugins/fn-tsa/functions.c:372
msgid "The @{abscissae} should be given in increasing order. If the @{abscissae} is not in increasing order the INTERPOLATION function is significantly slower."
msgstr "@{abscissae} мәндері өсу ретімен берілуі тиіс. Егер @{abscissae} өсу ретімен болмаса, INTERPOLATION функциясы айтарлықтай баяу жұмыс істейді."

#: ../plugins/fn-tsa/functions.c:374
msgid "If any two @{abscissae} values are equal an error is returned."
msgstr "Егер кез келген екі @{abscissae} мәні тең болса, қате қайтарылады."

#: ../plugins/fn-tsa/functions.c:375
msgid "If any of interpolation methods 1 ('linear with averaging'), 3 ('staircase with averaging'), and 5 ('natural cubic spline with averaging') is used, the number of returned values is one less than the number of targets and the target values must be given in increasing order. The values returned are the average heights of the interpolation function on the intervals determined by consecutive target values."
msgstr "Егер 1 ('орташалау арқылы сызықтық'), 3 ('орташалау арқылы сатылы') және 5 ('орташалау арқылы табиғи кубтық сплайн') интерполяция әдістерінің біреуі қолданылса, қайтарылатын мәндер саны нысаналардан біреуге аз болады және нысана мәндері өсу ретімен берілуі тиіс. Қайтарылатын мәндер — қатар келген нысана мәндерімен анықталатын аралықтардағы интерполяция функциясының орташа биіктіктері."

#: ../plugins/fn-tsa/functions.c:382 ../plugins/fn-tsa/functions.c:566
msgid "Strings and empty cells in @{abscissae} and @{ordinates} are ignored."
msgstr "@{abscissae} және @{ordinates} ішіндегі жолдар мен бос ұяшықтар ескерілмейді."

#: ../plugins/fn-tsa/functions.c:383 ../plugins/fn-tsa/functions.c:567
msgid "If several target data are provided they must be in the same column in consecutive cells."
msgstr "Егер бірнеше нысана деректері берілсе, олар бір бағандағы қатар орналасқан ұяшықтарда болуы тиіс."

#: ../plugins/fn-tsa/functions.c:552
msgid "PERIODOGRAM:periodogram of the given data"
msgstr "PERIODOGRAM: берілген деректердің периодограммасы"

#: ../plugins/fn-tsa/functions.c:553
msgid "ordinates:ordinates of the given data"
msgstr "ordinates: берілген деректердің ординаталары"

#: ../plugins/fn-tsa/functions.c:554
msgid "filter:windowing function to be used, defaults to no filter"
msgstr "filter: қолданылатын терезелік функция, үнсіз келісім бойынша сүзгісіз"

#: ../plugins/fn-tsa/functions.c:555
msgid "abscissae:abscissae of the given data, defaults to regularly spaced abscissae"
msgstr "abscissae: берілген деректердің абсциссалары, үнсіз келісім бойынша біркелкі орналасқан абсциссалар"

#: ../plugins/fn-tsa/functions.c:556
msgid "interpolation:method of interpolation, defaults to none"
msgstr "interpolation: интерполяция әдісі, үнсіз келісім бойынша жоқ"

#: ../plugins/fn-tsa/functions.c:557
msgid "number:number of interpolated data points"
msgstr "number: интерполяцияланған деректер нүктелерінің саны"

#: ../plugins/fn-tsa/functions.c:558
msgid "If an interpolation method is used, the number of returned values is one less than the number of targets and the targets values must be given in increasing order."
msgstr "Егер интерполяция әдісі қолданылса, қайтарылатын мәндер саны нысаналардан біреуге аз болады және нысана мәндері өсу ретімен берілуі тиіс."

#: ../plugins/fn-tsa/functions.c:561
msgid ""
"Possible window functions are:\n"
"0: no filter (rectangular window)\n"
"1: Bartlett (triangular window)\n"
"2: Hahn (cosine window)\n"
"3: Welch (parabolic window)"
msgstr ""
"Мүмкін терезелік функциялар:\n"
"0: сүзгі жоқ (тікбұрышты терезе)\n"
"1: Bartlett (үшбұрышты терезе)\n"
"2: Hahn (косинустық терезе)\n"
"3: Welch (parabolic window)"

#: ../plugins/fn-tsa/functions.c:811
msgid "FOURIER:Fourier or inverse Fourier transform"
msgstr "FOURIER: Фурье немесе кері Фурье түрлендіруі"

#: ../plugins/fn-tsa/functions.c:812 ../plugins/fn-tsa/functions.c:908
msgid "Sequence:the data sequence to be transformed"
msgstr "Sequence: түрлендірілетін деректер тізбегі"

#: ../plugins/fn-tsa/functions.c:813
msgid "Inverse:if true, the inverse Fourier transform is calculated, defaults to false"
msgstr "Inverse: егер ақиқат болса, кері Фурье түрлендіруі есептеледі, үнсіз келісім бойынша жалған"

#: ../plugins/fn-tsa/functions.c:814
msgid "Separate:if true, the real and imaginary parts are given separately, defaults to false"
msgstr "Separate: егер ақиқат болса, нақты және жорамал бөліктер бөлек беріледі, үнсіз келісім бойынша жалған"

#: ../plugins/fn-tsa/functions.c:815
msgid "This array function returns the Fourier or inverse Fourier transform of the given data sequence."
msgstr "Бұл массивтік функция берілген деректер тізбегінің Фурье немесе кері Фурье түрлендіруін қайтарады."

#: ../plugins/fn-tsa/functions.c:816
msgid "The output consists of one column of complex numbers if @{Separate} is false and of two columns of real numbers if @{Separate} is true."
msgstr "Егер @{Separate} жалған болса, шығыс кешенді сандардың бір бағанынан тұрады, ал егер @{Separate} ақиқат болса, нақты сандардың екі бағанынан тұрады."

#: ../plugins/fn-tsa/functions.c:817
msgid "If @{Separate} is true the first output column contains the real parts and the second column the imaginary parts."
msgstr "Егер @{Separate} ақиқат болса, бірінші шығыс бағанында нақты бөліктер, ал екінші бағанда жорамал бөліктер болады."

#: ../plugins/fn-tsa/functions.c:818 ../plugins/fn-tsa/functions.c:912
msgid "If @{Sequence} is neither an n by 1 nor 1 by n array, this function returns #VALUE!"
msgstr "Егер @{Sequence} n-нің 1-ге немесе 1-дің n-ге массиві болмаса, бұл функция #VALUE! мәнін қайтарады."

#: ../plugins/fn-tsa/functions.c:907
msgid "HPFILTER:Hodrick Prescott Filter"
msgstr "HPFILTER: Ходрик-Прескотт сүзгісі"

#: ../plugins/fn-tsa/functions.c:909
msgid "λ:filter parameter λ, defaults to 1600"
msgstr "λ: λ сүзгі параметрі, үнсіз келісім бойынша 1600"

#: ../plugins/fn-tsa/functions.c:910
msgid "This array function returns the trend and cyclical components obtained by applying the Hodrick Prescott Filter with parameter @{λ} to the given data sequence."
msgstr "Бұл массивтік функция берілген деректер тізбегіне @{λ} параметрімен Ходрик-Прескотт сүзгісін қолдану арқылы алынған тренд және циклдік компоненттерді қайтарады."

#: ../plugins/fn-tsa/functions.c:911
msgid "The output consists of two columns of numbers, the first containing the trend component, the second the cyclical component."
msgstr "Шығыс сандардың екі бағанынан тұрады: біріншісінде тренд компоненті, екіншісінде циклдік компонент болады."

#: ../plugins/fn-tsa/functions.c:913
msgid "If @{Sequence} contains less than 6 numerical values, this function returns #VALUE!"
msgstr "Егер @{Sequence} ішінде 6-дан аз сандық мән болса, бұл функция #VALUE! мәнін қайтарады."

#: ../plugins/gda/plugin-gda.c:372
msgid "EXECSQL:result of executing @{sql} in the libgda data source @{dsn}"
msgstr "EXECSQL: @{dsn} libgda дереккөзінде @{sql} сұранысын орындау нәтижесі"

#: ../plugins/gda/plugin-gda.c:374 ../plugins/gda/plugin-gda.c:450
msgid "dsn:libgda data source"
msgstr "dsn: libgda дереккөзі"

#: ../plugins/gda/plugin-gda.c:375 ../plugins/gda/plugin-gda.c:451
msgid "username:user name to access @{dsn}"
msgstr "username: @{dsn} дереккөзіне қол жеткізу үшін пайдаланушы аты"

#: ../plugins/gda/plugin-gda.c:376 ../plugins/gda/plugin-gda.c:452
msgid "password:password to access @{dsn} as @{username}"
msgstr "password: @{dsn} дереккөзіне @{username} ретінде қол жеткізу үшін пароль"

#: ../plugins/gda/plugin-gda.c:377
msgid "sql:SQL command"
msgstr "sql:SQL командасы"

#: ../plugins/gda/plugin-gda.c:378 ../plugins/gda/plugin-gda.c:454
msgid "Before using EXECSQL, you need to set up a libgda data source."
msgstr "EXECSQL функциясын қолданбас бұрын libgda дереккөзін орнату қажет."

#: ../plugins/gda/plugin-gda.c:449
msgid "READDBTABLE:all rows of the table @{table} in @{dsn}"
msgstr "READDBTABLE: @{dsn} ішіндегі @{table} кестесінің барлық жолдары"

#: ../plugins/gda/plugin-gda.c:453
msgid "table:SQL table to retrieve"
msgstr "table:шығару үшін SQL кестесі"

#: ../plugins/sample_datasource/sample_datasource.c:224
msgid "ATL_LAST:sample real-time data source"
msgstr "ATL_LAST: нақты уақыттағы дереккөз үлгісі"

#: ../plugins/sample_datasource/sample_datasource.c:225
msgid "tag:tag to watch"
msgstr "tag: бақыланатын тег"

#: ../plugins/sample_datasource/sample_datasource.c:226
msgid "ATL_LAST is a sample implementation of a real time data source.  It takes a string tag and monitors the named pipe ~/atl for changes to the value of that tag."
msgstr "ATL_LAST — нақты уақыттағы дереккөздің іске асырылу үлгісі. Ол жолдық тегті қабылдайды және осы тег мәніндегі өзгерістерді ~/atl аталған арнасы (named pipe) арқылы бақылайды."

#: ../plugins/sample_datasource/sample_datasource.c:227
msgid "This is not intended to be generally enabled and is OFF by default."
msgstr "Бұл жалпы қосуға арналмаған және үнсіз келісім бойынша ӨШІРУЛІ."
