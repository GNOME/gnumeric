#: ../plugins/fn-financial/functions.c:452
msgid "par:par value"
msgstr "par: номиналды құны"

#: ../plugins/fn-financial/functions.c:454
msgid "ACCRINTM calculates the accrued interest from @{issue} to @{maturity}."
msgstr "ACCRINTM @{issue} бастап @{maturity} дейінгі есептелген пайыздарды есептейді."

#: ../plugins/fn-financial/functions.c:455
msgid "@{par} defaults to $1000."
msgstr "@{par} үнсіз келісім бойынша $1000."

#: ../plugins/fn-financial/functions.c:487
msgid "INTRATE:interest rate"
msgstr "INTRATE: пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:490 ../plugins/fn-financial/functions.c:528
msgid "investment:amount paid on settlement"
msgstr "investment: есеп айырысу кезінде төленген сома"

#: ../plugins/fn-financial/functions.c:491 ../plugins/fn-financial/functions.c:570 ../plugins/fn-financial/functions.c:651 ../plugins/fn-financial/functions.c:2262 ../plugins/fn-financial/functions.c:2312 ../plugins/fn-financial/functions.c:2420 ../plugins/fn-financial/functions.c:2507 ../plugins/fn-financial/functions.c:2658 ../plugins/fn-financial/functions.c:2753 ../plugins/fn-financial/functions.c:2831
msgid "redemption:amount received at maturity"
msgstr "redemption: өтеу кезінде алынған сома"

#: ../plugins/fn-financial/functions.c:493
msgid "INTRATE calculates the interest of a fully vested security."
msgstr "INTRATE толық кепілдендірілген бағалы қағаздың пайызын есептейді."

#: ../plugins/fn-financial/functions.c:525
msgid "RECEIVED:amount to be received at maturity"
msgstr "RECEIVED: өтеу мерзімінде алынатын сома"

#: ../plugins/fn-financial/functions.c:531
msgid "RECEIVED calculates the amount to be received when a security matures."
msgstr "RECEIVED бағалы қағаздың өтеу мерзімі жеткенде алынатын соманы есептейді."

#: ../plugins/fn-financial/functions.c:566
msgid "PRICEDISC:discounted price"
msgstr "PRICEDISC: дисконтталған баға"

#: ../plugins/fn-financial/functions.c:569 ../plugins/fn-financial/functions.c:606 ../plugins/fn-financial/functions.c:1088 ../plugins/fn-financial/functions.c:1126
msgid "discount:annual rate at which to discount"
msgstr "discount: дисконттаудың жылдық мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:572
msgid "PRICEDISC calculates the price per $100 face value of a bond that does not pay interest at maturity."
msgstr "PRICEDISC өтеу мерзімінде пайыздарды төлемейтін облигацияның әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:602
msgid "PRICEMAT:price at maturity"
msgstr "PRICEMAT: өтеу мерзіміндегі баға"

#: ../plugins/fn-financial/functions.c:607 ../plugins/fn-financial/functions.c:1896 ../plugins/fn-financial/functions.c:2261 ../plugins/fn-financial/functions.c:2506 ../plugins/fn-financial/functions.c:2752 ../plugins/fn-financial/functions.c:3245
msgid "yield:annual yield of security"
msgstr "yield: бағалы қағаздың жылдық кірістілігі"

#: ../plugins/fn-financial/functions.c:609
msgid "PRICEMAT calculates the price per $100 face value of a bond that pays interest at maturity."
msgstr "PRICEMAT өтеу мерзімінде пайыздарды төлейтін облигацияның әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:647
msgid "DISC:discount rate"
msgstr "DISC: дисконттау мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:650
msgid "par:price per $100 face value"
msgstr "par: әр $100 номиналды құнына шаққандағы баға"

#: ../plugins/fn-financial/functions.c:653
msgid "DISC calculates the discount rate for a security."
msgstr "DISC бағалы қағаз үшін дисконттау мөлшерлемесін есептейді."

#: ../plugins/fn-financial/functions.c:654
msgid "@{redemption} is the redemption value per $100 face value."
msgstr "@{redemption} — әр $100 номиналды құнына шаққандағы өтеу құны."

#: ../plugins/fn-financial/functions.c:685
msgid "EFFECT:effective interest rate"
msgstr "EFFECT: тиімді пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:687 ../plugins/fn-financial/functions.c:712
msgid "nper:number of periods used for compounding"
msgstr "nper: күрделі пайыздарды есептеу үшін қолданылатын кезеңдер саны"

#: ../plugins/fn-financial/functions.c:688
msgid "EFFECT calculates the effective interest rate using the formula (1+@{rate}/@{nper})^@{nper}-1."
msgstr "EFFECT тиімді пайыздық мөлшерлемені (1+@{rate}/@{nper})^@{nper}-1 формуласы арқылы есептейді."

#: ../plugins/fn-financial/functions.c:710
msgid "NOMINAL:nominal interest rate"
msgstr "NOMINAL: номиналды пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:711 ../plugins/fn-financial/functions.c:736 ../plugins/fn-financial/functions.c:1545 ../plugins/fn-financial/functions.c:1731 ../plugins/fn-financial/functions.c:1761 ../plugins/fn-financial/functions.c:1801 ../plugins/fn-financial/functions.c:1845 ../plugins/fn-financial/functions.c:1939
msgid "rate:effective annual interest rate"
msgstr "rate: тиімді жылдық пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:713
msgid "NOMINAL calculates the nominal interest rate from the effective rate."
msgstr "NOMINAL тиімді мөлшерлемеден номиналды пайыздық мөлшерлемені есептейді."

#: ../plugins/fn-financial/functions.c:735
msgid "ISPMT:interest payment for period"
msgstr "ISPMT: кезең үшін пайыздық төлем"

#: ../plugins/fn-financial/functions.c:737 ../plugins/fn-financial/functions.c:1762 ../plugins/fn-financial/functions.c:1802
msgid "per:period number"
msgstr "per: кезең нөмірі"

#: ../plugins/fn-financial/functions.c:738 ../plugins/fn-financial/functions.c:1192 ../plugins/fn-financial/functions.c:1462 ../plugins/fn-financial/functions.c:1696 ../plugins/fn-financial/functions.c:1732 ../plugins/fn-financial/functions.c:1763 ../plugins/fn-financial/functions.c:1803 ../plugins/fn-financial/functions.c:3155 ../plugins/fn-financial/functions.c:3199
msgid "nper:number of periods"
msgstr "nper: кезеңдер саны"

#: ../plugins/fn-financial/functions.c:739 ../plugins/fn-financial/functions.c:1194 ../plugins/fn-financial/functions.c:1309 ../plugins/fn-financial/functions.c:1698 ../plugins/fn-financial/functions.c:1733 ../plugins/fn-financial/functions.c:1764 ../plugins/fn-financial/functions.c:1804 ../plugins/fn-financial/functions.c:1847 ../plugins/fn-financial/functions.c:1940 ../plugins/fn-financial/functions.c:3156 ../plugins/fn-financial/functions.c:3200
msgid "pv:present value"
msgstr "pv: келтірілген құн"

#: ../plugins/fn-financial/functions.c:740
msgid "ISPMT calculates the interest payment for period number @{per}."
msgstr "ISPMT @{per} нөмірлі кезең үшін пайыздық төлемді есептейді."

#: ../plugins/fn-financial/functions.c:771
msgid "DB:depreciation of an asset"
msgstr "DB: активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:772 ../plugins/fn-financial/functions.c:822 ../plugins/fn-financial/functions.c:871 ../plugins/fn-financial/functions.c:901 ../plugins/fn-financial/functions.c:2904 ../plugins/fn-financial/functions.c:2960 ../plugins/fn-financial/functions.c:3289
msgid "cost:initial cost of asset"
msgstr "cost: активтің бастапқы құны"

#: ../plugins/fn-financial/functions.c:773 ../plugins/fn-financial/functions.c:823 ../plugins/fn-financial/functions.c:872 ../plugins/fn-financial/functions.c:902 ../plugins/fn-financial/functions.c:2907 ../plugins/fn-financial/functions.c:2963 ../plugins/fn-financial/functions.c:3290
msgid "salvage:value after depreciation"
msgstr "salvage: амортизациядан кейінгі құн"

#: ../plugins/fn-financial/functions.c:774 ../plugins/fn-financial/functions.c:824 ../plugins/fn-financial/functions.c:873 ../plugins/fn-financial/functions.c:903 ../plugins/fn-financial/functions.c:3291
msgid "life:number of periods"
msgstr "life: кезеңдер саны"

#: ../plugins/fn-financial/functions.c:775 ../plugins/fn-financial/functions.c:825 ../plugins/fn-financial/functions.c:904 ../plugins/fn-financial/functions.c:2908 ../plugins/fn-financial/functions.c:2964
msgid "period:subject period"
msgstr "period: қарастырылатын кезең"

#: ../plugins/fn-financial/functions.c:776
msgid "month:number of months in first year of depreciation"
msgstr "month: амортизацияның бірінші жылындағы айлар саны"

#: ../plugins/fn-financial/functions.c:777
msgid "DB calculates the depreciation of an asset for a given period using the fixed-declining balance method."
msgstr "DB тіркелген қалдықты азайту әдісін қолдана отырып, берілген кезең үшін активтің амортизациясын есептейді."

#: ../plugins/fn-financial/functions.c:821
msgid "DDB:depreciation of an asset"
msgstr "DDB: активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:826 ../plugins/fn-financial/functions.c:3294
msgid "factor:factor at which the balance declines"
msgstr "factor: қалдықтың азаю коэффициенті"

#: ../plugins/fn-financial/functions.c:827
msgid "DDB calculates the depreciation of an asset for a given period using the double-declining balance method."
msgstr "DDB еселенген қалдықты азайту әдісін қолдана отырып, берілген кезең үшін активтің амортизациясын есептейді."

#: ../plugins/fn-financial/functions.c:870
msgid "SLN:depreciation of an asset"
msgstr "SLN: активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:874
msgid "SLN calculates the depreciation of an asset using the straight-line method."
msgstr "SLN түзу сызықты әдісті қолдана отырып, активтің амортизациясын есептейді."

#: ../plugins/fn-financial/functions.c:900
msgid "SYD:sum-of-years depreciation"
msgstr "SYD: жылдардың қосындысы бойынша амортизация"

#: ../plugins/fn-financial/functions.c:905
msgid "SYD calculates the depreciation of an asset using the sum-of-years method."
msgstr "SYD жылдардың қосындысы әдісін қолдана отырып, активтің амортизациясын есептейді."

#: ../plugins/fn-financial/functions.c:933
msgid "DOLLARDE:convert to decimal dollar amount"
msgstr "DOLLARDE: ондық доллар сомасына айналдыру"

#: ../plugins/fn-financial/functions.c:934
msgid "fractional_dollar:amount to convert"
msgstr "fractional_dollar: айналдырылатын сома"

#: ../plugins/fn-financial/functions.c:935 ../plugins/fn-financial/functions.c:983
msgid "fraction:denominator"
msgstr "fraction: бөлім"

#: ../plugins/fn-financial/functions.c:936
msgid "DOLLARDE converts a fractional dollar amount into a decimal amount.  This is the inverse of the DOLLARFR function."
msgstr "DOLLARDE бөлшектік доллар сомасын ондық сомаға айналдырады. Бұл DOLLARFR функциясына кері амал."

#: ../plugins/fn-financial/functions.c:981
msgid "DOLLARFR:convert to dollar fraction"
msgstr "DOLLARFR: долларлық бөлшекке айналдыру"

#: ../plugins/fn-financial/functions.c:982
msgid "decimal_dollar:amount to convert"
msgstr "decimal_dollar: айналдырылатын сома"

#: ../plugins/fn-financial/functions.c:984
msgid "DOLLARFR converts a decimal dollar amount into a fractional amount which is represented as the digits after the decimal point.  For example, 2/8 would be represented as .2 while 3/16 would be represented as .03. This is the inverse of the DOLLARDE function."
msgstr "DOLLARFR ондық доллар сомасын ондық нүктеден кейінгі цифрлар ретінде көрсетілетін бөлшектік сомаға айналдырады. Мысалы, 2/8 бөлшегі .2 ретінде, ал 3/16 бөлшегі .03 ретінде көрсетіледі. Бұл DOLLARDE функциясына кері амал."

#: ../plugins/fn-financial/functions.c:1027
msgid "MIRR:modified internal rate of return"
msgstr "MIRR: модификацияланған ішкі кірістілік мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1028 ../plugins/fn-financial/functions.c:1343 ../plugins/fn-financial/functions.c:1546 ../plugins/fn-financial/functions.c:1601
msgid "values:cash flow"
msgstr "values: ақша ағыны"

#: ../plugins/fn-financial/functions.c:1029
msgid "finance_rate:interest rate for financing cost"
msgstr "finance_rate: қаржыландыру шығындарының пайыздық мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1030
msgid "reinvest_rate:interest rate for reinvestments"
msgstr "reinvest_rate: қайта инвестициялаудың пайыздық мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1031
msgid "MIRR calculates the modified internal rate of return of a periodic cash flow."
msgstr "MIRR мерзімді ақша ағынының модификацияланған ішкі кірістілік мөлшерлемесін есептейді."

#: ../plugins/fn-financial/functions.c:1085
msgid "TBILLEQ:bond-equivalent yield for a treasury bill"
msgstr "TBILLEQ: қазынашылық вексельдің облигациялық балама кірістілігі"

#: ../plugins/fn-financial/functions.c:1089
msgid "TBILLEQ calculates the bond-equivalent yield for a treasury bill."
msgstr "TBILLEQ қазынашылық вексель үшін облигациялық балама кірістілікті есептейді."

#: ../plugins/fn-financial/functions.c:1123
msgid "TBILLPRICE:price of a treasury bill"
msgstr "TBILLPRICE: қазынашылық вексельдің бағасы"

#: ../plugins/fn-financial/functions.c:1127
msgid "TBILLPRICE calculates the price per $100 face value for a treasury bill."
msgstr "TBILLPRICE қазынашылық вексельдің әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:1157
msgid "TBILLYIELD:yield of a treasury bill"
msgstr "TBILLYIELD: қазынашылық вексельдің кірістілігі"

#: ../plugins/fn-financial/functions.c:1160
msgid "price:price"
msgstr "price: баға"

#: ../plugins/fn-financial/functions.c:1161
msgid "TBILLYIELD calculates the yield of a treasury bill."
msgstr "TBILLYIELD қазынашылық вексельдің кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:1191
msgid "RATE:rate of investment"
msgstr "RATE: инвестиция мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1193 ../plugins/fn-financial/functions.c:1463 ../plugins/fn-financial/functions.c:1697 ../plugins/fn-financial/functions.c:1846
msgid "pmt:payment at each period"
msgstr "pmt: әр кезеңдегі төлем"

#: ../plugins/fn-financial/functions.c:1195 ../plugins/fn-financial/functions.c:1310 ../plugins/fn-financial/functions.c:1464 ../plugins/fn-financial/functions.c:1734 ../plugins/fn-financial/functions.c:1765 ../plugins/fn-financial/functions.c:1805 ../plugins/fn-financial/functions.c:1848 ../plugins/fn-financial/functions.c:1941
msgid "fv:future value"
msgstr "fv: болашақ құн"

#: ../plugins/fn-financial/functions.c:1196 ../plugins/fn-financial/functions.c:1465 ../plugins/fn-financial/functions.c:1699 ../plugins/fn-financial/functions.c:1735 ../plugins/fn-financial/functions.c:1766 ../plugins/fn-financial/functions.c:1806 ../plugins/fn-financial/functions.c:1849 ../plugins/fn-financial/functions.c:3159 ../plugins/fn-financial/functions.c:3203
msgid "type:payment type"
msgstr "type: төлем түрі"

#: ../plugins/fn-financial/functions.c:1197 ../plugins/fn-financial/functions.c:1344 ../plugins/fn-financial/functions.c:1603
msgid "guess:an estimate of what the result should be"
msgstr "guess: нәтиже қандай болуы керек екендігі туралы болжам"

#: ../plugins/fn-financial/functions.c:1198
msgid "RATE calculates the rate of return."
msgstr "RATE кірістілік мөлшерлемесін есептейді."

#: ../plugins/fn-financial/functions.c:1200 ../plugins/fn-financial/functions.c:1347 ../plugins/fn-financial/functions.c:1605
msgid "The optional @{guess} is needed because there can be more than one valid result.  It defaults to 10%."
msgstr "Қосымша @{guess} параметрі қажет, себебі бірнеше жарамды нәтиже болуы мүмкін. Ол үнсіз келісім бойынша 10%."

#: ../plugins/fn-financial/functions.c:1307
msgid "RRI:equivalent interest rate for an investment increasing in value"
msgstr "RRI: құны артып келе жатқан инвестицияның баламалы пайыздық мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1308
msgid "p:number of periods"
msgstr "p: кезеңдер саны"

#: ../plugins/fn-financial/functions.c:1311
msgid "RRI determines an equivalent interest rate for an investment that increases in value. The interest is compounded after each complete period."
msgstr "RRI құны артатын инвестицияның баламалы пайыздық мөлшерлемесін анықтайды. Пайыздар әрбір толық кезеңнен кейін есептеледі."

#: ../plugins/fn-financial/functions.c:1313
msgid "Note that @{p} need not be an integer but for fractional value the calculated rate is only approximate."
msgstr "@{p} бүтін сан болуы міндетті емес, бірақ бөлшектік мәндер үшін есептелген мөлшерлеме тек жуықталған болып табылады."

#: ../plugins/fn-financial/functions.c:1342
msgid "IRR:internal rate of return"
msgstr "IRR: ішкі кірістілік мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1345
msgid "IRR calculates the internal rate of return of a cash flow with periodic payments.  @{values} lists the payments (negative values) and receipts (positive values) for each period."
msgstr "IRR мерзімді төлемдері бар ақша ағынының ішкі кірістілік мөлшерлемесін есептейді. @{values} әр кезең үшін төлемдерді (теріс мәндер) және түсімдерді (оң мәндер) тізімдейді."

#: ../plugins/fn-financial/functions.c:1460
msgid "PV:present value"
msgstr "PV: келтірілген құн"

#: ../plugins/fn-financial/functions.c:1461 ../plugins/fn-financial/functions.c:1501 ../plugins/fn-financial/functions.c:1695
msgid "rate:effective interest rate per period"
msgstr "rate: кезеңдегі тиімді пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:1466
msgid "PV calculates the present value of @{fv} which is @{nper} periods into the future, assuming a periodic payment of @{pmt} and an interest rate of @{rate} per period."
msgstr "PV әр кезеңдегі @{pmt} төлемін және @{rate} пайыздық мөлшерлемесін ескере отырып, болашақтағы @{nper} кезеңнен кейінгі @{fv} мәнінің келтірілген құнын есептейді."

#: ../plugins/fn-financial/functions.c:1500
msgid "NPV:net present value"
msgstr "NPV: таза келтірілген құн"

#: ../plugins/fn-financial/functions.c:1502
msgid "value1:cash flow for period 1"
msgstr "value1: 1-кезеңдегі ақша ағыны"

#: ../plugins/fn-financial/functions.c:1503
msgid "value2:cash flow for period 2"
msgstr "value2: 2-кезеңдегі ақша ағыны"

#: ../plugins/fn-financial/functions.c:1504
msgid "NPV calculates the net present value of a cash flow."
msgstr "NPV ақша ағынының таза келтірілген құнын есептейді."

#: ../plugins/fn-financial/functions.c:1544
msgid "XNPV:net present value"
msgstr "XNPV: таза келтірілген құн"

#: ../plugins/fn-financial/functions.c:1547 ../plugins/fn-financial/functions.c:1602
msgid "dates:dates of cash flow"
msgstr "dates: ақша ағынының күндері"

#: ../plugins/fn-financial/functions.c:1548
msgid "XNPV calculates the net present value of a cash flow at irregular times."
msgstr "XNPV тұрақсыз уақыт аралығындағы ақша ағынының таза келтірілген құнын есептейді."

#: ../plugins/fn-financial/functions.c:1600
msgid "XIRR:internal rate of return"
msgstr "XIRR: ішкі кірістілік мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:1604
msgid "XIRR calculates the annualized internal rate of return of a cash flow at arbitrary points in time.  @{values} lists the payments (negative values) and receipts (positive values) with one value for each entry in @{dates}."
msgstr "XIRR кез келген уақыт сәттеріндегі ақша ағынының жылдық ішкі кірістілік мөлшерлемесін есептейді. @{values} @{dates} ішіндегі әрбір жазбаға сәйкес бір мәннен төлемдерді (теріс мәндер) және түсімдерді (оң мәндер) тізімдейді."

#: ../plugins/fn-financial/functions.c:1694
msgid "FV:future value"
msgstr "FV: болашақ құн"

#: ../plugins/fn-financial/functions.c:1700
msgid "FV calculates the future value of @{pv} moved @{nper} periods into the future, assuming a periodic payment of @{pmt} and an interest rate of @{rate} per period."
msgstr "FV әр кезеңдегі @{pmt} төлемін және @{rate} пайыздық мөлшерлемесін ескере отырып, болашақтағы @{nper} кезеңнен кейінгі @{pv} мәнінің болашақ құнын есептейді."

#: ../plugins/fn-financial/functions.c:1730
msgid "PMT:payment for annuity"
msgstr "PMT: аннуитет үшін төлем"

#: ../plugins/fn-financial/functions.c:1736
msgid "PMT calculates the payment amount for an annuity."
msgstr "PMT аннуитет үшін төлем сомасын есептейді."

#: ../plugins/fn-financial/functions.c:1760
msgid "IPMT:interest payment for period"
msgstr "IPMT: кезең үшін пайыздық төлем"

#: ../plugins/fn-financial/functions.c:1767
msgid "IPMT calculates the interest part of an annuity's payment for period number @{per}."
msgstr "IPMT @{per} нөмірлі кезең үшін аннуитеттік төлемнің пайыздық бөлігін есептейді."

#: ../plugins/fn-financial/functions.c:1800
msgid "PPMT:interest payment for period"
msgstr "PPMT: кезең үшін негізгі қарыз бойынша төлем"

#: ../plugins/fn-financial/functions.c:1807
msgid "PPMT calculates the principal part of an annuity's payment for period number @{per}."
msgstr "PPMT @{per} нөмірлі кезең үшін аннуитеттік төлемнің негізгі бөлігін есептейді."

#: ../plugins/fn-financial/functions.c:1844
msgid "NPER:number of periods"
msgstr "NPER: кезеңдер саны"

#: ../plugins/fn-financial/functions.c:1850
msgid "NPER calculates the number of periods of an investment based on periodic constant payments and a constant interest rate."
msgstr "NPER тұрақты мерзімді төлемдер мен тұрақты пайыздық мөлшерлемеге негізделген инвестицияның кезеңдер санын есептейді."

#: ../plugins/fn-financial/functions.c:1892
msgid "DURATION:the (Macaulay) duration of a security"
msgstr "DURATION: бағалы қағаздың (Маколей) ұзақтығы"

#: ../plugins/fn-financial/functions.c:1895 ../plugins/fn-financial/functions.c:3244
msgid "coupon:annual coupon rate"
msgstr "coupon: жылдық купондық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:1899
msgid "DURATION calculates the (Macaulay) duration of a security."
msgstr "DURATION бағалы қағаздың (Маколей) ұзақтығын есептейді."

#: ../plugins/fn-financial/functions.c:1938
msgid "G_DURATION:the duration of a investment"
msgstr "G_DURATION: инвестицияның ұзақтығы"

#: ../plugins/fn-financial/functions.c:1942
msgid "G_DURATION calculates the number of periods needed for an investment to attain a desired value."
msgstr "G_DURATION инвестицияның қажетті мәнге жетуі үшін қажетті кезеңдер санын есептейді."

#: ../plugins/fn-financial/functions.c:1943
msgid "G_DURATION is the OpenFormula function PDURATION."
msgstr "G_DURATION — бұл PDURATION OpenFormula функциясы."

#: ../plugins/fn-financial/functions.c:1972
msgid "FVSCHEDULE:future value"
msgstr "FVSCHEDULE: болашақ құн"

#: ../plugins/fn-financial/functions.c:1973
msgid "principal:initial value"
msgstr "principal: бастапқы мән"

#: ../plugins/fn-financial/functions.c:1974
msgid "schedule:range of interest rates"
msgstr "schedule: пайыздық мөлшерлемелер ауқымы"

#: ../plugins/fn-financial/functions.c:1975
msgid "FVSCHEDULE calculates the future value of @{principal} after applying a range of interest rates with compounding."
msgstr "FVSCHEDULE күрделі пайыздармен пайыздық мөлшерлемелер ауқымын қолданғаннан кейінгі @{principal} болашақ құнын есептейді."

#: ../plugins/fn-financial/functions.c:2008
msgid "EURO:equivalent of 1 EUR"
msgstr "EURO: 1 EUR баламасы"

#: ../plugins/fn-financial/functions.c:2009
msgid "currency:three-letter currency code"
msgstr "currency: валютаның үш әріпті коды"

#: ../plugins/fn-financial/functions.c:2010
msgid "EURO calculates the national currency amount corresponding to 1 EUR for any of the national currencies that were replaced by the Euro on its introduction."
msgstr "EURO еуро енгізілген кезде ауыстырылған кез келген ұлттық валюталар үшін 1 EUR-ға сәйкес келетін ұлттық валюта сомасын есептейді."

#: ../plugins/fn-financial/functions.c:2011
msgid "@{currency} must be one of ATS (Austria), BEF (Belgium), CYP (Cyprus), DEM (Germany), EEK (Estonia), ESP (Spain), EUR (Euro), FIM (Finland), FRF (France), GRD (Greece), IEP (Ireland), ITL (Italy), LUF (Luxembourg), MTL (Malta), NLG (The Netherlands), PTE (Portugal), SIT (Slovenia), or SKK (Slovakia)."
msgstr "@{currency} келесілердің бірі болуы тиіс: ATS (Австрия), BEF (Бельгия), CYP (Кипр), DEM (Германия), EEK (Эстония), ESP (Испания), EUR (Еуро), FIM (Финляндия), FRF (Франция), GRD (Грекия), IEP (Ирландия), ITL (Италия), LUF (Люксембург), MTL (Мальта), NLG (Нидерланды), PTE (Португалия), SIT (Словения) немесе SKK (Словакия)."

#: ../plugins/fn-financial/functions.c:2030 ../plugins/fn-financial/functions.c:2214
msgid "This function is not likely to be useful anymore."
msgstr "Бұл функция енді пайдалы болмауы мүмкін."

#: ../plugins/fn-financial/functions.c:2205
msgid "EUROCONVERT:pre-Euro amount from one currency to another"
msgstr "EUROCONVERT: еуроға дейінгі соманы бір валютадан екіншісіне айналдыру"

#: ../plugins/fn-financial/functions.c:2206
msgid "n:amount"
msgstr "n: сома"

#: ../plugins/fn-financial/functions.c:2207
msgid "source:three-letter source currency code"
msgstr "source: бастапқы валютаның үш әріпті коды"

#: ../plugins/fn-financial/functions.c:2208
msgid "target:three-letter target currency code"
msgstr "target: валютаның үш әріпті мақсатты коды"

#: ../plugins/fn-financial/functions.c:2209
msgid "full_precision:whether to provide the full precision; defaults to false"
msgstr "full_precision: толық дәлдікті қамтамасыз ету керек пе; үнсіз келісім бойынша false"

#: ../plugins/fn-financial/functions.c:2210
msgid "triangulation_precision:number of digits (at least 3) to be rounded to after conversion of the source currency to euro; defaults to no rounding"
msgstr "triangulation_precision: бастапқы валютаны еуроға айналдырғаннан кейін дөңгелектенетін цифрлар саны (кемінде 3); үнсіз келісім бойынша дөңгелектеусіз"

#: ../plugins/fn-financial/functions.c:2211
msgid "EUROCONVERT converts @{n} units of currency @{source} to currency @{target}.  The rates used are the official ones used on the introduction of the Euro."
msgstr "EUROCONVERT @{n} @{source} валюта юнитін @{target} валютасына айналдырады. Қолданылатын мөлшерлемелер Еуро енгізілген кезде қолданылған ресми мөлшерлемелер болып табылады."

#: ../plugins/fn-financial/functions.c:2212
msgid "If @{full_precision} is true, the result is not rounded; if it false the result is rounded to 0 or 2 decimals depending on the target currency; defaults to false."
msgstr "Егер @{full_precision} мәні true болса, нәтиже дөңгелектенбейді; егер ол false болса, нәтиже мақсатты валютаға байланысты 0 немесе 2 ондық таңбаға дейін дөңгелектенеді; үнсіз келісім бойынша false."

#: ../plugins/fn-financial/functions.c:2213
msgid "@{source} and @{target} must be one of the currencies listed for the EURO function."
msgstr "@{source} және @{target} EURO функциясы үшін тізімделген валюталардың бірі болуы тиіс."

#: ../plugins/fn-financial/functions.c:2257
msgid "PRICE:price of a security"
msgstr "PRICE: бағалы қағаздың бағасы"

#: ../plugins/fn-financial/functions.c:2265
msgid "PRICE calculates the price per $100 face value of a security that pays periodic interest."
msgstr "PRICE мерзімді пайыздарды төлейтін бағалы қағаздың әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:2307
msgid "YIELD:yield of a security"
msgstr "YIELD: бағалы қағаздың кірістілігі"

#: ../plugins/fn-financial/functions.c:2311 ../plugins/fn-financial/functions.c:2419 ../plugins/fn-financial/functions.c:2466 ../plugins/fn-financial/functions.c:2657 ../plugins/fn-financial/functions.c:2830
msgid "price:price of security"
msgstr "price: бағалы қағаздың бағасы"

#: ../plugins/fn-financial/functions.c:2315
msgid "YIELD calculates the yield of a security that pays periodic interest."
msgstr "YIELD мерзімді пайыздарды төлейтін бағалы қағаздың кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:2416
msgid "YIELDDISC:yield of a discounted security"
msgstr "YIELDDISC: дисконтталған бағалы қағаздың кірістілігі"

#: ../plugins/fn-financial/functions.c:2422
msgid "YIELDDISC calculates the yield of a discounted security."
msgstr "YIELDDISC дисконтталған бағалы қағаздың кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:2461
msgid "YIELDMAT:yield of a security"
msgstr "YIELDMAT: бағалы қағаздың кірістілігі"

#: ../plugins/fn-financial/functions.c:2468
msgid "YIELDMAT calculates the yield of a security for which the interest is paid at maturity date."
msgstr "YIELDMAT пайыздары өтеу күнінде төленетін бағалы қағаздың кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:2500
msgid "ODDFPRICE:price of a security that has an odd first period"
msgstr "ODDFPRICE: бірінші кезеңі тұрақты емес бағалы қағаздың бағасы"

#: ../plugins/fn-financial/functions.c:2504 ../plugins/fn-financial/functions.c:2655
msgid "first_interest:first interest date"
msgstr "first_interest: алғашқы пайыз күні"

#: ../plugins/fn-financial/functions.c:2510
msgid "ODDFPRICE calculates the price per $100 face value of a security that pays periodic interest, but has an odd first period."
msgstr "ODDFPRICE мерзімді пайыздарды төлейтін, бірақ бірінші кезеңі тұрақты емес бағалы қағаздың әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:2651
msgid "ODDFYIELD:yield of a security that has an odd first period"
msgstr "ODDFYIELD: бірінші кезеңі тұрақты емес бағалы қағаздың кірістілігі"

#: ../plugins/fn-financial/functions.c:2661
msgid "ODDFYIELD calculates the yield of a security that pays periodic interest, but has an odd first period."
msgstr "ODDFYIELD мерзімді пайыздарды төлейтін, бірақ бірінші кезеңі тұрақты емес бағалы қағаздың кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:2747
msgid "ODDLPRICE:price of a security that has an odd last period"
msgstr "ODDLPRICE: соңғы кезеңі тұрақты емес бағалы қағаздың бағасы"

#: ../plugins/fn-financial/functions.c:2750 ../plugins/fn-financial/functions.c:2828
msgid "last_interest:last interest date"
msgstr "last_interest: соңғы пайыз күні"

#: ../plugins/fn-financial/functions.c:2756
msgid "ODDLPRICE calculates the price per $100 face value of a security that pays periodic interest, but has an odd last period."
msgstr "ODDLPRICE мерзімді пайыздарды төлейтін, бірақ соңғы кезеңі тұрақты емес бағалы қағаздың әр $100 номиналды құнына шаққандағы бағасын есептейді."

#: ../plugins/fn-financial/functions.c:2825
msgid "ODDLYIELD:yield of a security that has an odd last period"
msgstr "ODDLYIELD: соңғы кезеңі тұрақты емес бағалы қағаздың кірістілігі"

#: ../plugins/fn-financial/functions.c:2834
msgid "ODDLYIELD calculates the yield of a security that pays periodic interest, but has an odd last period."
msgstr "ODDLYIELD мерзімді пайыздарды төлейтін, бірақ соңғы кезеңі тұрақты емес бағалы қағаздың кірістілігін есептейді."

#: ../plugins/fn-financial/functions.c:2903
msgid "AMORDEGRC:depreciation of an asset using French accounting conventions"
msgstr "AMORDEGRC: француздық бухгалтерлік есеп ережелері бойынша активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:2905 ../plugins/fn-financial/functions.c:2961
msgid "purchase_date:date of purchase"
msgstr "purchase_date: сатып алу күні"

#: ../plugins/fn-financial/functions.c:2906 ../plugins/fn-financial/functions.c:2962
msgid "first_period:end of first period"
msgstr "first_period: бірінші кезеңнің соңы"

#: ../plugins/fn-financial/functions.c:2909 ../plugins/fn-financial/functions.c:2965
msgid "rate:depreciation rate"
msgstr "rate: амортизация мөлшерлемесі"

#: ../plugins/fn-financial/functions.c:2912
msgid "AMORDEGRC calculates the depreciation of an asset using French accounting conventions. Assets purchased in the middle of a period take prorated depreciation into account. This is similar to AMORLINC, except that a depreciation coefficient is applied in the calculation depending on the life of the assets."
msgstr "AMORDEGRC француздық бухгалтерлік есеп ережелері бойынша активтің амортизациясын есептейді. Кезеңнің ортасында сатып алынған активтер үшін пропорционалды амортизация ескеріледі. Бұл AMORLINC функциясына ұқсас, бірақ есептеу кезінде активтердің қызмет ету мерзіміне байланысты амортизация коэффициенті қолданылады."

#: ../plugins/fn-financial/functions.c:2916
msgid ""
"The depreciation coefficient used is:\n"
"1.0 for an expected lifetime less than 3 years,\n"
"1.5 for an expected lifetime of at least 3 years but less than 5 years,\n"
"2.0 for an expected lifetime of at least 5 years but at most 6 years,\n"
"2.5 for an expected lifetime of more than 6 years."
msgstr ""
"Қолданылатын амортизация коэффициенті:\n"
"1.0 — күтілетін қызмет мерзімі 3 жылдан аз болса,\n"
"1.5 — күтілетін қызмет мерзімі кемінде 3 жыл, бірақ 5 жылдан аз болса,\n"
"2.0 — күтілетін қызмет мерзімі кемінде 5 жыл, бірақ ең көп дегенде 6 жыл болса,\n"
"2.5 — күтілетін қызмет мерзімі 6 жылдан көп болса."

#: ../plugins/fn-financial/functions.c:2921
msgid "Special depreciation rules are applied for the last two periods resulting in a possible total depreciation exceeding the difference of @{cost} - @{salvage}."
msgstr "Соңғы екі кезең үшін арнайы амортизация ережелері қолданылады, бұл жалпы амортизация сомасының @{cost} - @{salvage} айырмасынан асып кетуіне әкелуі мүмкін."

#: ../plugins/fn-financial/functions.c:2923
msgid "Named for AMORtissement DEGRessif Comptabilite."
msgstr "AMORtissement DEGRessif Comptabilite үшін аталған."

#: ../plugins/fn-financial/functions.c:2959
msgid "AMORLINC:depreciation of an asset using French accounting conventions"
msgstr "AMORLINC: француздық бухгалтерлік есеп ережелері бойынша активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:2968
msgid "AMORLINC calculates the depreciation of an asset using French accounting conventions. Assets purchased in the middle of a period take prorated depreciation into account."
msgstr "AMORLINC француздық бухгалтерлік есеп ережелері бойынша активтің амортизациясын есептейді. Кезеңнің ортасында сатып алынған активтер үшін пропорционалды амортизация ескеріледі."

#: ../plugins/fn-financial/functions.c:2970
msgid "Named for AMORtissement LINeaire Comptabilite."
msgstr "AMORtissement LINeaire Comptabilite үшін аталған."

#: ../plugins/fn-financial/functions.c:3005
msgid "COUPDAYBS:number of days from coupon period to settlement"
msgstr "COUPDAYBS: купондық кезеңнің басынан есеп айырысу күніне дейінгі күндер саны"

#: ../plugins/fn-financial/functions.c:3010 ../plugins/fn-financial/functions.c:3034 ../plugins/fn-financial/functions.c:3058 ../plugins/fn-financial/functions.c:3082 ../plugins/fn-financial/functions.c:3108 ../plugins/fn-financial/functions.c:3134
msgid "eom:end-of-month flag"
msgstr "eom: ай соңы белгісі"

#: ../plugins/fn-financial/functions.c:3011
msgid "COUPDAYBS calculates the number of days from the beginning of the coupon period to the settlement date."
msgstr "COUPDAYBS купондық кезеңнің басынан есеп айырысу күніне дейінгі күндер санын есептейді."

#: ../plugins/fn-financial/functions.c:3029
msgid "COUPDAYS:number of days in the coupon period of the settlement date"
msgstr "COUPDAYS: есеп айырысу күнінің купондық кезеңіндегі күндер саны"

#: ../plugins/fn-financial/functions.c:3035
msgid "COUPDAYS calculates the number of days in the coupon period of the settlement date."
msgstr "COUPDAYS есеп айырысу күнінің купондық кезеңіндегі күндер санын есептейді."

#: ../plugins/fn-financial/functions.c:3053
msgid "COUPDAYSNC:number of days from the settlement date to the next coupon period"
msgstr "COUPDAYSNC: есеп айырысу күнінен келесі купондық кезеңге дейінгі күндер саны"

#: ../plugins/fn-financial/functions.c:3059
msgid "COUPDAYSNC calculates number of days from the settlement date to the next coupon period."
msgstr "COUPDAYSNC есеп айырысу күнінен келесі купондық кезеңге дейінгі күндер санын есептейді."

#: ../plugins/fn-financial/functions.c:3077
msgid "COUPNCD:the next coupon date after settlement"
msgstr "COUPNCD: есеп айырысудан кейінгі келесі купон күні"

#: ../plugins/fn-financial/functions.c:3083
msgid "COUPNCD calculates the coupon date following settlement."
msgstr "COUPNCD есеп айырысудан кейінгі купон күнін есептейді."

#: ../plugins/fn-financial/functions.c:3103
msgid "COUPPCD:the last coupon date before settlement"
msgstr "COUPPCD: есеп айырысуға дейінгі соңғы купон күні"

#: ../plugins/fn-financial/functions.c:3109
msgid "COUPPCD calculates the coupon date preceding settlement."
msgstr "COUPPCD есеп айырысуға дейінгі купон күнін есептейді."

#: ../plugins/fn-financial/functions.c:3129
msgid "COUPNUM:number of coupons"
msgstr "COUPNUM: купондар саны"

#: ../plugins/fn-financial/functions.c:3135
msgid "COUPNUM calculates the number of coupons to be paid between the settlement and maturity dates, rounded up."
msgstr "COUPNUM есеп айырысу және өтеу күндері арасында төленетін купондар санын есептейді (жоғары қарай дөңгелектенеді)."

#: ../plugins/fn-financial/functions.c:3153
msgid "CUMIPMT:cumulative interest payment"
msgstr "CUMIPMT: жинақталған пайыздық төлем"

#: ../plugins/fn-financial/functions.c:3154 ../plugins/fn-financial/functions.c:3198
msgid "rate:interest rate per period"
msgstr "rate: кезеңдегі пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:3157 ../plugins/fn-financial/functions.c:3201 ../plugins/fn-financial/functions.c:3292
msgid "start_period:first period to accumulate for"
msgstr "start_period: жинақтау басталатын бірінші кезең"

#: ../plugins/fn-financial/functions.c:3158 ../plugins/fn-financial/functions.c:3202 ../plugins/fn-financial/functions.c:3293
msgid "end_period:last period to accumulate for"
msgstr "end_period: жинақтау аяқталатын соңғы кезең"

#: ../plugins/fn-financial/functions.c:3160
msgid "CUMIPMT calculates the cumulative interest paid on a loan from @{start_period} to @{end_period}."
msgstr "CUMIPMT @{start_period} кезеңінен @{end_period} кезеңіне дейінгі несие бойынша төленген жинақталған пайыздарды есептейді."

#: ../plugins/fn-financial/functions.c:3197
msgid "CUMPRINC:cumulative principal"
msgstr "CUMPRINC: жинақталған негізгі қарыз"

#: ../plugins/fn-financial/functions.c:3204
msgid "CUMPRINC calculates the cumulative principal paid on a loan from @{start_period} to @{end_period}."
msgstr "CUMPRINC @{start_period} кезеңінен @{end_period} кезеңіне дейінгі несие бойынша төленген жинақталған негізгі қарызды есептейді."

#: ../plugins/fn-financial/functions.c:3241
msgid "MDURATION:the modified (Macaulay) duration of a security"
msgstr "MDURATION: бағалы қағаздың модификацияланған (Маколей) ұзақтығы"

#: ../plugins/fn-financial/functions.c:3248
msgid "MDURATION calculates the modified (Macaulay) duration of a security."
msgstr "MDURATION бағалы қағаздың модификацияланған (Маколей) ұзақтығын есептейді."

#: ../plugins/fn-financial/functions.c:3288
msgid "VDB:depreciation of an asset"
msgstr "VDB: активтің амортизациясы"

#: ../plugins/fn-financial/functions.c:3295
msgid "no_switch:do not switch to straight-line depreciation"
msgstr "no_switch: түзу сызықты амортизацияға ауыспау"

#: ../plugins/fn-financial/functions.c:3296
msgid "VDB calculates the depreciation of an asset for a given period range using the variable-rate declining balance method."
msgstr "VDB айнымалы мөлшерлемелі қалдықты азайту әдісін қолдана отырып, берілген кезең ауқымы үшін активтің амортизациясын есептейді."

#: ../plugins/fn-financial/functions.c:3297
msgid "If @{no_switch} is FALSE, the calculation switches to straight-line depreciation when depreciation is greater than the declining balance calculation."
msgstr "Егер @{no_switch} FALSE болса, амортизация қалдықты азайту есебінен көп болған кезде есептеу түзу сызықты амортизацияға ауысады."

#: ../plugins/fn-flt/functions.c:36
msgid "FLT.RADIX:return the floating point system's base"
msgstr "FLT.RADIX: жылжымалы нүкте жүйесінің негізін қайтару"

#: ../plugins/fn-flt/functions.c:37
msgid "The FLT.RADIX function returns the base of the floating point number system in use."
msgstr "FLT.RADIX функциясы қолданыстағы жылжымалы нүктелі сандар жүйесінің негізін қайтарады."

#: ../plugins/fn-flt/functions.c:52
msgid "FLT.MIN:return the smallest positive floating point number"
msgstr "FLT.MIN: ең кіші оң жылжымалы нүктелі санды қайтару"

#: ../plugins/fn-flt/functions.c:53
msgid "The FLT.MIN function returns the smallest positive normal floating point number that can be represented."
msgstr "FLT.MIN функциясы көрсетуге болатын ең кіші оң қалыпты жылжымалы нүктелі санды қайтарады."

#: ../plugins/fn-flt/functions.c:68
msgid "FLT.MAX:return the largest positive floating point number"
msgstr "FLT.MAX: ең үлкен оң жылжымалы нүктелі санды қайтару"

#: ../plugins/fn-flt/functions.c:69
msgid "The FLT.MAX function returns the largest positive floating point number that can be represented."
msgstr "FLT.MAX функциясы көрсетуге болатын ең үлкен оң жылжымалы нүктелі санды қайтарады."

#: ../plugins/fn-flt/functions.c:84
msgid "FLT.NEXTAFTER:next representable value"
msgstr "FLT.NEXTAFTER: келесі көрсетілетін мән"

#: ../plugins/fn-flt/functions.c:85
msgid "x:floating point value"
msgstr "x: жылжымалы нүктелі мән"

#: ../plugins/fn-flt/functions.c:86
msgid "y:direction"
msgstr "y: бағыт"

#: ../plugins/fn-flt/functions.c:87
msgid "The FLT.NEXTAFTER function returns the next floating point value after @{x} in the direction of @{y}.  \"+\" and \"-\" are special values for @{y} that represent positive and negative infinity."
msgstr "FLT.NEXTAFTER функциясы @{x} мәнінен кейінгі @{y} бағытындағы келесі жылжымалы нүктелі мәнді қайтарады. \"+\" және \"-\" — @{y} үшін оң және теріс шексіздікті білдіретін арнайы мәндер."

#: ../plugins/fn-hebrew-date/functions.c:89
msgid "HDATE:Hebrew date"
msgstr "HDATE: еврей күнтізбесі бойынша күн"

#: ../plugins/fn-hebrew-date/functions.c:90 ../plugins/fn-hebrew-date/functions.c:159 ../plugins/fn-hebrew-date/functions.c:232 ../plugins/fn-hebrew-date/functions.c:259 ../plugins/fn-hebrew-date/functions.c:286 ../plugins/fn-hebrew-date/functions.c:313
msgid "year:Gregorian year of date, defaults to the current year"
msgstr "year: күннің григориандық жылы, үнсіз келісім бойынша ағымдағы жыл"

#: ../plugins/fn-hebrew-date/functions.c:91 ../plugins/fn-hebrew-date/functions.c:160 ../plugins/fn-hebrew-date/functions.c:233 ../plugins/fn-hebrew-date/functions.c:260 ../plugins/fn-hebrew-date/functions.c:287 ../plugins/fn-hebrew-date/functions.c:314
msgid "month:Gregorian month of year, defaults to the current month"
msgstr "month: жылдың григориандық айы, үнсіз келісім бойынша ағымдағы ай"

#: ../plugins/fn-hebrew-date/functions.c:92 ../plugins/fn-hebrew-date/functions.c:161 ../plugins/fn-hebrew-date/functions.c:234 ../plugins/fn-hebrew-date/functions.c:261 ../plugins/fn-hebrew-date/functions.c:288 ../plugins/fn-hebrew-date/functions.c:315
msgid "day:Gregorian day of month, defaults to the current day"
msgstr "day: айдың григориандық күні, үнсіз келісім бойынша ағымдағы күн"

#: ../plugins/fn-hebrew-date/functions.c:124
msgid "DATE2HDATE:Hebrew date"
msgstr "DATE2HDATE: еврей күнтізбесі бойынша күн"

#: ../plugins/fn-hebrew-date/functions.c:125 ../plugins/fn-hebrew-date/functions.c:200 ../plugins/fn-hebrew-date/functions.c:339
msgid "date:Gregorian date, defaults to today"
msgstr "date: григориандық күн, үнсіз келісім бойынша бүгін"

#: ../plugins/fn-hebrew-date/functions.c:158
msgid "HDATE_HEB:Hebrew date in Hebrew"
msgstr "HDATE_HEB:еврей тіліндегі еврей күні"

#: ../plugins/fn-hebrew-date/functions.c:199
msgid "DATE2HDATE_HEB:Hebrew date in Hebrew"
msgstr "DATE2HDATE_HEB:еврей тіліндегі еврей күні"

#: ../plugins/fn-hebrew-date/functions.c:231
msgid "HDATE_MONTH:Hebrew month of Gregorian date"
msgstr "HDATE_MONTH:Григориан күнінің еврейше айы"

#: ../plugins/fn-hebrew-date/functions.c:258
msgid "HDATE_DAY:Hebrew day of Gregorian date"
msgstr "HDATE_DAY:Григориан күнінің еврейше күні"

#: ../plugins/fn-hebrew-date/functions.c:285
msgid "HDATE_YEAR:Hebrew year of Gregorian date"
msgstr "HDATE_YEAR:Григориан күнінің еврейше жылы"

#: ../plugins/fn-hebrew-date/functions.c:312
msgid "HDATE_JULIAN:Julian day number for given Gregorian date"
msgstr "HDATE_JULIAN:берілген Григориан күні үшін Юлиан күнінің нөмірі"

#: ../plugins/fn-hebrew-date/functions.c:338
msgid "DATE2JULIAN:Julian day number for given Gregorian date"
msgstr "DATE2JULIAN:берілген Григориан күні үшін Юлиан күнінің нөмірі"

#: ../plugins/fn-info/functions.c:64
msgid "CELL:information of @{type} about @{cell}"
msgstr "CELL:@{cell} туралы @{type} ақпараты"

#: ../plugins/fn-info/functions.c:65
msgid "type:string specifying the type of information requested"
msgstr "type:сұралған ақпарат түрін анықтайтын жол"

#: ../plugins/fn-info/functions.c:66
msgid "cell:cell reference"
msgstr "cell:ұяшық сілтемесі"

#: ../plugins/fn-info/functions.c:67
msgid ""
"@{type} specifies the type of information you want to obtain:\n"
"  address        \t\tReturns the given cell reference as text.\n"
"  col            \t\tReturns the number of the column in @{cell}.\n"
"  color          \t\tReturns 0.\n"
"  contents       \t\tReturns the contents of the cell in @{cell}.\n"
"  column         \t\tReturns the number of the column in @{cell}.\n"
"  columnwidth    \tReturns the column width.\n"
"  coord          \t\tReturns the absolute address of @{cell}.\n"
"  datatype       \tsame as type\n"
"  filename       \t\tReturns the name of the file of @{cell}.\n"
"  format         \t\tReturns the code of the format of the cell.\n"
"  formulatype    \tsame as type\n"
"  locked         \t\tReturns 1 if @{cell} is locked.\n"
"  parentheses    \tReturns 1 if @{cell} contains a negative value\n"
"                 \t\tand its format displays it with parentheses.\n"
"  prefix         \t\tReturns a character indicating the horizontal\n"
"                 \t\talignment of @{cell}.\n"
"  prefixcharacter  \tsame as prefix\n"
"  protect        \t\tReturns 1 if @{cell} is locked.\n"
"  row            \t\tReturns the number of the row in @{cell}.\n"
"  sheetname      \tReturns the name of the sheet of @{cell}.\n"
"  type           \t\tReturns \"l\" if @{cell} contains a string, \n"
"                 \t\t\"v\" if it contains some other value, and \n"
"                 \t\t\"b\" if @{cell} is blank.\n"
"  value          \t\tReturns the contents of the cell in @{cell}.\n"
"  width          \t\tReturns the column width."
msgstr ""
"@{type} алғыңыз келетін ақпарат түрін анықтайды:\n"
"  address        \t\tБерілген ұяшық сілтемесін мәтін ретінде қайтарады.\n"
"  col            \t\t@{cell} ішіндегі баған нөмірін қайтарады.\n"
"  color          \t\t0 қайтарады.\n"
"  contents       \t\t@{cell} ішіндегі ұяшық мазмұнын қайтарады.\n"
"  column         \t\t@{cell} ішіндегі баған нөмірін қайтарады.\n"
"  columnwidth    \tБаған енін қайтарады.\n"
"  coord          \t\t@{cell} ұяшығының абсолютті адресін қайтарады.\n"
"  datatype       \ttype сияқты\n"
"  filename       \t\t@{cell} файлының атын қайтарады.\n"
"  format         \t\tҰяшық пішімінің кодын қайтарады.\n"
"  formulatype    \ttype сияқты\n"
"  locked         \t\tЕгер @{cell} құлыпталған болса, 1 қайтарады.\n"
"  parentheses    \tЕгер @{cell} теріс мәнді қамтыса және оның пішімі\n"
"                 \t\tоны жақшамен көрсетсе, 1 қайтарады.\n"
"  prefix         \t\t@{cell} ұяшығының горизонталды туралануын\n"
"                 \t\tкөрсететін таңбаны қайтарады.\n"
"  prefixcharacter  \tprefix сияқты\n"
"  protect        \t\tЕгер @{cell} құлыпталған болса, 1 қайтарады.\n"
"  row            \t\t@{cell} ішіндегі жол нөмірін қайтарады.\n"
"  sheetname      \t@{cell} парағының атын қайтарады.\n"
"  type           \t\tЕгер @{cell} жолды қамтыса, \"l\" мәнін,\n"
"                 \t\tбасқа мәнді қамтыса, \"v\" мәнін,\n"
"                 \t\tал бос болса, \"b\" мәнін қайтарады.\n"
"  value          \t\t@{cell} ішіндегі ұяшық мазмұнын қайтарады.\n"
"  width          \t\tБаған енін қайтарады."

#: ../plugins/fn-info/functions.c:363
msgid "EXPRESSION:expression in @{cell} as a string"
msgstr "EXPRESSION:@{cell} ішіндегі өрнек жол ретінде"

#: ../plugins/fn-info/functions.c:364
msgid "cell:a cell reference"
msgstr "cell:ұяшық сілтемесі"

#: ../plugins/fn-info/functions.c:365
msgid "If @{cell} contains no expression, EXPRESSION returns empty."
msgstr "Егер @{cell} ішінде өрнек болмаса, EXPRESSION бос мән қайтарады."

#: ../plugins/fn-info/functions.c:400
msgid "GET.FORMULA:the formula in @{cell} as a string"
msgstr "GET.FORMULA:@{cell} ішіндегі формула жол ретінде"

#: ../plugins/fn-info/functions.c:401 ../plugins/fn-info/functions.c:443 ../plugins/fn-info/functions.c:1014
msgid "cell:the referenced cell"
msgstr "cell:сілтеме жасалған ұяшық"

#: ../plugins/fn-info/functions.c:402
msgid "GET.FORMULA is the OpenFormula function FORMULA."
msgstr "GET.FORMULA — бұл OpenFormula стандартындағы FORMULA функциясы."

#: ../plugins/fn-info/functions.c:403
msgid ""
"If A1 is empty and A2 contains =B1+B2, then\n"
"GET.FORMULA(A2) yields '=B1+B2' and\n"
"GET.FORMULA(A1) yields ''."
msgstr ""
"Егер A1 бос болса, ал A2 ұяшығында =B1+B2 болса, онда\n"
"GET.FORMULA(A2) нәтижесі '=B1+B2' болады және\n"
"GET.FORMULA(A1) нәтижесі '' болады."

#: ../plugins/fn-info/functions.c:442
msgid "ISFORMULA:TRUE if @{cell} contains a formula"
msgstr "ISFORMULA:егер @{cell} ішінде формула болса, АҚИҚАТ"

#: ../plugins/fn-info/functions.c:444
msgid "ISFORMULA is OpenFormula compatible."
msgstr "ISFORMULA функциясы OpenFormula стандартымен үйлесімді."

#: ../plugins/fn-info/functions.c:473
msgid "COUNTBLANK:the number of blank cells in @{range}"
msgstr "COUNTBLANK:@{range} ауқымындағы бос ұяшықтар саны"

#: ../plugins/fn-info/functions.c:474
msgid "range:a cell range"
msgstr "range:ұяшықтар ауқымы"

#: ../plugins/fn-info/functions.c:476
msgid "COUNTBLANK(A1:A20) returns the number of blank cell in A1:A20."
msgstr "COUNTBLANK(A1:A20) функциясы A1:A20 ауқымындағы бос ұяшықтар санын қайтарады."

#: ../plugins/fn-info/functions.c:528
msgid "INFO:information about the current operating environment according to @{type}"
msgstr "INFO:@{type} түріне сәйкес ағымдағы жұмыс ортасы туралы ақпарат"

#: ../plugins/fn-info/functions.c:530
msgid "type:string giving the type of information requested"
msgstr "type:сұралған ақпарат түрін көрсететін жол"

#: ../plugins/fn-info/functions.c:531
msgid ""
"INFO returns information about the current operating environment according to @{type}:\n"
"  memavail     \t\tReturns the amount of memory available, bytes.\n"
"  memused      \tReturns the amount of memory used (bytes).\n"
"  numfile      \t\tReturns the number of active worksheets.\n"
"  osversion    \t\tReturns the operating system version.\n"
"  recalc       \t\tReturns the recalculation mode (automatic).\n"
"  release      \t\tReturns the version of Gnumeric as text.\n"
"  system       \t\tReturns the name of the environment.\n"
"  totmem       \t\tReturns the amount of total memory available."
msgstr ""
"INFO функциясы @{type} түріне сәйкес ағымдағы жұмыс ортасы туралы ақпаратты қайтарады:\n"
"  memavail     \t\tҚолжетімді жад көлемі, байт.\n"
"  memused      \tҚолданыстағы жад көлемі (байт).\n"
"  numfile      \t\tБелсенді жұмыс беттерінің саны.\n"
"  osversion    \t\tОперациялық жүйе нұсқасы.\n"
"  recalc       \t\tҚайта есептеу режимі (автоматты).\n"
"  release      \t\tGnumeric нұсқасы мәтін ретінде.\n"
"  system       \t\tОртаның аты.\n"
"  totmem       \t\tЖалпы қолжетімді жад көлемі."

#: ../plugins/fn-info/functions.c:627
msgid "ISERROR:TRUE if @{value} is any error value"
msgstr "ISERROR:егер @{value} кез келген қате мәні болса, АҚИҚАТ"

#: ../plugins/fn-info/functions.c:628 ../plugins/fn-info/functions.c:646 ../plugins/fn-info/functions.c:668 ../plugins/fn-info/functions.c:758 ../plugins/fn-info/functions.c:796 ../plugins/fn-info/functions.c:814 ../plugins/fn-info/functions.c:831 ../plugins/fn-info/functions.c:870 ../plugins/fn-info/functions.c:900 ../plugins/fn-info/functions.c:950
msgid "value:a value"
msgstr "value:мән"

#: ../plugins/fn-info/functions.c:645
msgid "ISNA:TRUE if @{value} is the #N/A error value"
msgstr "ISNA:егер @{value} мәні #N/A қате мәні болса, АҚИҚАТ"

#: ../plugins/fn-info/functions.c:667
msgid "ISERR:TRUE if @{value} is any error value except #N/A"
msgstr "ISERR:егер @{value} мәні #N/A-дан басқа кез келген қате мәні болса, АҚИҚАТ"

#: ../plugins/fn-info/functions.c:686
msgid "ERROR.TYPE:the type of @{error}"
msgstr "ERROR.TYPE:@{error} қатесінің түрі"

#: ../plugins/fn-info/functions.c:687
msgid "error:an error"
msgstr "error:қате"

#: ../plugins/fn-info/functions.c:688
msgid ""
"ERROR.TYPE returns an error number corresponding to the given error value.  The error numbers for error values are:\n"
"\n"
"\t#DIV/0!  \t\t2\n"
"\t#VALUE!  \t3\n"
"\t#REF!    \t\t4\n"
"\t#NAME?   \t5\n"
"\t#NUM!    \t6\n"
"\t#N/A     \t\t7"
msgstr ""
"ERROR.TYPE берілген қате мәніне сәйкес қате нөмірін қайтарады. Қате мәндері үшін қате нөмірлері мынадай:\n"
"\n"
"\t#DIV/0!  \t\t2\n"
"\t#VALUE!  \t3\n"
"\t#REF!    \t\t4\n"
"\t#NAME?   \t5\n"
"\t#NUM!    \t6\n"
"\t#N/A     \t\t7"

#: ../plugins/fn-info/functions.c:722
msgid "NA:the error value #N/A"
msgstr "NA:#N/A қате мәні"

#: ../plugins/fn-info/functions.c:740
msgid "ERROR:the error with the given @{name}"
msgstr "ERROR:берілген @{name} атауы бар қате"

#: ../plugins/fn-info/functions.c:741
msgid "name:string"
msgstr "name:жол"

#: ../plugins/fn-info/functions.c:757
msgid "ISBLANK:TRUE if @{value} is blank"
msgstr "ISBLANK:егер @{value} бос болса, АҚИҚАТ"

#: ../plugins/fn-info/functions.c:759
msgid "This function checks if a value is blank.  Empty cells are blank, but empty strings are not."
msgstr "Бұл функция мәннің бос екенін тексереді. Бос ұяшықтар бос болып саналады, бірақ бос жолдар олай емес."

#: ../plugins/fn-info/functions.c:774
msgid "ISEVEN:TRUE if @{n} is even"
msgstr "ISEVEN:егер @{n} жұп болса, АҚИҚАТ"

