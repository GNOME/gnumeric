msgid "x:a binary number, either as a string or as a number involving only the digits 0 and 1"
msgstr "x: екілік сан, жол ретінде немесе тек 0 мен 1 цифрларынан тұратын сан ретінде"

#: ../plugins/fn-eng/functions.c:257
msgid "BIN2OCT:octal representation of the binary number @{x}"
msgstr "BIN2OCT: @{x} екілік санының сегіздік өрнектелуі"

#: ../plugins/fn-eng/functions.c:259 ../plugins/fn-eng/functions.c:283 ../plugins/fn-eng/functions.c:308 ../plugins/fn-eng/functions.c:338 ../plugins/fn-eng/functions.c:361 ../plugins/fn-eng/functions.c:438 ../plugins/fn-eng/functions.c:461 ../plugins/fn-eng/functions.c:484 ../plugins/fn-eng/functions.c:507
msgid "places:number of digits"
msgstr "places: цифрлар саны"

#: ../plugins/fn-eng/functions.c:260
msgid "If @{places} is given, BIN2OCT pads the result with zeros to achieve exactly @{places} digits. If this is not possible, BIN2OCT returns #NUM!"
msgstr "Егер @{places} берілсе, BIN2OCT дәл @{places} цифрға жету үшін нәтижені нөлдермен толықтырады. Егер бұл мүмкін болмаса, BIN2OCT #NUM! қайтарады"

#: ../plugins/fn-eng/functions.c:281
msgid "BIN2HEX:hexadecimal representation of the binary number @{x}"
msgstr "BIN2HEX: @{x} екілік санының он алтылық өрнектелуі"

#: ../plugins/fn-eng/functions.c:284
msgid "If @{places} is given, BIN2HEX pads the result with zeros to achieve exactly @{places} digits. If this is not possible, BIN2HEX returns #NUM!"
msgstr "Егер @{places} берілсе, BIN2HEX дәл @{places} цифрға жету үшін нәтижені нөлдермен толықтырады. Егер бұл мүмкін болмаса, BIN2HEX #NUM! қайтарады"

