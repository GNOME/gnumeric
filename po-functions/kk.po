#: ../plugins/fn-eng/functions.c:831
msgid "This function is Excel compatible (except \"picapt\")."
msgstr "Бұл функция («picapt»-тан басқа) Excel бағдарламасымен үйлесімді."

#: ../plugins/fn-eng/functions.c:1419
msgid "ERF:Gauss error function"
msgstr "ERF: Гаусс қателіктер функциясы"

#: ../plugins/fn-eng/functions.c:1420
msgid "lower:lower limit of the integral, defaults to 0"
msgstr "lower: интегралдың төменгі шегі, бастапқыда 0"

#: ../plugins/fn-eng/functions.c:1421
msgid "upper:upper limit of the integral"
msgstr "upper: интегралдың жоғарғы шегі"

#: ../plugins/fn-eng/functions.c:1422
msgid "ERF returns 2/sqrt(π)* integral from @{lower} to @{upper} of exp(-t*t) dt"
msgstr "ERF @{lower} шегінен @{upper} шегіне дейінгі exp(-t*t) dt интегралының 2/sqrt(π)* мәнін қайтарады"

#: ../plugins/fn-eng/functions.c:1423
msgid "This function is Excel compatible if two arguments are supplied and neither is negative."
msgstr "Бұл функция, егер екі аргумент берілсе және ешқайсысы теріс болмаса, Excel бағдарламасымен үйлесімді."

#: ../plugins/fn-eng/functions.c:1428 ../plugins/fn-eng/functions.c:1455
msgid "wiki:en:Error_function"
msgstr "wiki:en:Error_function"

#: ../plugins/fn-eng/functions.c:1450
msgid "ERFC:Complementary Gauss error function"
msgstr "ERFC: Қосымша Гаусс қателіктер функциясы"

#: ../plugins/fn-eng/functions.c:1452
msgid "ERFC returns 2/sqrt(π)* integral from @{x} to ∞ of exp(-t*t) dt"
msgstr "ERFC @{x} мәнінен ∞ мәніне дейінгі exp(-t*t) dt интегралының 2/sqrt(π)* мәнін қайтарады"

#: ../plugins/fn-eng/functions.c:1470
msgid "DELTA:Kronecker delta function"
msgstr "DELTA: Кронекер дельта функциясы"

#: ../plugins/fn-eng/functions.c:1471 ../plugins/fn-eng/functions.c:1494
msgid "x0:number"
msgstr "x0: сан"

#: ../plugins/fn-eng/functions.c:1472 ../plugins/fn-eng/functions.c:1495
msgid "x1:number, defaults to 0"
msgstr "x1: сан, бастапқыда 0"

#: ../plugins/fn-eng/functions.c:1473
msgid "DELTA  returns 1 if  @{x1} = @{x0} and 0 otherwise."
msgstr "DELTA егер @{x1} = @{x0} болса 1-ді, әйтпесе 0-ді қайтарады."

#: ../plugins/fn-eng/functions.c:1474 ../plugins/fn-eng/functions.c:1497
msgid "If either argument is non-numeric, #VALUE! is returned."
msgstr "Егер аргументтердің бірі сандық болмаса, #VALUE! қайтарылады."

#: ../plugins/fn-eng/functions.c:1493
msgid "GESTEP:step function with step at @{x1} evaluated at @{x0}"
msgstr "GESTEP: @{x0} нүктесінде есептелген, @{x1} нүктесінде сатысы (step) бар сатылы функция"

#: ../plugins/fn-eng/functions.c:1496
msgid "GESTEP returns 1 if  @{x1} ≤ @{x0} and 0 otherwise."
msgstr "GESTEP егер @{x1} ≤ @{x0} болса 1-ді, әйтпесе 0-ді қайтарады."

#: ../plugins/fn-eng/functions.c:1516
msgid "HEXREP:hexadecimal representation of numeric value"
msgstr "HEXREP: сандық мәннің он алтылық өрнектелуі"

#: ../plugins/fn-eng/functions.c:1518
msgid "HEXREP returns a hexadecimal string representation of @{x}."
msgstr "HEXREP @{x} мәнінің он алтылық жол түріндегі өрнегін қайтарады."

#: ../plugins/fn-eng/functions.c:1519
msgid "This is a function meant for debugging.  The layout of the result may change and even depend on how Gnumeric was compiled."
msgstr "Бұл — жөндеуге (debugging) арналған функция. Нәтиженің құрылымы өзгеруі мүмкін және тіпті Gnumeric-тің қалай құрастырылғанына да байланысты болуы мүмкін."

#: ../plugins/fn-eng/functions.c:1549
msgid "INVSUMINV:the reciprocal of the sum of reciprocals of the arguments"
msgstr "INVSUMINV: аргументтердің кері мәндерінің қосындысына кері мән"

#: ../plugins/fn-eng/functions.c:1550
msgid "x0:non-negative number"
msgstr "x0: теріс емес сан"

#: ../plugins/fn-eng/functions.c:1551
msgid "x1:non-negative number"
msgstr "x1: теріс емес сан"

#: ../plugins/fn-eng/functions.c:1552
msgid ""
"If any of the arguments is negative, #VALUE! is returned.\n"
"If any argument is zero, the result is zero."
msgstr ""
"Егер аргументтердің кез келгені теріс болса, #VALUE! қайтарылады.\n"
"Егер кез келген аргумент нөлге тең болса, нәтиже нөл болады."

#: ../plugins/fn-eng/functions.c:1554
msgid "INVSUMINV sum calculates the reciprocal (the inverse) of the sum of reciprocals (inverses) of all its arguments."
msgstr "INVSUMINV қосындысы барлық аргументтерінің кері мәндерінің қосындысына кері мәнді (кері шаманы) есептейді."

#: ../plugins/fn-erlang/functions.c:103
msgid "PROBBLOCK:probability of blocking"
msgstr "PROBBLOCK: бұғаттау ықтималдығы"

#: ../plugins/fn-erlang/functions.c:104 ../plugins/fn-erlang/functions.c:189
msgid "traffic:number of calls"
msgstr "traffic: қоңыраулар саны"

#: ../plugins/fn-erlang/functions.c:105 ../plugins/fn-erlang/functions.c:130 ../plugins/fn-erlang/functions.c:227
msgid "circuits:number of circuits"
msgstr "circuits: тізбектер саны"

#: ../plugins/fn-erlang/functions.c:106
msgid "PROBBLOCK returns probability of blocking when @{traffic} calls load into @{circuits} circuits."
msgstr "PROBBLOCK @{traffic} қоңыраулар @{circuits} тізбектеріне жүктелген кездегі бұғаттау ықтималдығын қайтарады."

#: ../plugins/fn-erlang/functions.c:108 ../plugins/fn-erlang/functions.c:132
msgid "@{traffic} cannot exceed @{circuits}."
msgstr "@{traffic} мәні @{circuits} мәнінен аспауы керек."

#: ../plugins/fn-erlang/functions.c:128
msgid "OFFTRAF:predicted number of offered calls"
msgstr "OFFTRAF: ұсынылған қоңыраулардың болжамды саны"

#: ../plugins/fn-erlang/functions.c:129
msgid "traffic:number of carried calls"
msgstr "traffic: орындалған қоңыраулар саны"

#: ../plugins/fn-erlang/functions.c:131
msgid "OFFTRAF returns the predicted number of offered calls given @{traffic} carried calls (taken from measurements) on @{circuits} circuits."
msgstr "OFFTRAF @{circuits} тізбектегі @{traffic} орындалған қоңыраулар (өлшемдерден алынған) бойынша ұсынылған қоңыраулардың болжамды санын қайтарады."

#: ../plugins/fn-erlang/functions.c:188
msgid "DIMCIRC:number of circuits required"
msgstr "DIMCIRC: қажетті тізбектер саны"

#: ../plugins/fn-erlang/functions.c:190 ../plugins/fn-erlang/functions.c:228
msgid "gos:grade of service"
msgstr "gos: қызмет көрсету сапасы"

#: ../plugins/fn-erlang/functions.c:191
msgid "DIMCIRC returns the number of circuits required given @{traffic} calls with grade of service @{gos}."
msgstr "DIMCIRC @{gos} қызмет көрсету сапасымен @{traffic} қоңыраулар үшін қажетті тізбектер санын қайтарады."

#: ../plugins/fn-erlang/functions.c:226
msgid "OFFCAP:traffic capacity"
msgstr "OFFCAP: трафик сыйымдылығы"

#: ../plugins/fn-erlang/functions.c:229
msgid "OFFCAP returns the traffic capacity given @{circuits} circuits with grade of service @{gos}."
msgstr "OFFCAP @{gos} қызмет көрсету сапасымен @{circuits} тізбектері үшін трафик сыйымдылығын қайтарады."

#. *************************************************************************
#: ../plugins/fn-financial/functions.c:51
msgid "@{frequency} may be 1 (annual), 2 (semi-annual), or 4 (quarterly)."
msgstr "@{frequency} 1 (жылдық), 2 (жарты жылдық) немесе 4 (тоқсандық) болуы мүмкін."

#: ../plugins/fn-financial/functions.c:54
msgid "If @{type} is 0, the default, payment is at the end of each period.  If @{type} is 1, payment is at the beginning of each period."
msgstr "Егер @{type} 0 (үнсіз келісім бойынша) болса, төлем әр кезеңнің соңында жасалады. Егер @{type} 1 болса, төлем әр кезеңнің басында жасалады."

#: ../plugins/fn-financial/functions.c:360
msgid "ACCRINT:accrued interest"
msgstr "ACCRINT: есептелген пайыздар"

#: ../plugins/fn-financial/functions.c:361 ../plugins/fn-financial/functions.c:449 ../plugins/fn-financial/functions.c:605 ../plugins/fn-financial/functions.c:2464 ../plugins/fn-financial/functions.c:2503 ../plugins/fn-financial/functions.c:2654
msgid "issue:date of issue"
msgstr "issue: шығарылған күні"

#: ../plugins/fn-financial/functions.c:362
msgid "first_interest:date of first interest payment"
msgstr "first_interest: алғашқы пайыздық төлем күні"

#: ../plugins/fn-financial/functions.c:363 ../plugins/fn-financial/functions.c:488 ../plugins/fn-financial/functions.c:526 ../plugins/fn-financial/functions.c:567 ../plugins/fn-financial/functions.c:603 ../plugins/fn-financial/functions.c:648 ../plugins/fn-financial/functions.c:1086 ../plugins/fn-financial/functions.c:1124 ../plugins/fn-financial/functions.c:1158 ../plugins/fn-financial/functions.c:1893 ../plugins/fn-financial/functions.c:2258
#: ../plugins/fn-financial/functions.c:2308 ../plugins/fn-financial/functions.c:2417 ../plugins/fn-financial/functions.c:2462 ../plugins/fn-financial/functions.c:2501 ../plugins/fn-financial/functions.c:2652 ../plugins/fn-financial/functions.c:2748 ../plugins/fn-financial/functions.c:2826 ../plugins/fn-financial/functions.c:3006 ../plugins/fn-financial/functions.c:3030 ../plugins/fn-financial/functions.c:3054 ../plugins/fn-financial/functions.c:3078
#: ../plugins/fn-financial/functions.c:3104 ../plugins/fn-financial/functions.c:3130 ../plugins/fn-financial/functions.c:3242
msgid "settlement:settlement date"
msgstr "settlement: есеп айырысу күні"

#: ../plugins/fn-financial/functions.c:364 ../plugins/fn-financial/functions.c:451 ../plugins/fn-financial/functions.c:529 ../plugins/fn-financial/functions.c:686 ../plugins/fn-financial/functions.c:2260 ../plugins/fn-financial/functions.c:2310 ../plugins/fn-financial/functions.c:2465 ../plugins/fn-financial/functions.c:2505 ../plugins/fn-financial/functions.c:2656 ../plugins/fn-financial/functions.c:2751 ../plugins/fn-financial/functions.c:2829
msgid "rate:nominal annual interest rate"
msgstr "rate: номиналды жылдық пайыздық мөлшерлеме"

#: ../plugins/fn-financial/functions.c:365
msgid "par:par value, defaults to $1000"
msgstr "par: номиналды құны, үнсіз келісім бойынша $1000"

#: ../plugins/fn-financial/functions.c:366 ../plugins/fn-financial/functions.c:1897 ../plugins/fn-financial/functions.c:2263 ../plugins/fn-financial/functions.c:2313 ../plugins/fn-financial/functions.c:2508 ../plugins/fn-financial/functions.c:2659 ../plugins/fn-financial/functions.c:2754 ../plugins/fn-financial/functions.c:2832 ../plugins/fn-financial/functions.c:3008 ../plugins/fn-financial/functions.c:3032 ../plugins/fn-financial/functions.c:3056
#: ../plugins/fn-financial/functions.c:3080 ../plugins/fn-financial/functions.c:3106 ../plugins/fn-financial/functions.c:3132 ../plugins/fn-financial/functions.c:3246
msgid "frequency:number of interest payments per year"
msgstr "frequency: жылына төленетін пайыздық төлемдер саны"

#: ../plugins/fn-financial/functions.c:367
msgid "basis:calendar basis, defaults to 0"
msgstr "basis: күнтізбелік негіз, үнсіз келісім бойынша 0"

#: ../plugins/fn-financial/functions.c:368
msgid "calc_method:calculation method, defaults to TRUE"
msgstr "calc_method: есептеу әдісі, үнсіз келісім бойынша TRUE"

#: ../plugins/fn-financial/functions.c:370
msgid "If @{first_interest} < @{settlement} and @{calc_method} is TRUE, then ACCRINT returns the sum of the interest accrued in all coupon periods from @{issue}  date until @{settlement} date."
msgstr "Егер @{first_interest} < @{settlement} және @{calc_method} TRUE болса, онда ACCRINT @{issue} күнінен бастап @{settlement} күніне дейінгі барлық купондық кезеңдерде жиналған пайыздардың қосындысын қайтарады."

#: ../plugins/fn-financial/functions.c:375
msgid "If @{first_interest} < @{settlement} and @{calc_method} is FALSE, then ACCRINT returns the sum of the interest accrued in all coupon periods from @{first_interest}  date until @{settlement} date."
msgstr "Егер @{first_interest} < @{settlement} және @{calc_method} FALSE болса, онда ACCRINT @{first_interest} күнінен бастап @{settlement} күніне дейінгі барлық купондық кезеңдерде жиналған пайыздардың қосындысын қайтарады."

#: ../plugins/fn-financial/functions.c:380
msgid "Otherwise ACCRINT returns the sum of the interest accrued in all coupon periods from @{issue}  date until @{settlement} date."
msgstr "Әйтпесе, ACCRINT @{issue} күнінен бастап @{settlement} күніне дейінгі барлық купондық кезеңдерде жиналған пайыздардың қосындысын қайтарады."

#: ../plugins/fn-financial/functions.c:383
msgid "@{frequency} must be one of 1, 2 or 4, but the exact value does not affect the result."
msgstr "@{frequency} 1, 2 немесе 4 мәндерінің бірі болуы тиіс, бірақ нақты мән нәтижеге әсер етпейді."

#: ../plugins/fn-financial/functions.c:385
msgid "@{issue} must precede both @{first_interest} and @{settlement}."
msgstr "@{issue} күні @{first_interest} және @{settlement} күндерінен бұрын болуы керек."

