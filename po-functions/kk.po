msgid "number1:first value"
msgstr "number1: бірінші мән"

#: ../plugins/fn-stat/functions.c:607 ../plugins/fn-stat/functions.c:634 ../plugins/fn-stat/functions.c:733 ../plugins/fn-stat/functions.c:759 ../plugins/fn-stat/functions.c:785 ../plugins/fn-stat/functions.c:810 ../plugins/fn-stat/functions.c:835 ../plugins/fn-stat/functions.c:860 ../plugins/fn-stat/functions.c:894 ../plugins/fn-stat/functions.c:928 ../plugins/fn-stat/functions.c:956 ../plugins/fn-stat/functions.c:2069 ../plugins/fn-stat/functions.c:2099
#: ../plugins/fn-stat/functions.c:2124 ../plugins/fn-stat/functions.c:2147 ../plugins/fn-stat/functions.c:2272 ../plugins/fn-stat/functions.c:2708 ../plugins/fn-stat/functions.c:2732 ../plugins/fn-stat/functions.c:2757
msgid "number2:second value"
msgstr "number2: екінші мән"

#: ../plugins/fn-stat/functions.c:609 ../plugins/fn-stat/functions.c:636
msgid "If the data set does not contain any duplicates this function returns a #N/A error."
msgstr "Егер деректер жиынында ешқандай қайталанатын мәндер болмаса, бұл функция #N/A қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:613 ../plugins/fn-stat/functions.c:640
msgid "wiki:en:Mode_(statistics)"
msgstr "wiki:kk:Мода_(статистика)"

#: ../plugins/fn-stat/functions.c:614 ../plugins/fn-stat/functions.c:641
msgid "wolfram:Mode.html"
msgstr "wolfram:Mode.html"

#: ../plugins/fn-stat/functions.c:632
msgid "MODE.MULT:most common numbers in the dataset"
msgstr "MODE.MULT: деректер жиынындағы ең көп кездесетін сандар"

#: ../plugins/fn-stat/functions.c:731
msgid "HARMEAN:harmonic mean"
msgstr "HARMEAN: гармоникалық орташа мән"

#: ../plugins/fn-stat/functions.c:734
msgid "The harmonic mean of N data points is N divided by the sum of the reciprocals of the data points)."
msgstr "N деректер нүктесінің гармоникалық орташа мәні — бұл N санын деректер нүктелеріне кері шамалардың қосындысына бөлгенге тең."

#: ../plugins/fn-stat/functions.c:738
msgid "wiki:en:Harmonic_mean"
msgstr "wiki:kk:Гармоникалық_орта_шама"

#: ../plugins/fn-stat/functions.c:739
msgid "wolfram:HarmonicMean.html"
msgstr "wolfram:HarmonicMean.html"

#: ../plugins/fn-stat/functions.c:757
msgid "GEOMEAN:geometric mean"
msgstr "GEOMEAN: геометриялық орташа мән"

#: ../plugins/fn-stat/functions.c:760
msgid "The geometric mean is equal to the Nth root of the product of the N values."
msgstr "Геометриялық орташа мән N мәннің көбейтіндісінің N-ші дәрежелі түбіріне тең."

#: ../plugins/fn-stat/functions.c:764
msgid "wiki:en:Geometric_mean"
msgstr "wiki:kk:Геометриялық_орта_шама"

#: ../plugins/fn-stat/functions.c:765
msgid "wolfram:GeometricMean.html"
msgstr "wolfram:GeometricMean.html"

#: ../plugins/fn-stat/functions.c:783
msgid "COUNT:total number of integer or floating point arguments passed"
msgstr "COUNT: берілген бүтін немесе жылжымалы нүктелі аргументтердің жалпы саны"

#: ../plugins/fn-stat/functions.c:788
msgid "Then COUNT(A1:A5) equals 5."
msgstr "Онда COUNT(A1:A5) мәні 5-ке тең болады."

#: ../plugins/fn-stat/functions.c:808
msgid "COUNTA:number of arguments passed not including empty cells"
msgstr "COUNTA: берілген аргументтердің саны (бос ұяшықтарды қоспағанда)"

#: ../plugins/fn-stat/functions.c:812
msgid "Let us assume that the cells A1, A2, ..., A5 contain numbers and strings 11.4, \"missing\", \"missing\", 25.9, and 40.1."
msgstr "A1, A2, ..., A5 ұяшықтарында 11.4, \"missing\", \"missing\", 25.9 және 40.1 сандары мен жолдары бар деп есептейік."

#: ../plugins/fn-stat/functions.c:813
msgid "Then COUNTA(A1:A5) equals 5."
msgstr "Онда COUNTA(A1:A5) 5-ке тең болады."

#: ../plugins/fn-stat/functions.c:833
msgid "AVERAGE:average of all the numeric values and cells"
msgstr "AVERAGE: барлық сандық мәндер мен ұяшықтардың орташа мәні"

#: ../plugins/fn-stat/functions.c:839
msgid "wiki:en:Arithmetic_mean"
msgstr "wiki:en:Arithmetic_mean"

#: ../plugins/fn-stat/functions.c:840
msgid "wolfram:ArithmeticMean.html"
msgstr "wolfram:ArithmeticMean.html"

#: ../plugins/fn-stat/functions.c:858
msgid "MIN:smallest value, with negative numbers considered smaller than positive numbers"
msgstr "MIN: ең кіші мән, теріс сандар оң сандардан кіші деп есептеледі"

#: ../plugins/fn-stat/functions.c:892
msgid "MAX:largest value, with negative numbers considered smaller than positive numbers"
msgstr "MAX: ең үлкен мән, теріс сандар оң сандардан кіші деп есептеледі"

#: ../plugins/fn-stat/functions.c:926
msgid "SKEW:unbiased estimate for skewness of a distribution"
msgstr "SKEW: үлестірім асимметриясының бейтарап бағасы"

#: ../plugins/fn-stat/functions.c:930
msgid "This is only meaningful if the underlying distribution really has a third moment.  The skewness of a symmetric (e.g., normal) distribution is zero."
msgstr "Бұл негізгі үлестірімнің үшінші моменті болған жағдайда ғана мағыналы болады. Симметриялы (мысалы, қалыпты) үлестірімнің асимметриясы нөлге тең."

#: ../plugins/fn-stat/functions.c:933
msgid "If less than three numbers are given, this function returns a #DIV/0! error."
msgstr "Егер үштен аз сан берілсе, бұл функция #DIV/0! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:954
msgid "SKEWP:population skewness of a data set"
msgstr "SKEWP: деректер жиынтығының бас жиынтық асимметриясы"

#: ../plugins/fn-stat/functions.c:958
msgid "If less than two numbers are given, SKEWP returns a #DIV/0! error."
msgstr "Егер екіден аз сан берілсе, SKEWP #DIV/0! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:978
msgid "EXPONDIST:probability density or cumulative distribution function of the exponential distribution"
msgstr "EXPONDIST: экспоненциалды үлестірімнің ықтималдық тығыздығы немесе интегралдық үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:980
msgid "y:scale parameter"
msgstr "y: масштаб параметрі"

#: ../plugins/fn-stat/functions.c:981 ../plugins/fn-stat/functions.c:1051 ../plugins/fn-stat/functions.c:1291 ../plugins/fn-stat/functions.c:1759 ../plugins/fn-stat/functions.c:1974 ../plugins/fn-stat/functions.c:2010
msgid "cumulative:whether to evaluate the density function or the cumulative distribution function"
msgstr "cumulative: тығыздық функциясын немесе интегралдық үлестірім функциясын есептеу керектігі"

#: ../plugins/fn-stat/functions.c:982
msgid "If @{cumulative} is false it will return:\t@{y} * exp (-@{y}*@{x}), otherwise it will return\t1 - exp (-@{y}*@{x})."
msgstr "Егер @{cumulative} мәні «жалған» болса, ол келесіні қайтарады:\t@{y} * exp (-@{y}*@{x}), әйтпесе келесіні қайтарады\t1 - exp (-@{y}*@{x})."

#: ../plugins/fn-stat/functions.c:985
msgid "If @{x} < 0 or @{y} <= 0 this will return an error."
msgstr "Егер @{x} < 0 немесе @{y} <= 0 болса, бұл қате қайтарады."

#: ../plugins/fn-stat/functions.c:1011
msgid "BERNOULLI:probability mass function of a Bernoulli distribution"
msgstr "BERNOULLI: Бернулли үлестірімінің ықтималдық массасы функциясы"

#: ../plugins/fn-stat/functions.c:1012
msgid "k:integer"
msgstr "k: бүтін сан"

#: ../plugins/fn-stat/functions.c:1014
msgid "If @{k} != 0 and @{k} != 1 this function returns a #NUM! error."
msgstr "Егер @{k} != 0 және @{k} != 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1047
msgid "GAMMADIST:probability density or cumulative distribution function of the gamma distribution"
msgstr "GAMMADIST: гамма-үлестірімнің ықтималдық тығыздығы немесе интегралдық үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:1049 ../plugins/fn-stat/functions.c:1082 ../plugins/fn-stat/functions.c:1254 ../plugins/fn-stat/functions.c:1289 ../plugins/fn-stat/functions.c:1332 ../plugins/fn-stat/functions.c:1972
msgid "alpha:scale parameter"
msgstr "alpha: масштаб параметрі"

#: ../plugins/fn-stat/functions.c:1050 ../plugins/fn-stat/functions.c:1083 ../plugins/fn-stat/functions.c:1255 ../plugins/fn-stat/functions.c:1290 ../plugins/fn-stat/functions.c:1333 ../plugins/fn-stat/functions.c:1973
msgid "beta:scale parameter"
msgstr "beta: масштаб параметрі"

#: ../plugins/fn-stat/functions.c:1052 ../plugins/fn-stat/functions.c:1459 ../plugins/fn-stat/functions.c:1978 ../plugins/fn-stat/functions.c:2198
msgid "If @{x} < 0 this function returns a #NUM! error."
msgstr "Егер @{x} < 0 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1053 ../plugins/fn-stat/functions.c:1259 ../plugins/fn-stat/functions.c:1296 ../plugins/fn-stat/functions.c:1337
msgid "If @{alpha} <= 0 or @{beta} <= 0, this function returns a #NUM! error."
msgstr "Егер @{alpha} <= 0 немесе @{beta} <= 0 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1080
msgid "GAMMAINV:inverse of the cumulative gamma distribution"
msgstr "GAMMAINV: интегралдық гамма-үлестірімнің кері функциясы"

#: ../plugins/fn-stat/functions.c:1085 ../plugins/fn-stat/functions.c:1979
msgid "If @{alpha} <= 0 or @{beta} <= 0 this function returns a #NUM! error."
msgstr "Егер @{alpha} <= 0 немесе @{beta} <= 0 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1110
msgid "CHIDIST:survival function of the chi-squared distribution"
msgstr "CHIDIST: хи-квадрат үлестірімінің өміршеңдік функциясы"

#: ../plugins/fn-stat/functions.c:1112 ../plugins/fn-stat/functions.c:1140 ../plugins/fn-stat/functions.c:1367 ../plugins/fn-stat/functions.c:1419
msgid "dof:number of degrees of freedom"
msgstr "dof: еркіндік дәрежелерінің саны"

#: ../plugins/fn-stat/functions.c:1113 ../plugins/fn-stat/functions.c:1141 ../plugins/fn-stat/functions.c:1369 ../plugins/fn-stat/functions.c:1458 ../plugins/fn-stat/functions.c:1663
msgid "The survival function is 1 minus the cumulative distribution function."
msgstr "Өміршеңдік функциясы 1-ден интегралдық үлестірім функциясын азайтқанға тең."

#: ../plugins/fn-stat/functions.c:1114
msgid "If @{dof} is non-integer it is truncated."
msgstr "Егер @{dof} бүтін сан болмаса, ол қиып жіберіледі."

#: ../plugins/fn-stat/functions.c:1115 ../plugins/fn-stat/functions.c:1370
msgid "If @{dof} < 1 this function returns a #NUM! error."
msgstr "Егер @{dof} < 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1117
msgid "CHIDIST(@{x},@{dof}) is the OpenFormula function LEGACY.CHIDIST(@{x},@{dof})."
msgstr "CHIDIST(@{x},@{dof}) — бұл LEGACY.CHIDIST(@{x},@{dof}) OpenFormula функциясы."

#: ../plugins/fn-stat/functions.c:1138
msgid "CHIINV:inverse of the survival function of the chi-squared distribution"
msgstr "CHIINV: хи-квадрат үлестірімінің кері өміршеңдік функциясы"

#: ../plugins/fn-stat/functions.c:1142 ../plugins/fn-stat/functions.c:1423
msgid "If @{p} < 0 or @{p} > 1 or @{dof} < 1 this function returns a #NUM! error."
msgstr "Егер @{p} < 0 немесе @{p} > 1 немесе @{dof} < 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1144
msgid "CHIINV(@{p},@{dof}) is the OpenFormula function LEGACY.CHIDIST(@{p},@{dof})."
msgstr "CHIINV(@{p},@{dof}) — бұл LEGACY.CHIDIST(@{p},@{dof}) OpenFormula функциясы."

#: ../plugins/fn-stat/functions.c:1165
msgid "CHITEST:p value of the Goodness of Fit Test"
msgstr "CHITEST: келісімділік критерийінің p-мәні"

#: ../plugins/fn-stat/functions.c:1166
msgid "actual_range:observed data"
msgstr "actual_range: бақыланатын деректер"

#: ../plugins/fn-stat/functions.c:1167
msgid "theoretical_range:expected values"
msgstr "theoretical_range: күтілетін мәндер"

#: ../plugins/fn-stat/functions.c:1168
msgid "If the actual range is not an n by 1 or 1 by n range, but an n by m range, then CHITEST uses (n-1) times (m-1) as degrees of freedom. This is useful if the expected values were calculated from the observed value in a test of independence or test of homogeneity."
msgstr "Егер нақты ауқым n-ге 1 немесе 1-ге n ауқымы емес, n-ге m ауқымы болса, онда CHITEST еркіндік дәрежесі ретінде (n-1) * (m-1) мәнін пайдаланады. Бұл тәуелсіздік немесе біртектілік тестінде бақыланатын мәннен күтілетін мәндер есептелген жағдайда пайдалы."

#: ../plugins/fn-stat/functions.c:1174
msgid "CHITEST is the OpenFormula function LEGACY.CHITEST."
msgstr "CHITEST — бұл LEGACY.CHITEST OpenFormula функциясы."

#: ../plugins/fn-stat/functions.c:1252
msgid "BETADIST:cumulative distribution function of the beta distribution"
msgstr "BETADIST: бета-үлестірімнің интегралдық үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:1256 ../plugins/fn-stat/functions.c:1293 ../plugins/fn-stat/functions.c:1334
msgid "a:optional lower bound, defaults to 0"
msgstr "a: міндетті емес төменгі шек, бастапқы мәні 0"

#: ../plugins/fn-stat/functions.c:1257 ../plugins/fn-stat/functions.c:1294 ../plugins/fn-stat/functions.c:1335
msgid "b:optional upper bound, defaults to 1"
msgstr "b: міндетті емес жоғарғы шек, бастапқы мәні 1"

#: ../plugins/fn-stat/functions.c:1258 ../plugins/fn-stat/functions.c:1295
msgid "If @{x} < @{a} or @{x} > @{b} this function returns a #NUM! error."
msgstr "Егер @{x} < @{a} немесе @{x} > @{b} болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1260 ../plugins/fn-stat/functions.c:1297 ../plugins/fn-stat/functions.c:1338
msgid "If @{a} >= @{b} this function returns a #NUM! error."
msgstr "Егер @{a} >= @{b} болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1287
msgid "BETA.DIST:cumulative distribution function of the beta distribution"
msgstr "BETA.DIST: бета-үлестірімнің интегралдық үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:1330
msgid "BETAINV:inverse of the cumulative distribution function of the beta distribution"
msgstr "BETAINV: бета-үлестірімнің интегралдық үлестірім функциясының кері мәні"

#: ../plugins/fn-stat/functions.c:1365
msgid "TDIST:survival function of the Student t-distribution"
msgstr "TDIST: Стьюденттің t-үлестірімінің өміршеңдік функциясы"

#: ../plugins/fn-stat/functions.c:1368
msgid "tails:1 or 2"
msgstr "tails: 1 немесе 2"

#: ../plugins/fn-stat/functions.c:1371
msgid "If @{tails} is neither 1 or 2 this function returns a #NUM! error."
msgstr "Егер @{tails} 1 де, 2 де болмаса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1372
msgid "The parameterization of this function is different from what is used for, e.g., NORMSDIST.  This is a common source of mistakes, but necessary for compatibility."
msgstr "Бұл функцияның параметризациясы, мысалы, NORMSDIST үшін қолданылатыннан өзгеше. Бұл қателердің жиі кездесетін себебі, бірақ үйлесімділік үшін қажет."

#: ../plugins/fn-stat/functions.c:1375
msgid "This function is Excel compatible for non-negative @{x}."
msgstr "Бұл функция теріс емес @{x} мәндері үшін Excel-мен үйлесімді."

#: ../plugins/fn-stat/functions.c:1417
msgid "TINV:two tailed inverse of the Student t-distribution"
msgstr "TINV: Стьюденттің екі жақты t-үлестірімінің кері мәні"

#: ../plugins/fn-stat/functions.c:1418
msgid "p:probability in both tails"
msgstr "p: екі жақтағы ықтималдық"

#: ../plugins/fn-stat/functions.c:1420
msgid "This function returns the non-negative value x such that the area under the Student t density with @{dof} degrees of freedom to the right of x is @{p}/2."
msgstr "Бұл функция x-тен оң жақтағы @{dof} еркіндік дәрежесі бар Стьюдент t-тығыздығының астындағы аудан @{p}/2 болатындай теріс емес x мәнін қайтарады."

#: ../plugins/fn-stat/functions.c:1425
msgid "The parameterization of this function is different from what is used for, e.g., NORMSINV.  This is a common source of mistakes, but necessary for compatibility."
msgstr "Бұл функцияның параметризациясы, мысалы, NORMSINV үшін қолданылатыннан өзгеше. Бұл қателердің жиі кездесетін себебі, бірақ үйлесімділік үшін қажет."

#: ../plugins/fn-stat/functions.c:1454
msgid "FDIST:survival function of the F distribution"
msgstr "FDIST: F-үлестірімінің өміршеңдік функциясы"

#: ../plugins/fn-stat/functions.c:1456 ../plugins/fn-stat/functions.c:1661
msgid "dof_of_num:numerator degrees of freedom"
msgstr "dof_of_num: алымының еркіндік дәрежелері"

#: ../plugins/fn-stat/functions.c:1457 ../plugins/fn-stat/functions.c:1662
msgid "dof_of_denom:denominator degrees of freedom"
msgstr "dof_of_denom: бөлімінің еркіндік дәрежелері"

#: ../plugins/fn-stat/functions.c:1460
msgid "If @{dof_of_num} < 1 or @{dof_of_denom} < 1, this function returns a #NUM! error."
msgstr "Егер @{dof_of_num} < 1 немесе @{dof_of_denom} < 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1462
msgid "FDIST is the OpenFormula function LEGACY.FDIST."
msgstr "FDIST — бұл LEGACY.FDIST OpenFormula функциясы."

#: ../plugins/fn-stat/functions.c:1484
msgid "LANDAU:approximate probability density function of the Landau distribution"
msgstr "LANDAU: Ландау үлестірімінің жуықталған ықтималдық тығыздық функциясы"

#: ../plugins/fn-stat/functions.c:1659
msgid "FINV:inverse of the survival function of the F distribution"
msgstr "FINV: F-үлестірімінің өміршеңдік функциясының кері мәні"

#: ../plugins/fn-stat/functions.c:1665
msgid "If @{dof_of_num} < 1 or @{dof_of_denom} < 1 this function returns a #NUM! error."
msgstr "Егер @{dof_of_num} < 1 немесе @{dof_of_denom} < 1 болса, бұл функция #NUM! қатесін қайтарады."

#: ../plugins/fn-stat/functions.c:1667
msgid "FINV is the OpenFormula function LEGACY.FINV."
msgstr "FINV — бұл LEGACY.FINV OpenFormula функциясы."

#: ../plugins/fn-stat/functions.c:1689
msgid "BINOMDIST:probability mass or cumulative distribution function of the binomial distribution"
msgstr "BINOMDIST: биномдық үлестірімнің ықтималдық массасы немесе интегралдық үлестірім функциясы"

#: ../plugins/fn-stat/functions.c:1690
msgid "n:number of successes"
msgstr "n: сәттіліктер саны"

#: ../plugins/fn-stat/functions.c:1691 ../plugins/fn-stat/functions.c:1725 ../plugins/fn-stat/functions.c:1787
msgid "trials:number of trials"
msgstr "trials: сынақтар саны"

#: ../plugins/fn-stat/functions.c:1692 ../plugins/fn-stat/functions.c:1726 ../plugins/fn-stat/functions.c:1788
msgid "p:probability of success in each trial"
